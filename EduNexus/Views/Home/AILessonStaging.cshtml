@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Lesson Staging - EduNexus</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            /* Synchronized with EduNexus */
            --primary: #5c24ff;
            --primary-light: #9b8cf8;
            --primary-lighter: #f0edff;
            --bg-color: #fafafa;
            --surface: #ffffff;
            --text-main: #111827;
            --text-muted: #6b7280;
            --border: #e5e7eb;
            --danger: #ef4444;
            --success: #10b981;
            --warning: #f59e0b;
            --ai-gradient: linear-gradient(135deg, #5c24ff 0%, #d946ef 100%);
            --radius-md: 8px;
            --radius-lg: 12px;
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Topbar */
        .topbar {
            height: 70px;
            background-color: var(--surface);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 40px;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .back-btn {
            color: var(--text-muted);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 500;
            font-size: 14px;
            transition: 0.2s;
        }

        .back-btn:hover {
            color: var(--text-main);
        }

        .ai-status-badge {
            background: var(--primary-lighter);
            color: var(--primary);
            padding: 6px 12px;
            border-radius: 100px;
            font-size: 13px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .btn {
            padding: 10px 20px;
            border-radius: var(--radius-md);
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            border: none;
            transition: all 0.2s ease;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-outline {
            background-color: transparent;
            border: 1px solid var(--border);
            color: var(--text-main);
        }

        .btn-outline:hover {
            background-color: var(--bg-color);
        }

        .btn-primary {
            background-color: var(--primary-light);
            color: white;
            box-shadow: 0 4px 12px rgba(155, 140, 248, 0.3);
        }

        .btn-primary:hover {
            background-color: var(--primary);
            box-shadow: 0 6px 16px rgba(92, 36, 255, 0.4);
            transform: translateY(-1px);
        }

        .btn-ai {
            background: var(--ai-gradient);
            color: white;
            border: none;
        }

        .btn-ai:hover {
            opacity: 0.9;
            box-shadow: 0 6px 16px rgba(217, 70, 239, 0.4);
        }

        /* Layout */
        .staging-container {
            flex: 1;
            display: flex;
            padding: 40px;
            max-width: 1400px;
            margin: 0 auto;
            width: 100%;
            gap: 32px;
        }

        .editor-col {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .ai-col {
            width: 400px;
            display: flex;
            flex-direction: column;
            gap: 24px;
        }

        /* Notice Banner */
        .ai-banner {
            background: #faf5ff; /* light purple */
            border: 1px solid #e9d5ff;
            border-radius: var(--radius-lg);
            padding: 16px 24px;
            display: flex;
            align-items: flex-start;
            gap: 16px;
        }

        .ai-banner-icon {
            font-size: 24px;
            background: var(--ai-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .ai-banner-content h4 {
            font-size: 15px;
            font-weight: 700;
            color: #6b21a8;
            margin-bottom: 4px;
        }

        .ai-banner-content p {
            font-size: 14px;
            color: #7e22ce;
            line-height: 1.5;
        }

        /* Main Editor */
        .title-input {
            width: 100%;
            font-size: 32px;
            font-weight: 800;
            color: var(--text-main);
            border: none;
            background: transparent;
            outline: none;
            padding: 10px 0;
            border-bottom: 1px solid transparent;
            transition: 0.2s;
        }

        .title-input:focus {
            border-bottom: 1px solid var(--primary-light);
        }

        .editor-box {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            display: flex;
            flex-direction: column;
            min-height: 500px;
            box-shadow: var(--shadow-sm);
        }

        .editor-toolbar {
            padding: 12px 16px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 8px;
            background-color: #fafafa;
            border-radius: var(--radius-lg) var(--radius-lg) 0 0;
        }

        .toolbar-btn {
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: transparent;
            border: none;
            border-radius: 6px;
            color: var(--text-muted);
            cursor: pointer;
        }

        .toolbar-btn:hover {
            background-color: #e5e7eb;
            color: var(--text-main);
        }

        .editor-content {
            padding: 32px;
            flex: 1;
            outline: none;
            font-size: 16px;
            line-height: 1.7;
            color: var(--text-main);
            overflow-y: auto;
        }

        /* AI Assistant Sidebar */
        .assistant-card {
            background: var(--surface);
            border-radius: var(--radius-lg);
            border: 1px solid var(--border);
            box-shadow: var(--shadow-sm);
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .assistant-header {
            padding: 20px;
            background: #fafafa;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 12px;
            font-weight: 600;
            color: var(--text-main);
        }

        .assistant-header i {
            background: var(--ai-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-size: 20px;
        }

        /* Prompt History */
        .prompt-info {
            padding: 20px;
            border-bottom: 1px solid var(--border);
        }

        .prompt-label {
            font-size: 12px;
            color: var(--text-muted);
            text-transform: uppercase;
            font-weight: 600;
            margin-bottom: 8px;
        }

        .prompt-bubble {
            background: var(--primary-lighter);
            padding: 12px 16px;
            border-radius: var(--radius-md);
            font-size: 14px;
            color: var(--text-main);
            line-height: 1.5;
            position: relative;
        }

        /* Suggestions */
        .suggestions-list {
            padding: 20px;
        }

        .suggestion-item {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            padding: 12px;
            background: #fafafa;
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            margin-bottom: 12px;
            transition: 0.2s;
            cursor: pointer;
        }

        .suggestion-item:hover {
            border-color: var(--primary-light);
            background: var(--surface);
        }

        .suggestion-item i {
            color: #d946ef;
            margin-top: 2px;
        }

        .suggestion-text {
            font-size: 13px;
            color: var(--text-main);
            line-height: 1.5;
        }

        /* Chat Input */
        .ai-chat-input {
            padding: 20px;
            background: #fafafa;
            border-top: 1px solid var(--border);
        }

        .chat-box {
            position: relative;
        }

        .chat-textarea {
            width: 100%;
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 12px 48px 12px 16px;
            font-size: 14px;
            font-family: inherit;
            outline: none;
            resize: none;
            height: 80px;
            transition: 0.2s;
        }

        .chat-textarea:focus {
            border-color: #d946ef;
            box-shadow: 0 0 0 3px rgba(217, 70, 239, 0.1);
        }

        .send-btn {
            position: absolute;
            right: 8px;
            bottom: 8px;
            width: 32px;
            height: 32px;
            background: var(--ai-gradient);
            color: white;
            border: none;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: 0.2s;
        }

        .send-btn:hover {
            transform: scale(1.05);
        }

    </style>
</head>
<body>

    <!-- Topbar -->
    <header class="topbar">
        <div class="topbar-left">
            <a href="/Home/CourseStructure" class="back-btn">
                <i class="fa-solid fa-arrow-left"></i> Cancel
            </a>
            <div class="ai-status-badge">
                <i class="fa-solid fa-wand-magic-sparkles"></i> AI Generated Draft
            </div>
        </div>
        <div class="topbar-right">
            <button class="btn btn-outline"><i class="fa-solid fa-rotate-left"></i> Discard</button>
            <button class="btn btn-primary"><i class="fa-solid fa-check"></i> Approve & Save to Course</button>
        </div>
    </header>

    <main class="staging-container">
        
        <!-- Left: Editor Content -->
        <div class="editor-col">
            
            <div class="ai-banner">
                <div class="ai-banner-icon"><i class="fa-solid fa-sparkles"></i></div>
                <div class="ai-banner-content">
                    <h4>Draft Ready for Review</h4>
                    <p>The AI has generated the lesson based on your syllabus. Please review the content, make any manual edits directly in the editor below, or use the assistant on the right to regenerate specific sections.</p>
                </div>
            </div>

            <input type="text" class="title-input" value="Understanding React Context API">

            <div class="editor-box">
                <!-- Toolbar -->
                <div class="editor-toolbar">
                    <button class="toolbar-btn active"><i class="fa-solid fa-bold"></i></button>
                    <button class="toolbar-btn"><i class="fa-solid fa-italic"></i></button>
                    <button class="toolbar-btn"><i class="fa-solid fa-list-ul"></i></button>
                    <button class="toolbar-btn"><i class="fa-solid fa-link"></i></button>
                    <button class="toolbar-btn"><i class="fa-regular fa-image"></i></button>
                </div>

                <!-- Editor Content -->
                <div class="editor-content" contenteditable="true">
                    <h2>Introduction to Context API</h2>
                    <p>In a typical React application, data is passed top-down (parent to child) via props. However, this can become cumbersome for certain types of props (e.g., locale preference, UI theme) that are required by many components within an application.</p>
                    <br>
                    <p>Context provides a way to share values like these between components without having to explicitly pass a prop through every level of the tree. This problem is commonly referred to as <strong>"prop drilling"</strong>.</p>
                    <br>
                    <h3>When to Use Context</h3>
                    <ul>
                        <li>Theming (Dark/Light mode)</li>
                        <li>User Authentication State (Logged in user profile)</li>
                        <li>Localization / Language preferences</li>
                    </ul>
                    <br>
                    <p><em>Note: Context is primarily used when some data needs to be accessible by many components at different nesting levels. Apply it sparingly because it makes component reuse more difficult.</em></p>
                </div>
            </div>

        </div>

        <!-- Right: AI Assistant Panel -->
        <div class="ai-col">
            
            <div class="assistant-card">
                <div class="assistant-header">
                    <i class="fa-solid fa-robot"></i> EduNexus Copilot
                </div>

                <!-- Original Prompt Context -->
                <div class="prompt-info">
                    <div class="prompt-label">Original Prompt</div>
                    <div class="prompt-bubble">
                        "Create a beginner-friendly lesson on React Context API. Explain what prop drilling is. Include a bulleted list of common use cases. Keep the tone encouraging."
                    </div>
                </div>

                <!-- One-click suggestions -->
                <div class="suggestions-list">
                    <div class="prompt-label" style="margin-bottom: 12px;">Quick Actions</div>
                    
                    <div class="suggestion-item">
                        <i class="fa-solid fa-code"></i>
                        <div class="suggestion-text">
                            <strong>Add Code Example</strong><br>
                            Generate a practical code snippet showing Provider and useContext usage.
                        </div>
                    </div>

                    <div class="suggestion-item">
                        <i class="fa-solid fa-list-check"></i>
                        <div class="suggestion-text">
                            <strong>Generate Quiz</strong><br>
                            Create a 5-question multiple choice quiz based on this text.
                        </div>
                    </div>

                    <div class="suggestion-item">
                        <i class="fa-solid fa-compress"></i>
                        <div class="suggestion-text">
                            <strong>Summarize</strong><br>
                            Make the text more concise and easier to scan.
                        </div>
                    </div>
                </div>

                <!-- Refine Input -->
                <div class="ai-chat-input">
                    <div class="prompt-label" style="margin-bottom: 8px;">Refine Content</div>
                    <div class="chat-box">
                        <textarea class="chat-textarea" placeholder="E.g. Make the introduction more engaging, or translate to Vietnamese..."></textarea>
                        <button class="send-btn"><i class="fa-solid fa-arrow-up"></i></button>
                    </div>
                </div>
            </div>

        </div>

    </main>

</body>
</html>
