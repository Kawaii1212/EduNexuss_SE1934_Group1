@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Essay Results - EduNexus</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            /* Synchronized with EduNexus */
            --primary: #5c24ff;
            --primary-light: #9b8cf8;
            --primary-lighter: #f0edff;
            --bg-color: #fafafa;
            --surface: #ffffff;
            --text-main: #111827;
            --text-muted: #6b7280;
            --border: #e5e7eb;
            --danger: #ef4444;
            --success: #10b981;
            --warning: #f59e0b;
            --radius-md: 8px;
            --radius-lg: 12px;
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Topbar */
        .topbar {
            height: 70px;
            background-color: var(--surface);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 40px;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .back-btn {
            color: var(--text-muted);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 500;
            font-size: 14px;
            transition: 0.2s;
        }

        .back-btn:hover {
            color: var(--text-main);
        }

        .btn {
            padding: 10px 20px;
            border-radius: var(--radius-md);
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            border: none;
            transition: all 0.2s ease;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
        }

        .btn-outline {
            background-color: transparent;
            border: 1px solid var(--border);
            color: var(--text-main);
        }

        .btn-outline:hover {
            background-color: var(--bg-color);
        }

        /* Layout */
        .results-container {
            flex: 1;
            display: flex;
            padding: 40px;
            max-width: 1400px;
            margin: 0 auto;
            width: 100%;
            gap: 32px;
        }

        .main-col {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 24px;
        }

        .side-col {
            width: 400px;
            display: flex;
            flex-direction: column;
            gap: 24px;
        }

        /* Main Cards */
        .content-card {
            background: var(--surface);
            border-radius: var(--radius-lg);
            border: 1px solid var(--border);
            padding: 32px;
            box-shadow: var(--shadow-sm);
        }

        .header-title {
            font-size: 24px;
            font-weight: 700;
            color: var(--text-main);
            margin-bottom: 8px;
        }

        .header-subtitle {
            font-size: 14px;
            color: var(--text-muted);
            margin-bottom: 24px;
        }

        /* Feedback Section */
        .feedback-box {
            background: #f0fdf4; /* Light green for success/positive vibe */
            border: 1px solid #bbf7d0;
            border-radius: var(--radius-lg);
            padding: 24px;
            margin-bottom: 32px;
            position: relative;
        }

        .feedback-box::before {
            content: '';
            position: absolute;
            left: 0;
            top: 24px;
            bottom: 24px;
            width: 4px;
            background: var(--success);
            border-radius: 0 4px 4px 0;
        }

        .feedback-title {
            font-weight: 700;
            font-size: 16px;
            color: #166534;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .feedback-text {
            font-size: 15px;
            color: #15803d;
            line-height: 1.6;
        }

        .instructor-profile {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-top: 20px;
            padding-top: 20px;
            border-top: 1px solid #bbf7d0;
        }

        .instructor-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: #86efac;
            color: #14532d;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 14px;
        }

        .instructor-name {
            font-size: 14px;
            font-weight: 600;
            color: #166534;
        }

        /* Submission Review Area */
        .submission-title {
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 16px;
            color: var(--text-main);
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-top: 32px;
            border-top: 1px solid var(--border);
        }

        .submitted-file {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px;
            background: var(--bg-color);
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
        }

        .file-info {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .file-icon {
            width: 40px;
            height: 40px;
            border-radius: 8px;
            background: #eff6ff;
            color: #3b82f6;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }

        .file-details h4 {
            font-size: 14px;
            font-weight: 600;
            color: var(--text-main);
            margin-bottom: 2px;
        }

        .file-details p {
            font-size: 12px;
            color: var(--text-muted);
        }

        /* Sidebar Details */
        .grade-card {
            background: var(--surface);
            border-radius: var(--radius-lg);
            border: 1px solid var(--border);
            padding: 32px;
            box-shadow: var(--shadow-sm);
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .grade-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 6px;
            background: var(--primary);
        }

        .total-score-badge {
            display: inline-flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            width: 120px;
            height: 120px;
            border-radius: 50%;
            background: var(--primary-lighter);
            border: 4px solid var(--primary-light);
            margin-bottom: 24px;
        }

        .total-score-badge .score {
            font-size: 36px;
            font-weight: 800;
            color: var(--primary);
            line-height: 1;
        }

        .total-score-badge .max {
            font-size: 14px;
            color: var(--text-muted);
            font-weight: 600;
        }

        .grade-letter {
            font-size: 20px;
            font-weight: 700;
            color: var(--text-main);
            margin-bottom: 8px;
        }

        .grade-status {
            display: inline-block;
            padding: 4px 12px;
            background: #ecfdf5;
            color: var(--success);
            border-radius: 100px;
            font-size: 12px;
            font-weight: 600;
            border: 1px solid #a7f3d0;
        }

        /* Rubric Table */
        .rubric-card {
            background: var(--surface);
            border-radius: var(--radius-lg);
            border: 1px solid var(--border);
            padding: 32px;
            box-shadow: var(--shadow-sm);
        }

        .card-title {
            font-size: 16px;
            font-weight: 700;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .rubric-row {
            margin-bottom: 20px;
        }

        .rubric-row:last-child {
            margin-bottom: 0;
        }

        .rubric-header {
            display: flex;
            justify-content: space-between;
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 8px;
        }

        .rubric-header .pts {
            color: var(--primary);
        }

        .rubric-desc {
            font-size: 12px;
            color: var(--text-muted);
            margin-bottom: 8px;
        }

        .rubric-track {
            height: 6px;
            background: var(--border);
            border-radius: 3px;
            overflow: hidden;
        }

        .rubric-fill {
            height: 100%;
            background: var(--primary);
            border-radius: 3px;
        }

        /* Originality Report */
        .plagiarism-box {
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 16px;
            background: #f8fafc;
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            margin-top: 24px;
        }

        .plagiarism-icon {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            background: var(--surface);
            border: 2px solid var(--success);
            color: var(--success);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            font-weight: 700;
        }

        .plagiarism-text h4 {
            font-size: 14px;
            font-weight: 600;
            color: var(--text-main);
            margin-bottom: 2px;
        }

        .plagiarism-text p {
            font-size: 12px;
            color: var(--text-muted);
        }

    </style>
</head>
<body>

    <!-- Topbar -->
    <header class="topbar">
        <div class="topbar-left">
            <a href="/Home/CourseStructure" class="back-btn">
                <i class="fa-solid fa-arrow-left"></i> Back to Dashboard
            </a>
        </div>
        <div class="topbar-right">
            <button class="btn btn-outline"><i class="fa-solid fa-print"></i> Print Results</button>
        </div>
    </header>

    <main class="results-container">
        
        <!-- Left: Essay Info & Feedback -->
        <div class="main-col">
            
            <div class="content-card">
                <h1 class="header-title">Midterm Essay: Microservices vs Monoliths</h1>
                <p class="header-subtitle">Advanced Full-Stack Development • Submitted on Oct 25, 2026</p>

                <div class="feedback-box">
                    <div class="feedback-title">
                        <i class="fa-solid fa-comment-dots"></i> Instructor Feedback
                    </div>
                    <div class="feedback-text">
                        Excellent analysis of the CI/CD pipeline complexities when shifting from Monolith to Microservices. Your real-world case study on Netflix was very well researched and perfectly formatted. However, the section on distributed transactions (Saga Pattern) lacked a bit of technical depth. Overall, a highly commendable piece of work! Keep it up.
                    </div>
                    <div class="instructor-profile">
                        <div class="instructor-avatar">AS</div>
                        <div class="instructor-name">Dr. Alan Smith</div>
                    </div>
                </div>

                <div class="submission-title">
                    Your Submission
                    <a href="#" class="btn btn-outline" style="padding: 6px 12px; font-size: 12px;"><i class="fa-solid fa-download"></i> Download</a>
                </div>

                <div class="submitted-file">
                    <div class="file-info">
                        <div class="file-icon"><i class="fa-solid fa-file-word"></i></div>
                        <div class="file-details">
                            <h4>Microservices_Analysis_JohnDoe.docx</h4>
                            <p>Word Document • 2.4 MB • 1,845 Words</p>
                        </div>
                    </div>
                    <button class="btn btn-outline" style="border: none;"><i class="fa-solid fa-eye"></i> View Inline</button>
                </div>

                <!-- Preview Area Mock (Could be iframe for PDF/Docs) -->
                <div style="margin-top: 24px; padding: 32px; border: 1px solid var(--border); border-radius: var(--radius-md); background: #fcfcfc; min-height: 400px; font-family: serif; color: #333; line-height: 1.8;">
                    <h2 style="text-align: center; margin-bottom: 24px;">The Paradigm Shift: From Monoliths to Microservices</h2>
                    <p>In modern software engineering, the architectural choice between maintaining a monolithic application or migrating to a microservices ecosystem dictates not only the development workflow but also the organizational structure of the engineering team...</p>
                    <p><em>(Document preview continues here...)</em></p>
                </div>

            </div>

        </div>

        <!-- Right: Grade & Rubric -->
        <div class="side-col">
            
            <!-- Grade Card -->
            <div class="grade-card">
                <div class="total-score-badge">
                    <div class="score">92</div>
                    <div class="max">/ 100</div>
                </div>
                <div class="grade-letter">Grade: A-</div>
                <div class="grade-status">Graded</div>
            </div>

            <!-- Rubric Details -->
            <div class="rubric-card">
                <div class="card-title">
                    <i class="fa-solid fa-list-check"></i> Rubric Breakdown
                </div>

                <div class="rubric-row">
                    <div class="rubric-header">
                        <span>Content & Analysis</span>
                        <span class="pts">38 / 40</span>
                    </div>
                    <div class="rubric-desc">Depth of arguments, case study relevance.</div>
                    <div class="rubric-track">
                        <div class="rubric-fill" style="width: 95%;"></div>
                    </div>
                </div>

                <div class="rubric-row">
                    <div class="rubric-header">
                        <span>Technical Accuracy</span>
                        <span class="pts">25 / 30</span>
                    </div>
                    <div class="rubric-desc">Correct understanding of architecture patterns.</div>
                    <div class="rubric-track">
                        <div class="rubric-fill" style="width: 83%;"></div>
                    </div>
                </div>

                <div class="rubric-row">
                    <div class="rubric-header">
                        <span>Formatting & Citations</span>
                        <span class="pts">15 / 15</span>
                    </div>
                    <div class="rubric-desc">APA formatting, word count, bibliography.</div>
                    <div class="rubric-track">
                        <div class="rubric-fill" style="width: 100%;"></div>
                    </div>
                </div>

                <div class="rubric-row">
                    <div class="rubric-header">
                        <span>Grammar & Clarity</span>
                        <span class="pts">14 / 15</span>
                    </div>
                    <div class="rubric-desc">Readability, flow, and absence of errors.</div>
                    <div class="rubric-track">
                        <div class="rubric-fill" style="width: 93%;"></div>
                    </div>
                </div>

                <div class="plagiarism-box">
                    <div class="plagiarism-icon">
                        <i class="fa-solid fa-check"></i>
                    </div>
                    <div class="plagiarism-text">
                        <h4>Originality Report</h4>
                        <p>No plagiarism detected. 98% Original.</p>
                    </div>
                </div>
            </div>

        </div>

    </main>

</body>
</html>
