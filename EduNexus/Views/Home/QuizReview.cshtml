@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quiz Review - EduNexus</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            /* Synchronized with EduNexus */
            --primary: #5c24ff;
            --primary-light: #9b8cf8;
            --primary-lighter: #f0edff;
            --bg-color: #fafafa;
            --surface: #ffffff;
            --text-main: #111827;
            --text-muted: #6b7280;
            --border: #e5e7eb;
            --danger: #ef4444;
            --success: #10b981;
            --warning: #f59e0b;
            --radius-md: 8px;
            --radius-lg: 12px;
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            min-height: 100vh;
        }

        /* Topbar */
        .topbar {
            height: 70px;
            background-color: var(--surface);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 40px;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .back-btn {
            color: var(--text-muted);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 500;
            font-size: 14px;
            transition: 0.2s;
        }

        .back-btn:hover {
            color: var(--text-main);
        }

        .btn {
            padding: 10px 20px;
            border-radius: var(--radius-md);
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            border: none;
            transition: all 0.2s ease;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
        }

        .btn-outline {
            background-color: transparent;
            border: 1px solid var(--border);
            color: var(--text-main);
        }

        .btn-outline:hover {
            background-color: var(--bg-color);
        }

        .btn-primary {
            background-color: var(--primary-light);
            color: white;
            box-shadow: 0 4px 12px rgba(155, 140, 248, 0.3);
        }

        .btn-primary:hover {
            background-color: var(--primary);
            box-shadow: 0 6px 16px rgba(92, 36, 255, 0.4);
            transform: translateY(-1px);
        }

        /* Container Layout */
        .container {
            max-width: 900px;
            margin: 40px auto;
            padding: 0 24px;
        }

        /* Review Header Card */
        .review-header-card {
            background: var(--surface);
            border-radius: var(--radius-lg);
            border: 1px solid var(--border);
            padding: 32px;
            margin-bottom: 32px;
            box-shadow: var(--shadow-sm);
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }

        .review-info h1 {
            font-size: 24px;
            font-weight: 700;
            color: var(--text-main);
            margin-bottom: 8px;
        }

        .review-info p {
            color: var(--text-muted);
            font-size: 14px;
            margin-bottom: 24px;
        }

        .review-meta-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px;
        }

        .meta-item {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .meta-label {
            font-size: 12px;
            color: var(--text-muted);
            text-transform: uppercase;
            font-weight: 600;
            letter-spacing: 0.5px;
        }

        .meta-value {
            font-size: 15px;
            font-weight: 600;
            color: var(--text-main);
        }

        .score-badge {
            background: #ecfdf5;
            color: var(--success);
            border: 1px solid #a7f3d0;
            padding: 16px 24px;
            border-radius: var(--radius-md);
            text-align: center;
        }

        .score-badge .score {
            font-size: 32px;
            font-weight: 800;
            line-height: 1;
            margin-bottom: 4px;
        }

        .score-badge .label {
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
        }

        /* Toolbar */
        .toolbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
        }

        .filter-group {
            display: flex;
            gap: 12px;
        }

        .filter-btn {
            padding: 8px 16px;
            border-radius: 100px;
            font-size: 13px;
            font-weight: 600;
            border: 1px solid var(--border);
            background: var(--surface);
            color: var(--text-muted);
            cursor: pointer;
            transition: 0.2s;
        }

        .filter-btn:hover {
            background: var(--bg-color);
            color: var(--text-main);
        }

        .filter-btn.active {
            background: var(--primary-lighter);
            border-color: var(--primary-light);
            color: var(--primary);
        }

        /* Review Card (Question) */
        .review-card {
            background: var(--surface);
            border-radius: var(--radius-lg);
            border: 1px solid var(--border);
            padding: 32px;
            margin-bottom: 24px;
            box-shadow: var(--shadow-sm);
        }

        .review-card.is-correct {
            border-left: 4px solid var(--success);
        }

        .review-card.is-incorrect {
            border-left: 4px solid var(--danger);
        }

        .q-meta {
            display: flex;
            justify-content: space-between;
            margin-bottom: 16px;
            font-size: 14px;
            font-weight: 600;
        }

        .q-number { color: var(--text-muted); }
        .q-points { color: var(--text-main); }

        .q-text {
            font-size: 16px;
            line-height: 1.6;
            margin-bottom: 24px;
            color: var(--text-main);
            font-weight: 500;
        }

        .options-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .opt-row {
            display: flex;
            align-items: center;
            padding: 16px;
            border-radius: var(--radius-md);
            border: 1px solid var(--border);
            font-size: 15px;
            background: #fafafa;
            position: relative;
        }

        .opt-icon {
            width: 24px;
            height: 24px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 16px;
            font-size: 12px;
            flex-shrink: 0;
            border: 2px solid var(--border);
            color: transparent;
        }

        /* States */
        .opt-row.correct-user {
            background: #ecfdf5;
            border-color: #a7f3d0;
        }
        .opt-row.correct-user .opt-icon {
            background: var(--success);
            border-color: var(--success);
            color: white;
        }

        .opt-row.incorrect-user {
            background: #fef2f2;
            border-color: #fecaca;
        }
        .opt-row.incorrect-user .opt-icon {
            background: var(--danger);
            border-color: var(--danger);
            color: white;
        }

        .opt-row.correct-missed {
            border-color: var(--success);
            background: #ffffff;
        }
        .opt-row.correct-missed .opt-icon {
            border-color: var(--success);
            color: var(--success);
        }

        .opt-text {
            flex: 1;
        }

        .badge-answer {
            font-size: 11px;
            font-weight: 700;
            padding: 4px 8px;
            border-radius: 4px;
            margin-left: 12px;
        }

        .badge-answer.your { background: var(--text-main); color: white; }

        /* Instructor Feedback */
        .feedback-box {
            margin-top: 24px;
            padding: 20px;
            background: #f8fafc; /* subtle slate */
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            font-size: 14px;
            color: var(--text-main);
            line-height: 1.6;
        }

        .feedback-title {
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 600;
            color: var(--text-main);
            margin-bottom: 8px;
        }

        .feedback-title i {
            color: var(--primary);
        }

    </style>
</head>
<body>

    <!-- Topbar -->
    <header class="topbar">
        <div class="topbar-left">
            <a href="/Quiz/History" class="back-btn">
                <i class="fa-solid fa-arrow-left"></i> Back to History
            </a>
        </div>
        <div class="topbar-right">
            <button class="btn btn-outline"><i class="fa-solid fa-print"></i> Print Review</button>
            <button class="btn btn-primary">Retake Quiz</button>
        </div>
    </header>

    <div class="container">
        
        <!-- Header Information -->
        <div class="review-header-card">
            <div class="review-info">
                <h1>Review: Entity Framework Core Final</h1>
                <p>Advanced Full-Stack Development • Module 2</p>

                <div class="review-meta-grid">
                    <div class="meta-item">
                        <span class="meta-label">Submitted On</span>
                        <span class="meta-value">Oct 15, 2026 at 02:30 PM</span>
                    </div>
                    <div class="meta-item">
                        <span class="meta-label">Time Taken</span>
                        <span class="meta-value">22m 15s</span>
                    </div>
                    <div class="meta-item">
                        <span class="meta-label">Attempt</span>
                        <span class="meta-value">1 of 3</span>
                    </div>
                </div>
            </div>

            <div class="score-badge">
                <div class="score">78%</div>
                <div class="label">Passed</div>
            </div>
        </div>

        <div style="margin-top: 40px; text-align: center; padding: 40px; background: white; border-radius: var(--radius-lg); border: 1px solid var(--border); box-shadow: var(--shadow-sm);">
            <i class="fa-solid fa-tools" style="font-size: 48px; color: var(--primary-light); margin-bottom: 16px;"></i>
            <h3 style="font-weight: 700; color: var(--text-main); margin-bottom: 8px;">Tính năng đang phát triển</h3>
            <p style="color: var(--text-muted); font-size: 15px;">Chức năng xem lại câu trả lời chi tiết sẽ được cập nhật trong phiên bản sau.</p>
        </div>

    </div>

</body>
</html>
