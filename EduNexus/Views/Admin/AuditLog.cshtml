@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "System Audit Logs";
}

<div class="admin-header mb-5">
    <div>
        <h1>Audit Logs & History</h1>
        <p style="color: var(--text-muted); font-size: 15px; margin-top: 6px;">Monitor system activities and user logins</p>
    </div>
</div>

<div class="glass-card">
    <div class="card-header border-bottom pt-4 pb-0 px-4" style="background: rgba(255,255,255,0.5);">
        <ul class="nav nav-tabs border-bottom-0" id="logTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active fw-semibold" id="audit-tab" data-bs-toggle="tab" data-bs-target="#audit" type="button" role="tab" style="color: var(--admin-primary); border-top: 3px solid var(--admin-primary); border-radius: 0;">System Audit Log</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-semibold text-muted" id="login-tab" data-bs-toggle="tab" data-bs-target="#login" type="button" role="tab" style="border-top: 3px solid transparent; border-radius: 0;">Login History</button>
            </li>
        </ul>
    </div>
    
    <div class="card-body p-0">
        <div class="tab-content" id="logTabsContent">
            
            <!-- Audit Log Tab -->
            <div class="tab-pane fade show active" id="audit" role="tabpanel">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="border-bottom-0 py-3 px-4 text-muted" style="font-weight: 600; font-size: 13px; text-transform: uppercase; width: 180px;">Timestamp</th>
                                <th class="border-bottom-0 py-3 px-4 text-muted" style="font-weight: 600; font-size: 13px; text-transform: uppercase; width: 120px;">Actor ID</th>
                                <th class="border-bottom-0 py-3 px-4 text-muted" style="font-weight: 600; font-size: 13px; text-transform: uppercase;">Action Type</th>
                                <th class="border-bottom-0 py-3 px-4 text-muted" style="font-weight: 600; font-size: 13px; text-transform: uppercase;">Resource</th>
                                <th class="border-bottom-0 py-3 px-4 text-muted" style="font-weight: 600; font-size: 13px; text-transform: uppercase;">Metadata</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.AuditLogs != null && ViewBag.AuditLogs.Count > 0)
                            {
                                foreach (var log in ViewBag.AuditLogs)
                                {
                                    <tr>
                                        <td class="py-3 px-4" style="font-size: 14px; color: var(--text-muted);">
                                            @log.CreatedAt?.ToString("yyyy-MM-dd HH:mm:ss")
                                        </td>
                                        <td class="py-3 px-4" style="font-weight: 500;">
                                            User #@log.ActorId
                                        </td>
                                        <td class="py-3 px-4">
                                            <span class="badge bg-light text-dark border">@log.ActionType</span>
                                        </td>
                                        <td class="py-3 px-4" style="font-size: 14px;">
                                            @log.ResourceType (@log.ResourceId)
                                        </td>
                                        <td class="py-3 px-4">
                                            <div style="font-family: monospace; font-size: 12px; max-width: 300px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: var(--text-muted);" title="@log.Metadata">
                                                @log.Metadata
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted">No audit logs found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Login History Tab -->
            <div class="tab-pane fade" id="login" role="tabpanel">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="border-bottom-0 py-3 px-4 text-muted" style="font-weight: 600; font-size: 13px; text-transform: uppercase; width: 180px;">Time</th>
                                <th class="border-bottom-0 py-3 px-4 text-muted" style="font-weight: 600; font-size: 13px; text-transform: uppercase;">User</th>
                                <th class="border-bottom-0 py-3 px-4 text-muted" style="font-weight: 600; font-size: 13px; text-transform: uppercase;">IP Address</th>
                                <th class="border-bottom-0 py-3 px-4 text-muted" style="font-weight: 600; font-size: 13px; text-transform: uppercase;">User Agent</th>
                                <th class="border-bottom-0 py-3 px-4 text-muted" style="font-weight: 600; font-size: 13px; text-transform: uppercase;">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.LoginHistories != null && ViewBag.LoginHistories.Count > 0)
                            {
                                foreach (var history in ViewBag.LoginHistories)
                                {
                                    <tr>
                                        <td class="py-3 px-4" style="font-size: 14px; color: var(--text-muted);">
                                            @history.LoginAt?.ToString("yyyy-MM-dd HH:mm:ss")
                                        </td>
                                        <td class="py-3 px-4" style="font-weight: 500;">
                                            @(history.User?.FullName ?? "Unknown") <span class="text-muted" style="font-weight: 400; font-size: 12px;">(#@history.UserId)</span>
                                        </td>
                                        <td class="py-3 px-4" style="font-family: monospace; font-size: 14px;">
                                            @history.IpAddress
                                        </td>
                                        <td class="py-3 px-4">
                                            <div style="font-size: 13px; max-width: 300px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: var(--text-muted);" title="@history.UserAgent">
                                                @history.UserAgent
                                            </div>
                                        </td>
                                        <td class="py-3 px-4">
                                            @if (history.Status == "SUCCESS")
                                            {
                                                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25">SUCCESS</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25">@history.Status</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted">No login histories found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const tabs = document.querySelectorAll('#logTabs button[data-bs-toggle="tab"]');
            tabs.forEach(tab => {
                tab.addEventListener('shown.bs.tab', event => {
                    // Reset styling on all tabs
                    tabs.forEach(t => {
                        t.style.color = '';
                        t.style.borderTopColor = 'transparent';
                        t.classList.remove('text-muted');
                        t.classList.add('text-muted');
                    });
                    
                    // Apply styling to active tab
                    const activeTab = event.target;
                    activeTab.style.color = 'var(--admin-primary)';
                    activeTab.style.borderTopColor = 'var(--admin-primary)';
                    activeTab.classList.remove('text-muted');
                });
            });
        });
    </script>
}
