@model EduNexus.ViewModels.QuestionStagingViewModel
@{
    Layout = "~/Views/Shared/_SmeLayout.cshtml";
    ViewData["Title"] = "AI Question Staging - EduNexus";
    ViewData["ActiveMenu"] = "MyCourses";
    ViewData["ActiveSubMenu"] = "Question";
}

<style>
    .ai-staging-page {
        --primary: #5c24ff;
        --primary-light: #9b8cf8;
        --primary-lighter: #f0edff;
        --surface: #fff;
        --text: #111827;
        --muted: #6b7280;
        --border: #e5e7eb;
        --success: #10b981;
        --danger: #ef4444;
        --warning: #f59e0b;
        --radius: 10px;
        --shadow: 0 1px 3px rgba(0,0,0,.08);
    }

    .ai-staging-page .topbar {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 24px;
        margin-bottom: 24px;
    }

    .ai-staging-page .topbar-left {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .ai-staging-page .back-btn {
        color: var(--muted);
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
        padding: 8px 14px;
        border: 1px solid var(--border);
        border-radius: 8px;
        background: var(--surface);
    }

    .ai-staging-page .back-btn:hover {
        color: var(--text);
        background: #f8fafc;
        border-color: var(--muted);
    }

    .ai-staging-page .page-badge {
        background: var(--primary-lighter);
        color: var(--primary);
        padding: 8px 16px;
        border-radius: 100px;
        font-size: 13px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .ai-staging-page .ai-container {
        display: flex;
        gap: 24px;
    }

    .ai-staging-page .main {
        flex: 1;
        min-width: 0;
    }

    .ai-staging-page .panel {
        width: 320px;
        flex-shrink: 0;
    }

    .ai-staging-page .banner {
        background: linear-gradient(135deg, var(--primary), #8b5cf6);
        color: #fff;
        padding: 20px 24px;
        border-radius: var(--radius);
        margin-bottom: 24px;
        display: flex;
        gap: 16px;
        align-items: center;
        box-shadow: 0 4px 12px rgba(92, 36, 255, 0.15);
    }

    .ai-staging-page .banner-icon {
        font-size: 28px;
        background: rgba(255,255,255,.2);
        width: 52px;
        height: 52px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .ai-staging-page .banner h4 {
        font-size: 16px;
        font-weight: 700;
        margin-bottom: 4px;
    }

    .ai-staging-page .banner p {
        font-size: 13px;
        opacity: .9;
        line-height: 1.5;
    }

    .ai-staging-page .card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        overflow: hidden;
    }

    .ai-staging-page .card-header {
        padding: 18px 24px;
        border-bottom: 1px solid var(--border);
        background: #fafafa;
    }

    .ai-staging-page .card-header h3 {
        font-size: 15px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--text);
    }

    .ai-staging-page .badge {
        background: var(--primary-lighter);
        color: var(--primary);
        font-size: 12px;
        font-weight: 700;
        padding: 2px 8px;
        border-radius: 20px;
    }

    .ai-staging-page .empty {
        padding: 64px 20px;
        text-align: center;
        color: var(--muted);
    }

    .ai-staging-page .empty i {
        font-size: 44px;
        color: var(--primary-light);
        margin-bottom: 16px;
        display: block;
        opacity: .8;
    }

    .ai-staging-page .empty p {
        font-size: 14px;
        line-height: 1.6;
    }

    .ai-staging-page table {
        width: 100%;
        border-collapse: collapse;
    }

    .ai-staging-page th {
        background: #fafafa;
        padding: 14px 20px;
        text-align: left;
        font-size: 12px;
        font-weight: 700;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: .05em;
        border-bottom: 1px solid var(--border);
    }

    .ai-staging-page td {
        padding: 18px 20px;
        border-bottom: 1px solid var(--border);
        font-size: 13.5px;
        vertical-align: top;
    }

    .ai-staging-page tr:last-child td {
        border-bottom: none;
    }

    .ai-staging-page .q-text {
        font-weight: 600;
        color: var(--text);
        margin-bottom: 12px;
        line-height: 1.5;
    }

    .ai-staging-page .q-opts {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-bottom: 14px;
    }

    .ai-staging-page .q-opt {
        padding: 8px 12px;
        background: #f8fafc;
        border: 1px solid var(--border);
        border-radius: 6px;
        font-size: 12.5px;
        display: flex;
        align-items: center;
        gap: 8px;
        color: #475569;
    }

    .ai-staging-page .q-opt.ok {
        background: #ecfdf5;
        border-color: #a7f3d0;
        color: #065f46;
        font-weight: 600;
    }

    .ai-staging-page .q-opt.ok i {
        color: var(--success);
    }

    .ai-staging-page .exp-link {
        font-size: 12.5px;
        color: var(--primary);
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        user-select: none;
    }

    .ai-staging-page .exp-box {
        display: none;
        margin-top: 10px;
        padding: 12px 16px;
        background: #fdfcff;
        border: 1px solid var(--primary-light);
        border-radius: 8px;
        font-size: 12.5px;
        color: #553c9a;
        line-height: 1.6;
    }

    .ai-staging-page .diff {
        display: inline-flex;
        padding: 2px 8px;
        border-radius: 4px;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
    }

    .ai-staging-page .diff-EASY { background: #d1fae5; color: #065f46; }
    .ai-staging-page .diff-MEDIUM { background: #fef3c7; color: #d97706; }
    .ai-staging-page .diff-HARD { background: #fee2e2; color: #991b1b; }

    .ai-staging-page .actions {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .ai-staging-page .btn {
        padding: 8px 12px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        border: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        transition: all 0.2s;
        text-decoration: none;
    }

    .ai-staging-page .btn-success {
        background: var(--success);
        color: #fff;
    }

    .ai-staging-page .btn-success:hover {
        background: #059669;
    }

    .ai-staging-page .btn-warning {
        background: #f59e0b;
        color: #fff;
    }

    .ai-staging-page .btn-warning:hover {
        background: #d97706;
    }

    .ai-staging-page .btn-danger {
        background: #fee2e2;
        color: var(--danger);
    }

    .ai-staging-page .btn-danger:hover {
        background: #fecaca;
    }

    .ai-staging-page .gen-panel {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 24px;
        position: sticky;
        top: 24px;
        box-shadow: var(--shadow);
    }

    .ai-staging-page .gen-header {
        font-size: 15px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .ai-staging-page .gen-body {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .ai-staging-page .form-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .ai-staging-page .form-group label {
        font-size: 13.5px;
        font-weight: 600;
        color: var(--text);
    }

    .ai-staging-page .form-control {
        width: 100%;
        padding: 10px 12px;
        border: 1px solid var(--border);
        border-radius: 6px;
        font-size: 13.5px;
        outline: none;
        transition: border-color .15s;
        background: #fff;
    }

    .ai-staging-page .form-control:focus {
        border-color: var(--primary-light);
    }

    .ai-staging-page .diff-btns {
        display: flex;
        gap: 8px;
    }

    .ai-staging-page .diff-btn {
        flex: 1;
        padding: 8px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: var(--surface);
        font-size: 12.5px;
        font-weight: 500;
        cursor: pointer;
        color: var(--muted);
        text-align: center;
        transition: all 0.15s;
    }

    .ai-staging-page .diff-btn.active {
        border-color: var(--primary);
        background: var(--primary-lighter);
        color: var(--primary);
        font-weight: 600;
    }

    .ai-staging-page .form-hint {
        font-size: 11px;
        color: var(--muted);
        margin-top: -4px;
    }

    .ai-staging-page .info-box {
        padding: 12px;
        background: #f8fafc;
        border: 1px solid var(--border);
        border-radius: 6px;
        font-size: 12px;
        color: #475569;
        display: flex;
        gap: 8px;
        line-height: 1.5;
    }

    .ai-staging-page .info-box i {
        color: var(--primary);
        font-size: 14px;
    }

    .ai-staging-page .gen-btn {
        width: 100%;
        padding: 12px;
        border-radius: 6px;
        background: linear-gradient(135deg, var(--primary), #8b5cf6);
        color: #fff;
        font-size: 13.5px;
        font-weight: 600;
        cursor: pointer;
        border: none;
        box-shadow: 0 4px 10px rgba(92, 36, 255, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: all 0.2s;
    }

    .ai-staging-page .gen-btn:hover {
        transform: translateY(-1px);
        opacity: .95;
    }

    .ai-staging-page .spinner {
        display: none;
        width: 16px;
        height: 16px;
        border: 2px solid rgba(255,255,255,.3);
        border-top-color: #fff;
        border-radius: 50%;
        animation: spinStaging .7s linear infinite;
    }

    .ai-staging-page .alert {
        padding: 12px 16px;
        border-radius: 8px;
        font-size: 13.5px;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .ai-staging-page .alert-success {
        background: #ecfdf5;
        border: 1px solid #a7f3d0;
        color: #065f46;
    }

    .ai-staging-page .alert-error {
        background: #fef2f2;
        border: 1px solid #fca5a5;
        color: #991b1b;
    }

    @@keyframes spinStaging {
        to {
            transform: rotate(360deg);
        }
    }
</style>

<div class="ai-staging-page">
    <header class="topbar">
        <div class="topbar-left">
            @if (ViewBag.ActiveCourseId != null)
            {
                <a href="/Question/Index?courseId=@ViewBag.ActiveCourseId" class="back-btn">
                    <i class="fa-solid fa-arrow-left"></i> Quay lại Ngân hàng
                </a>
            }
            else
            {
                <a href="/Course/MyCourses" class="back-btn">
                    <i class="fa-solid fa-arrow-left"></i> Danh sách khóa học
                </a>
            }
            <div class="page-badge">
                <i class="fa-solid fa-wand-magic-sparkles"></i> AI Question Staging
            </div>
        </div>
        @if (Model.StagedQuestions.Count > 0)
        {
            <form asp-action="ApproveAll" asp-route-moduleId="@Model.Form.ModuleId" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-success">
                    <i class="fa-solid fa-check-double"></i> Duyệt tất cả (@Model.StagedQuestions.Count)
                </button>
            </form>
        }
    </header>

    <div class="ai-container">
        <div class="main">
            @if (!string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <div class="alert alert-success">
                    <i class="fa-solid fa-circle-check"></i> @Model.SuccessMessage
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-error">
                    <i class="fa-solid fa-circle-exclamation"></i> @Model.ErrorMessage
                </div>
            }

            <div class="banner">
                <div class="banner-icon"><i class="fa-solid fa-sparkles"></i></div>
                <div>
                    <h4>Khu vực chờ duyệt &raquo; AI Generated Questions</h4>
                    <p>
                        Câu hỏi do AI sinh ra, chưa vào ngân hàng chính thức.
                        SME chọn <strong>Duyệt</strong> để chuyển vào ngân hàng hoặc
                        <strong>Từ chối</strong> để loại bỏ.
                    </p>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <h3>
                        <i class="fa-solid fa-list-check" style="color:var(--primary)"></i>
                        Câu hỏi chờ duyệt
                        <span class="badge">@Model.StagedQuestions.Count</span>
                    </h3>
                </div>

                @if (Model.StagedQuestions.Count == 0)
                {
                    <div class="empty">
                        <i class="fa-regular fa-rectangle-list"></i>
                        <p>Chưa có câu hỏi nào.<br>Dùng panel bên phải để sinh câu hỏi từ AI.</p>
                    </div>
                }
                else
                {
                    <table>
                        <thead>
                            <tr>
                                <th style="width:52%">Câu hỏi & Đáp án</th>
                                <th>Độ khó</th>
                                <th>Nguồn</th>
                                <th>Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var q in Model.StagedQuestions)
                            {
                                <tr>
                                    <td>
                                        <div class="q-text">@q.Content</div>
                                        <div class="q-opts">
                                            <div class="q-opt @(q.CorrectOption == "A" ? "ok" : "")">
                                                <i class="fa-regular @(q.CorrectOption == "A" ? "fa-circle-check" : "fa-circle")"></i>
                                                A. @q.OptionA
                                            </div>
                                            <div class="q-opt @(q.CorrectOption == "B" ? "ok" : "")">
                                                <i class="fa-regular @(q.CorrectOption == "B" ? "fa-circle-check" : "fa-circle")"></i>
                                                B. @q.OptionB
                                            </div>
                                            <div class="q-opt @(q.CorrectOption == "C" ? "ok" : "")">
                                                <i class="fa-regular @(q.CorrectOption == "C" ? "fa-circle-check" : "fa-circle")"></i>
                                                C. @q.OptionC
                                            </div>
                                            <div class="q-opt @(q.CorrectOption == "D" ? "ok" : "")">
                                                <i class="fa-regular @(q.CorrectOption == "D" ? "fa-circle-check" : "fa-circle")"></i>
                                                D. @q.OptionD
                                            </div>
                                        </div>
                                        @if (!string.IsNullOrEmpty(q.AiExplanation))
                                        {
                                            <span class="exp-link" onclick="toggleExp(@q.Id)">
                                                <i class="fa-regular fa-lightbulb"></i> Xem giải thích
                                            </span>
                                            <div class="exp-box" id="exp-@q.Id">@q.AiExplanation</div>
                                        }
                                    </td>
                                    <td><span class="diff diff-@q.Difficulty">@q.Difficulty</span></td>
                                    <td>
                                        <span style="font-size:12px;color:var(--muted)">
                                            <i class="fa-solid fa-robot" style="color:var(--primary)"></i> AI
                                        </span>
                                    </td>
                                    <td>
                                        <div class="actions">
                                            <form asp-action="Approve" asp-route-id="@q.Id"
                                                  asp-route-moduleId="@Model.Form.ModuleId" method="post">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-success" style="width:100%">
                                                    <i class="fa-solid fa-check"></i> Duyệt
                                                </button>
                                            </form>
                                            <form asp-action="Reject" asp-route-id="@q.Id"
                                                  asp-route-moduleId="@Model.Form.ModuleId" method="post">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-warning" style="width:100%">
                                                    <i class="fa-solid fa-ban"></i> Từ chối
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        <div class="panel">
            <div class="gen-panel">
                <div class="gen-header">
                    <i class="fa-solid fa-robot" style="color: var(--primary);"></i> Sinh câu hỏi bằng AI
                </div>
                <form asp-action="Generate" method="post" class="gen-body">
                    @Html.AntiForgeryToken()

                    @if (ViewBag.ActiveCourseTitle != null)
                    {
                        <div class="form-group">
                            <label>Khóa học</label>
                            <input type="text" class="form-control" value="@ViewBag.ActiveCourseTitle" readonly style="background-color: #f1f5f9; cursor: not-allowed;" />
                        </div>
                    }

                    <div class="form-group">
                        <label asp-for="Form.ModuleId">Thuộc Module</label>
                        <select asp-for="Form.ModuleId" class="form-control"
                                onchange="location.href='/QuestionStaging/Index?moduleId='+this.value">
                            @foreach (var m in Model.Modules)
                            {
                                <option value="@m.Id" selected="@(m.Id == Model.Form.ModuleId ? "selected" : null)">
                                    Chương @m.OrderNo: @m.Title
                                </option>
                            }
                        </select>
                    </div>

                    <div class="form-group">
                        <label asp-for="Form.Topic">Chủ đề / Từ khóa</label>
                        <input asp-for="Form.Topic" class="form-control"
                               placeholder="VD: React useEffect, SQL JOIN..." />
                        <span asp-validation-for="Form.Topic" style="font-size:12px;color:var(--danger)"></span>
                    </div>

                    <div class="form-group">
                        <label>Độ khó</label>
                        <div class="diff-btns">
                            <button type="button" onclick="setDiff('EASY',this)"
                                    class="diff-btn @(Model.Form.Difficulty == "EASY" ? "active" : "")">
                                Dễ
                            </button>
                            <button type="button" onclick="setDiff('MEDIUM',this)"
                                    class="diff-btn @(Model.Form.Difficulty != "EASY" && Model.Form.Difficulty != "HARD" ? "active" : "")">
                                Vừa
                            </button>
                            <button type="button" onclick="setDiff('HARD',this)"
                                    class="diff-btn @(Model.Form.Difficulty == "HARD" ? "active" : "")">
                                Khó
                            </button>
                        </div>
                        <input type="hidden" asp-for="Form.Difficulty" id="diffInput" />
                    </div>

                    <div class="form-group">
                        <label asp-for="Form.Count">Số câu hỏi</label>
                        <input asp-for="Form.Count" type="number" min="1" max="20" class="form-control" />
                        <div class="form-hint">Tối đa 20 câu mỗi lần.</div>
                    </div>

                    @if (Model.LastTokensUsed > 0)
                    {
                        <div class="info-box">
                            <i class="fa-solid fa-coins"></i>
                            <span>Lần trước tiêu tốn ~<strong>@Model.LastTokensUsed</strong> token.</span>
                        </div>
                    }

                    <div class="info-box">
                        <i class="fa-solid fa-circle-info"></i>
                        <span>AI phản hồi trong 30 giây. Kết quả vào khu vực chờ duyệt.</span>
                    </div>

                    <button type="submit" class="gen-btn" id="genBtn" onclick="onGenerate()">
                        <i class="fa-solid fa-wand-magic-sparkles" id="genIcon"></i>
                        <span class="spinner" id="genSpinner"></span>
                        <span id="genText">Sinh câu hỏi</span>
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    function setDiff(val, btn) {
        document.querySelectorAll('.diff-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById('diffInput').value = val;
    }
    function onGenerate() {
        document.getElementById('genIcon').style.display    = 'none';
        document.getElementById('genSpinner').style.display = 'block';
        document.getElementById('genText').textContent      = 'Đang gọi AI...';
        
        setTimeout(() => {
            document.getElementById('genBtn').disabled = true;
        }, 50);
    }
    function toggleExp(id) {
        const el = document.getElementById('exp-' + id);
        el.style.display = el.style.display === 'block' ? 'none' : 'block';
    }
</script>
