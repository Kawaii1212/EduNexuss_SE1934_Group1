@model EduNexus.ViewModels.AllCoursesViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Courses - EduNexus</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary: #5c24ff;
            --primary-light: #9b8cf8;
            --primary-lighter: #f0edff;
            --primary-hover: #481ce0;
            --bg-color: #f8fafc;
            --surface: #ffffff;
            --text-main: #0f172a;
            --text-muted: #64748b;
            --text-light: #94a3b8;
            --border: #e2e8f0;
            --danger: #ef4444;
            --success: #10b981;
            --radius-md: 12px;
            --radius-lg: 16px;
            --radius-full: 9999px;
            --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
            --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.05);
            --shadow-hover: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            display: flex;
            min-height: 100vh;
        }

        /* Sidebar */
        .sidebar {
            width: 260px;
            background-color: var(--surface);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            padding: 24px 20px;
            position: sticky;
            top: 0;
            height: 100vh;
            flex-shrink: 0;
            z-index: 20;
        }
        .logo {
            font-size: 24px;
            font-weight: 800;
            color: var(--primary);
            margin-bottom: 40px;
            display: flex;
            align-items: center;
            gap: 12px;
            padding-left: 12px;
        }
        .logo span { color: var(--text-main); }
        .sidebar nav {
            display: flex;
            flex-direction: column;
            gap: 8px;
            flex: 1;
        }
        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            border-radius: var(--radius-md);
            color: var(--text-muted);
            text-decoration: none;
            font-weight: 500;
            transition: all 0.2s ease;
        }
        .nav-item:hover {
            background-color: var(--bg-color);
            color: var(--text-main);
        }
        .nav-item.active {
            background-color: var(--primary);
            color: white;
            box-shadow: 0 4px 12px rgba(92, 36, 255, 0.2);
        }
        .nav-item i { width: 20px; font-size: 18px; text-align: center; }

        /* Main Content */
        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            min-width: 0;
        }

        /* Header */
        .header {
            background-color: var(--surface);
            padding: 24px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--border);
            position: sticky;
            top: 0;
            z-index: 10;
        }
        .header-title h1 {
            font-size: 24px;
            font-weight: 700;
            margin-bottom: 4px;
        }
        .header-title p {
            color: var(--text-muted);
            font-size: 14px;
        }
        
        .search-bar {
            display: flex;
            align-items: center;
            background-color: var(--bg-color);
            border: 1px solid var(--border);
            border-radius: var(--radius-full);
            padding: 8px 16px;
            width: 320px;
            transition: 0.3s;
        }
        .search-bar:focus-within {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px var(--primary-lighter);
            background-color: var(--surface);
        }
        .search-bar input {
            border: none;
            background: transparent;
            outline: none;
            width: 100%;
            padding: 8px;
            font-size: 14px;
            color: var(--text-main);
        }
        .search-bar i {
            color: var(--text-muted);
        }

        .user-profile {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-left: 24px;
        }
        .avatar {
            width: 40px;
            height: 40px;
            border-radius: var(--radius-full);
            background: linear-gradient(135deg, var(--primary), var(--primary-light));
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
        }

        /* Content Area */
        .content-area {
            padding: 40px;
            max-width: 1400px;
            width: 100%;
            margin: 0 auto;
        }
        
        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
        }
        .section-header h2 {
            font-size: 20px;
            font-weight: 700;
        }
        
        /* Filters */
        .filters {
            display: flex;
            gap: 12px;
            margin-bottom: 32px;
            flex-wrap: wrap;
        }
        .filter-btn {
            padding: 8px 16px;
            border-radius: var(--radius-full);
            border: 1px solid var(--border);
            background: var(--surface);
            color: var(--text-muted);
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: 0.2s;
        }
        .filter-btn:hover {
            border-color: var(--primary-light);
            color: var(--primary);
        }
        .filter-btn.active {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }

        /* Courses Grid */
        .courses-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 24px;
        }
        
        .course-card {
            background: var(--surface);
            border-radius: var(--radius-lg);
            border: 1px solid var(--border);
            overflow: hidden;
            transition: all 0.3s ease;
            display: flex;
            flex-direction: column;
            cursor: pointer;
        }
        .course-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow-hover);
            border-color: var(--primary-light);
        }
        
        .course-thumbnail {
            width: 100%;
            height: 180px;
            background: linear-gradient(135deg, #e2e8f0 0%, #cbd5e1 100%);
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 48px;
        }
        .course-thumbnail img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .course-badge {
            position: absolute;
            top: 12px;
            left: 12px;
            background: rgba(255, 255, 255, 0.9);
            color: var(--text-main);
            padding: 4px 12px;
            border-radius: var(--radius-full);
            font-size: 12px;
            font-weight: 600;
            box-shadow: var(--shadow-sm);
        }
        
        .course-info {
            padding: 20px;
            flex: 1;
            display: flex;
            flex-direction: column;
        }
        .course-title {
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 8px;
            color: var(--text-main);
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        .course-desc {
            font-size: 14px;
            color: var(--text-muted);
            margin-bottom: 16px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            flex: 1;
        }
        
        .course-meta {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 16px;
            font-size: 13px;
            color: var(--text-muted);
        }
        .course-meta i {
            color: var(--primary);
            margin-right: 4px;
        }
        
        .course-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-top: 16px;
            border-top: 1px solid var(--border);
        }
        .course-price {
            font-size: 18px;
            font-weight: 800;
            color: var(--primary);
        }
        .course-price.free {
            color: var(--success);
        }
        .btn-enroll {
            background: var(--primary-lighter);
            color: var(--primary);
            padding: 8px 16px;
            border-radius: var(--radius-full);
            font-weight: 600;
            font-size: 13px;
            text-decoration: none;
            transition: 0.2s;
        }
        .course-card:hover .btn-enroll {
            background: var(--primary);
            color: white;
        }

        .empty-state {
            text-align: center;
            padding: 80px 0;
            color: var(--text-muted);
        }
        .empty-state i {
            font-size: 48px;
            margin-bottom: 16px;
            color: var(--border);
        }
        .empty-state h3 {
            font-size: 20px;
            color: var(--text-main);
            margin-bottom: 8px;
        }

        /* Random Gradients for Thumbnails */
        .grad-1 { background: linear-gradient(135deg, #FF9A9E 0%, #FECFEF 99%, #FECFEF 100%); }
        .grad-2 { background: linear-gradient(120deg, #a1c4fd 0%, #c2e9fb 100%); }
        .grad-3 { background: linear-gradient(120deg, #d4fc79 0%, #96e6a1 100%); }
        .grad-4 { background: linear-gradient(120deg, #84fab0 0%, #8fd3f4 100%); }
        .grad-5 { background: linear-gradient(120deg, #e0c3fc 0%, #8ec5fc 100%); }

    </style>
</head>
<body>

     <!-- Sidebar -->
    <aside class="sidebar">
        <div class="logo">
            <i class="fa-solid fa-graduation-cap" style="color: var(--primary)"></i>
            Edu<span>Nexus</span>
        </div>
        <nav>
            <a href="@Url.Action("StudentDashboard", "Common")" class="nav-item">
                <i class="fa-solid fa-chart-line"></i> Dashboard
            </a>
            <a href="@Url.Action("AllCourses", "Common")" class="nav-item active">
                <i class="fa-solid fa-book-open"></i> All Courses
            </a>
            <a href="@Url.Action("PersonalProgress", "Common")" class="nav-item">
                <i class="fa-solid fa-bullseye"></i> Personal Progress
            </a>
            <div class="progress-submenu" style="margin-left: 20px; padding-left: 12px; border-left: 2px solid var(--border); margin-top: -4px; margin-bottom: 12px;">
                <a href="@Url.Action("History", "Quiz")" class="nav-item" style="padding: 8px 12px; margin-bottom: 4px; font-size: 14px; gap: 10px;">
                    <i class="fa-solid fa-clipboard-check" style="font-size: 12px; color: #f59e0b;"></i> Quiz History
                </a>
                <a href="@Url.Action("FlashcardLibrary", "Home")" class="nav-item" style="padding: 8px 12px; margin-bottom: 4px; font-size: 14px; gap: 10px;">
                    <i class="fa-solid fa-clone" style="font-size: 12px; color: #10b981;"></i> Flashcard
                </a>
            </div>
            <a href="@Url.Action("StudentLibrary", "Common")" class="nav-item">
                <i class="fa-solid fa-folder-open"></i> Library
            </a>
            <div style="flex: 1;"></div>
            <a href="@Url.Action("StudentSettings", "Common")" class="nav-item">
                <i class="fa-solid fa-gear"></i> Settings
            </a>
            <a href="@Url.Action("SignOut", "Common")" class="nav-item" style="color: var(--danger);">
                <i class="fa-solid fa-arrow-right-from-bracket"></i> Logout
            </a>
        </nav>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
        <!-- Header -->
        <header class="header">
            <div class="header-title">
                <h1>Course Catalog</h1>
                <p>Discover new skills and expand your knowledge.</p>
            </div>
            
            <div style="display: flex; align-items: center;">
                <form method="get" action="@Url.Action("AllCourses", "Common")">
                    <div class="search-bar">
                        <i class="fa-solid fa-magnifying-glass"></i>
                        <input type="text" name="search" value="@Model.SearchQuery" placeholder="Search for courses...">
                    </div>
                </form>

                @if (Model.IsGuest)
                {
                    <div style="margin-left: 24px; display: flex; gap: 12px;">
                        <a href="@Url.Action("UserLogin", "Common")" style="text-decoration: none; font-weight: 600; color: var(--text-main); padding: 8px 16px; border: 1px solid var(--border); border-radius: var(--radius-full);">Sign In</a>
                        <a href="@Url.Action("UserRegister", "Common")" style="text-decoration: none; font-weight: 600; color: white; background: var(--primary); padding: 8px 16px; border-radius: var(--radius-full);">Sign Up</a>
                    </div>
                }
                else
                {
                    <div class="user-profile">
                        <span style="font-weight: 600; font-size: 14px;">@(Model.StudentName)</span>
                        <div class="avatar">
                            @(Model.StudentName.Substring(0, 1).ToUpper())
                        </div>
                    </div>
                }
            </div>
        </header>

        <!-- Content Area -->
        <div class="content-area">
            
            <div class="section-header">
                <h2>Explore Courses</h2>
                <span style="color: var(--text-muted); font-size: 14px; font-weight: 500;">Showing @Model.Courses.Count results</span>
            </div>

            <!-- Categories / Filters -->
            <div class="filters">
                <button class="filter-btn active">All</button>
                <button class="filter-btn">Development</button>
                <button class="filter-btn">Business</button>
                <button class="filter-btn">Design</button>
                <button class="filter-btn">Marketing</button>
            </div>

            <!-- Courses Grid -->
            @if (Model.Courses.Count > 0)
            {
                <div class="courses-grid">
                    @{
                        int colorIndex = 1;
                        var icons = new[] { "fa-code", "fa-chart-pie", "fa-pen-nib", "fa-bullhorn", "fa-rocket" };
                    }
                    @foreach (var course in Model.Courses)
                    {
                        var gradClass = $"grad-{colorIndex}";
                        var icon = icons[(colorIndex - 1) % icons.Length];
                        colorIndex = colorIndex >= 5 ? 1 : colorIndex + 1;

                        <div class="course-card">
                            <div class="course-thumbnail @gradClass">
                                @if (!string.IsNullOrEmpty(course.CourseGroupName))
                                {
                                    <div class="course-badge">@course.CourseGroupName</div>
                                }
                                <i class="fa-solid @icon"></i>
                            </div>
                            <div class="course-info">
                                <h3 class="course-title">@course.Title</h3>
                                <p class="course-desc">@course.Description</p>
                                
                                <div class="course-meta">
                                    <span><i class="fa-solid fa-chalkboard-user"></i> @course.InstructorName</span>
                                    <span><i class="fa-solid fa-layer-group"></i> v@(course.Version).0</span>
                                </div>
                                
                                <div class="course-footer">
                                    @if (course.Price == 0)
                                    {
                                        <div class="course-price free">Free</div>
                                    }
                                    else
                                    {
                                        <div class="course-price">$@course.Price.ToString("N0")</div>
                                    }
                                    @if (Model.IsGuest)
                                    {
                                        if (course.FirstLessonId.HasValue)
                                        {
                                            <a href="@Url.Action("LessonPreview", "Lesson", new { id = course.FirstLessonId })" class="btn-enroll">Try Learning</a>
                                        }
                                        else
                                        {
                                            <a href="@Url.Action("UserLogin", "Common")" class="btn-enroll">Try Learning</a>
                                        }
                                    }
                                    else
                                    {
                                        if (course.FirstLessonId.HasValue)
                                        {
                                            <a href="@Url.Action("LessonPreview", "Lesson", new { id = course.FirstLessonId })" class="btn-enroll">Explore</a>
                                        }
                                        else
                                        {
                                            <a href="#" class="btn-enroll">Explore</a>
                                        }
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="fa-regular fa-folder-open"></i>
                    <h3>No courses found</h3>
                    <p>Try adjusting your search query to find what you're looking for.</p>
                    @if (!string.IsNullOrEmpty(Model.SearchQuery))
                    {
                        <a href="@Url.Action("AllCourses", "Common")" style="color: var(--primary); font-weight: 600; text-decoration: none; margin-top: 16px; display: inline-block;">Clear Search</a>
                    }
                </div>
            }

        </div>
    </main>

</body>
</html>
