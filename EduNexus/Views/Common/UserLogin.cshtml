@model EduNexus.ViewModels.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign In - EduNexus</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #5c24ff;
            --primary-light: #9b8cf8;
            --bg-color: #ffffff;
            --text-main: #000000;
            --text-muted: #6b7280;
            --input-bg: #f3f4f6;
            --border-color: #e5e7eb;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            display: flex;
            min-height: 100vh;
            background-color: var(--bg-color);
        }

        .left-panel {
            flex: 1.1;
            display: flex;
            flex-direction: column;
            padding: 40px;
            position: relative;
        }

        .top-nav {
            font-size: 14px;
            color: var(--text-main);
            margin-bottom: auto;
        }

        .top-nav a {
            color: var(--primary);
            text-decoration: none;
            font-weight: 600;
        }

        .form-container {
            max-width: 420px;
            width: 100%;
            margin: 0 auto;
            margin-bottom: auto;
        }

        .form-container h1 {
            font-size: 36px;
            font-weight: 800;
            color: var(--text-main);
            margin-bottom: 40px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-control {
            width: 100%;
            padding: 16px;
            background-color: var(--input-bg);
            border: none;
            border-radius: 8px;
            font-size: 14px;
            color: var(--text-main);
            outline: none;
            transition: 0.2s;
        }

        .form-control::placeholder {
            color: #9ca3af;
        }

        .form-control:focus {
            box-shadow: 0 0 0 2px var(--primary-light);
        }

        .form-options {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 24px;
            font-size: 13px;
        }

        .checkbox-group {
            display: flex;
            align-items: center;
            gap: 12px;
            color: var(--text-main);
        }

        .custom-checkbox {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 24px;
            height: 24px;
            background-color: var(--primary);
            border-radius: 50%;
            cursor: pointer;
            flex-shrink: 0;
        }

        .custom-checkbox-dot {
            width: 8px;
            height: 8px;
            background-color: white;
            border-radius: 50%;
        }

        .forgot-password {
            color: var(--primary);
            text-decoration: none;
            font-weight: 600;
        }

        .btn-primary {
            width: 100%;
            padding: 16px;
            background-color: var(--primary-light);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
        }

        .btn-primary:hover {
            background-color: var(--primary);
        }

        .divider {
            display: flex;
            align-items: center;
            text-align: center;
            margin: 32px 0;
            color: var(--text-muted);
            font-size: 13px;
        }

        .divider::before,
        .divider::after {
            content: '';
            flex: 1;
            border-bottom: 1px solid var(--border-color);
        }

        .divider:not(:empty)::before {
            margin-right: .5em;
        }

        .divider:not(:empty)::after {
            margin-left: .5em;
        }

        .social-login {
            display: flex;
            justify-content: center;
        }

        .btn-google {
            width: 100px;
            height: 60px;
            background-color: var(--input-bg);
            border: none;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: 0.2s;
        }

        .btn-google:hover {
            background-color: #e5e7eb;
        }

        .btn-google svg {
            width: 24px;
            height: 24px;
        }

        .right-panel {
            flex: 0.9;
            background-color: var(--primary);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 60px;
        }

        .right-panel h1 {
            color: white;
            font-size: 64px;
            font-weight: 800;
            line-height: 1.2;
            letter-spacing: -1px;
        }

        @@media (max-width: 900px) {
            body {
                flex-direction: column;
            }
            .right-panel {
                display: none;
            }
        }
    </style>
</head>
<body>

    <div class="left-panel">
        <div class="top-nav">
            Don't have an account? <a href="@Url.Action("UserRegister", "Common")">Sign Up</a>
        </div>
        
        <div class="form-container">
            <h1>Welcome Back</h1>
            
            <form asp-action="UserLogin" method="POST">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="ModelOnly" class="text-danger" style="color:red; margin-bottom:15px; font-size:14px;"></div>
                }

                <div class="form-group">
                    <input asp-for="Email" class="form-control" placeholder="Email address" required>
                    <span asp-validation-for="Email" style="color:red; font-size: 12px; margin-top: 5px; display: block;"></span>
                </div>
                <div class="form-group">
                    <input asp-for="Password" class="form-control" placeholder="Password" required>
                    <span asp-validation-for="Password" style="color:red; font-size: 12px; margin-top: 5px; display: block;"></span>
                </div>
                
                <div class="form-options">
                    <div class="checkbox-group">
                        <!-- Custom styled checkbox -->
                        <div class="custom-checkbox" id="rememberMeCheck">
                            <div class="custom-checkbox-dot" style="display:none;"></div>
                        </div>
                        <input type="checkbox" asp-for="RememberMe" id="rememberMeInput" style="display:none;" />
                        <span>Remember me</span>
                    </div>
                    <a href="@Url.Action("ForgotPassword", "Common")" class="forgot-password">Forgot password?</a>
                </div>
                
                <button type="submit" class="btn-primary">Sign In</button>
            </form>

            <div class="divider">Or sign in with</div>

            <div class="social-login">
                <a href="@Url.Action("GoogleLogin", "Common")" class="btn-google" style="text-decoration: none; color: inherit;">
                    <svg viewBox="0 0 24 24">
                        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                        <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                        <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                        <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                        <path fill="none" d="M1 1h22v22H1z"/>
                    </svg>
                </a>
            </div>
        </div>
    </div>

    <div class="right-panel">
        <h1>Let Study<br>ON TIME.</h1>
    </div>

    <script>
        // Simple script to toggle the custom checkbox visually
        const rememberMeCheck = document.getElementById('rememberMeCheck');
        const rememberMeInput = document.getElementById('rememberMeInput');
        const dot = rememberMeCheck.querySelector('.custom-checkbox-dot');
        
        // Initialize from input
        if (rememberMeInput.checked) {
            dot.style.display = 'block';
            rememberMeCheck.style.backgroundColor = 'var(--primary)';
        } else {
            dot.style.display = 'none';
            rememberMeCheck.style.backgroundColor = 'var(--border-color)';
        }

        rememberMeCheck.addEventListener('click', function() {
            if (rememberMeInput.checked) {
                rememberMeInput.checked = false;
                dot.style.display = 'none';
                this.style.backgroundColor = 'var(--border-color)';
            } else {
                rememberMeInput.checked = true;
                dot.style.display = 'block';
                this.style.backgroundColor = 'var(--primary)';
            }
        });
    </script>
</body>
</html>
