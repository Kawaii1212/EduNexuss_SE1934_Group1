@model EduNexus.ViewModels.QuizTakingViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quiz Taking - @Model.QuizName</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary: #5c24ff; --primary-lighter: #f0edff; --bg: #f3f4f6; --surface: #fff;
            --text: #111827; --muted: #6b7280; --border: #e5e7eb;
        }
        * { box-sizing: border-box; font-family: 'Inter', sans-serif; }
        body { margin: 0; background: var(--bg); color: var(--text); min-height: 100vh; }
        .topbar { background: var(--surface); border-bottom: 1px solid var(--border); padding: 16px 32px; display: flex; justify-content: space-between; align-items: center; position: sticky; top: 0; z-index: 10; }
        .topbar h1 { font-size: 18px; margin: 0 0 4px; }
        .topbar p { margin: 0; font-size: 13px; color: var(--muted); }
        .timer { font-variant-numeric: tabular-nums; font-weight: 700; font-size: 20px; color: var(--primary); background: var(--primary-lighter); padding: 8px 16px; border-radius: 8px; }
        .layout { max-width: 960px; margin: 0 auto; padding: 24px 20px; display: grid; grid-template-columns: 1fr 220px; gap: 24px; }
        @@media (max-width: 768px) { .layout { grid-template-columns: 1fr; } }
        .panel { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
        .panel-body { padding: 28px; min-height: 280px; }
        .panel-footer { padding: 16px 20px; border-top: 1px solid var(--border); display: flex; justify-content: space-between; gap: 12px; }
        .btn { padding: 10px 18px; border-radius: 8px; font-weight: 600; font-size: 14px; cursor: pointer; border: 1px solid var(--border); background: var(--surface); }
        .btn:hover { border-color: #c4b5fd; }
        .btn:disabled { opacity: .5; cursor: not-allowed; }
        .btn-primary { background: var(--primary); color: #fff; border-color: var(--primary); width: 100%; margin-top: 16px; padding: 14px; }
        .btn-primary:hover { background: #481ce0; }
        .btn-nav-active { background: var(--primary); color: #fff; border-color: var(--primary); }
        .btn-nav-answered { background: var(--primary-lighter); color: var(--primary); border-color: #c4b5fd; }
        .panel-side .panel-head { padding: 14px 16px; font-weight: 600; border-bottom: 1px solid var(--border); font-size: 14px; }
        .q-nav { padding: 16px; display: flex; flex-wrap: wrap; gap: 8px; }
        .q-nav button { min-width: 36px; height: 36px; padding: 0; }
        .option-label { cursor: pointer; border: 1px solid var(--border); border-radius: 8px; padding: 14px 16px; display: block; margin-bottom: 10px; background: #fff; transition: .15s; }
        .option-label:hover { border-color: #9b8cf8; }
        input[type=radio] { display: none; }
        input[type=radio]:checked + .option-label { border-color: var(--primary); background: var(--primary-lighter); }
        .question-title { font-size: 17px; font-weight: 600; margin-bottom: 20px; line-height: 1.5; }
        .d-none { display: none !important; }
    </style>
</head>
<body>
<header class="topbar">
    <div>
        <h1>@Model.QuizName</h1>
        <p>Bài luyện tập — không tính vào sổ điểm chính thức</p>
    </div>
    <div class="timer" id="timer">@Model.DurationMinutes:00</div>
</header>

<form asp-action="Submit" method="post" id="quizForm" class="layout">
    @Html.AntiForgeryToken()
    <input type="hidden" name="AttemptId" value="@Model.AttemptId" />

    <div>
        <div class="panel">
            <div class="panel-body" id="questionPanel"></div>
            <div class="panel-footer">
                <button type="button" class="btn" id="prevBtn">← Trước</button>
                <button type="button" class="btn" id="nextBtn">Sau →</button>
            </div>
        </div>
        <button type="submit" class="btn btn-primary" onclick="return confirm('Nộp bài?');">
            <i class="fa-solid fa-paper-plane"></i> Nộp bài
        </button>
    </div>

    <div class="panel panel-side">
        <div class="panel-head">Danh sách câu</div>
        <div class="q-nav" id="qNav"></div>
    </div>
</form>

<script>
    const questions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Questions));
    let current = 0;
    const answers = {};

    function renderQuestion() {
        const q = questions[current];
        const opts = [
            { key: 'A', text: q.OptionA }, { key: 'B', text: q.OptionB },
            { key: 'C', text: q.OptionC }, { key: 'D', text: q.OptionD }
        ];
        let html = `<div class="question-title">Câu ${q.OrderNo}: ${q.Content}</div>`;
        opts.forEach(o => {
            const checked = answers[q.QuestionId] === o.key ? 'checked' : '';
            html += `<div>
                <input type="radio" name="Answers[${q.QuestionId}]" id="opt_${q.QuestionId}_${o.key}" value="${o.key}" ${checked}
                    onchange="answers[${q.QuestionId}]='${o.key}'; updateNav();">
                <label class="option-label" for="opt_${q.QuestionId}_${o.key}"><strong>${o.key}.</strong> ${o.text}</label>
            </div>`;
        });
        document.getElementById('questionPanel').innerHTML = html;
        document.getElementById('prevBtn').disabled = current === 0;
        document.getElementById('nextBtn').disabled = current === questions.length - 1;
        updateNav();
    }

    function updateNav() {
        document.getElementById('qNav').innerHTML = questions.map((q, i) => {
            let cls = 'btn';
            if (answers[q.QuestionId]) cls += ' btn-nav-answered';
            if (i === current) cls += ' btn-nav-active';
            return `<button type="button" class="${cls}" onclick="goTo(${i})">${q.OrderNo}</button>`;
        }).join('');
    }

    function goTo(i) { current = i; renderQuestion(); }
    document.getElementById('prevBtn').onclick = () => { if (current > 0) { current--; renderQuestion(); } };
    document.getElementById('nextBtn').onclick = () => { if (current < questions.length - 1) { current++; renderQuestion(); } };

    let seconds = @Model.DurationMinutes * 60;
    setInterval(() => {
        if (seconds <= 0) { document.getElementById('quizForm').submit(); return; }
        seconds--;
        const m = Math.floor(seconds / 60), s = seconds % 60;
        document.getElementById('timer').textContent = `${m}:${s.toString().padStart(2,'0')}`;
    }, 1000);

    renderQuestion();
</script>
</body>
</html>
