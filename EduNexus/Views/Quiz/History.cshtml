@model EduNexus.ViewModels.QuizHistoryViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quiz History - EduNexus</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            /* Synchronized with EduNexus */
            --primary: #5c24ff;
            --primary-light: #9b8cf8;
            --primary-lighter: #f0edff;
            --primary-hover: #481ce0;
            --bg-color: #fafafa;
            --surface: #ffffff;
            --text-main: #111827;
            --text-muted: #6b7280;
            --text-light: #9ca3af;
            --border: #e5e7eb;
            --border-hover: #d1d5db;
            --danger: #ef4444;
            --success: #10b981;
            --warning: #f59e0b;
            --radius-md: 8px;
            --radius-lg: 12px;
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            display: flex;
            min-height: 100vh;
        }

        /* Sidebar */
        .sidebar {
            width: 260px;
            background-color: var(--surface);
            border-right: 1px solid var(--border);
            padding: 24px;
            display: flex;
            flex-direction: column;
            position: fixed;
            height: 100vh;
            z-index: 10;
        }

        .logo {
            font-size: 24px;
            font-weight: 800;
            color: var(--text-main);
            margin-bottom: 40px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .logo span {
                color: var(--primary);
            }

        .sidebar nav {
            display: flex;
            flex-direction: column;
            flex: 1;
        }

        .nav-item {
            padding: 12px 16px;
            margin-bottom: 8px;
            border-radius: var(--radius-md);
            color: var(--text-muted);
            text-decoration: none;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 12px;
            transition: all 0.2s ease;
        }

            .nav-item:hover {
                background-color: var(--bg-color);
                color: var(--text-main);
            }

            .nav-item.active {
                background-color: var(--primary-lighter);
                color: var(--primary);
            }

        /* Main Content */
        .main-content {
            flex: 1;
            margin-left: 260px;
            padding: 40px;
            max-width: 1200px;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 32px;
        }

        .header-title h1 {
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .header-title p {
            color: var(--text-muted);
            font-size: 14px;
        }

        .btn {
            padding: 10px 20px;
            border-radius: var(--radius-md);
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            border: none;
            transition: all 0.2s ease;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
        }

        .btn-outline {
            background-color: transparent;
            border: 1px solid var(--border);
            color: var(--text-main);
        }

            .btn-outline:hover {
                background-color: var(--bg-color);
                border-color: var(--border-hover);
            }

        .btn-primary {
            background-color: var(--primary-light);
            color: white;
            box-shadow: 0 4px 12px rgba(155, 140, 248, 0.3);
        }

            .btn-primary:hover {
                background-color: var(--primary);
                box-shadow: 0 6px 16px rgba(92, 36, 255, 0.4);
                transform: translateY(-1px);
            }

        /* Stats Grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 24px;
            margin-bottom: 40px;
        }

        .stat-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 24px;
            box-shadow: var(--shadow-sm);
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .stat-icon {
            width: 48px;
            height: 48px;
            border-radius: var(--radius-md);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }

        .icon-blue {
            background: #eff6ff;
            color: #3b82f6;
        }

        .icon-green {
            background: #ecfdf5;
            color: var(--success);
        }

        .icon-orange {
            background: #fffbeb;
            color: var(--warning);
        }

        .icon-purple {
            background: var(--primary-lighter);
            color: var(--primary);
        }

        .stat-info h4 {
            color: var(--text-muted);
            font-size: 13px;
            font-weight: 500;
            margin-bottom: 4px;
        }

        .stat-info p {
            color: var(--text-main);
            font-size: 24px;
            font-weight: 700;
        }

        /* Filter Toolbar */
        .toolbar {
            display: flex;
            gap: 16px;
            margin-bottom: 24px;
            align-items: center;
        }

        .search-box {
            flex: 1;
            position: relative;
            display: flex;
            align-items: center;
        }

            .search-box i {
                position: absolute;
                left: 16px;
                color: var(--text-light);
            }

        .search-input {
            width: 100%;
            padding: 12px 16px 12px 44px;
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            background: var(--surface);
            font-size: 14px;
            outline: none;
            transition: all 0.2s ease;
        }

            .search-input:focus {
                border-color: var(--primary-light);
            }

        .filter-select {
            padding: 12px 16px;
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            background: var(--surface);
            font-size: 14px;
            color: var(--text-main);
            outline: none;
            cursor: pointer;
        }

        /* History List/Table */
        .history-container {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-sm);
            overflow: hidden;
        }

        .history-header {
            display: grid;
            grid-template-columns: 2fr 1.5fr 1fr 1fr 1.5fr 1fr 1fr;
            padding: 16px 24px;
            background: #fcfcfc;
            border-bottom: 1px solid var(--border);
            font-size: 12px;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .sortable {
            cursor: pointer;
            user-select: none;
            display: flex;
            align-items: center;
            gap: 4px;
        }

            .sortable:hover {
                color: var(--primary);
            }

            .sortable i {
                font-size: 10px;
                color: var(--border-hover);
            }

        .history-row {
            display: grid;
            grid-template-columns: 2fr 1.5fr 1fr 1fr 1.5fr 1fr 1fr;
            padding: 20px 24px;
            border-bottom: 1px solid var(--border);
            align-items: center;
            transition: 0.2s;
        }

            .history-row:last-child {
                border-bottom: none;
            }

            .history-row:hover {
                background: var(--bg-color);
            }

        /* Columns */
        .col-quiz {
            display: flex;
            align-items: flex-start;
            gap: 16px;
        }

        .quiz-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: var(--primary-lighter);
            color: var(--primary);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            flex-shrink: 0;
        }

        .quiz-details h4 {
            font-size: 15px;
            font-weight: 600;
            color: var(--text-main);
            margin-bottom: 0px;
        }

        .col-date {
            font-size: 14px;
            color: var(--text-main);
            font-weight: 500;
        }

            .col-date span {
                display: block;
                font-size: 12px;
                color: var(--text-muted);
                font-weight: 400;
                margin-top: 2px;
            }

        .col-score {
            font-size: 18px;
            font-weight: 700;
        }

        .score-high {
            color: var(--success);
        }

        .score-medium {
            color: var(--warning);
        }

        .score-low {
            color: var(--danger);
        }

        .col-status {
            display: flex;
        }

        .badge {
            padding: 4px 10px;
            border-radius: 100px;
            font-size: 12px;
            font-weight: 600;
        }

        .badge-passed {
            background: #ecfdf5;
            color: var(--success);
            border: 1px solid #a7f3d0;
        }

        .badge-failed {
            background: #fef2f2;
            color: var(--danger);
            border: 1px solid #fecaca;
        }

        .col-action {
            display: flex;
            justify-content: flex-end;
        }

        .btn-text {
            color: var(--primary);
            font-weight: 600;
            font-size: 13px;
            text-decoration: none;
            padding: 8px 12px;
            border-radius: var(--radius-md);
            transition: 0.2s;
        }

            .btn-text:hover {
                background: var(--primary-lighter);
            }

        /* Responsive */
        @@media (max-width: 1024px) {
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .history-header {
                display: none; /* Hide table header on mobile */
            }

            .history-row {
                grid-template-columns: 1fr;
                gap: 16px;
            }

            .col-action {
                justify-content: flex-start;
            }
        }
    </style>
</head>
<body>

    <aside class="sidebar">
        <div class="logo">
            <i class="fa-solid fa-graduation-cap" style="color: var(--primary)"></i>
            Edu<span>Nexus</span>
        </div>
        <nav>
            <a href="@Url.Action("StudentDashboard", "Common")" class="nav-item">
                <i class="fa-solid fa-chart-line"></i> Dashboard
            </a>
            <a href="@Url.Action("AllCourses", "Common")" class="nav-item">
                <i class="fa-solid fa-book-open"></i> All Courses
            </a>
            <a href="@Url.Action("PersonalProgress", "Common")" class="nav-item">
                <i class="fa-solid fa-bullseye"></i> Personal Progress
            </a>
            <div class="course-submenu" style="margin-left: 20px; padding-left: 12px; border-left: 2px solid var(--border); margin-top: -4px; margin-bottom: 12px;">
                <a href="@Url.Action("History", "Quiz")" class="nav-item active" style="padding: 8px 12px; margin-bottom: 4px; font-size: 14px; gap: 10px;">
                    <i class="fa-solid fa-clipboard-check" style="font-size: 12px; color: var(--primary);"></i> Quiz
                </a>
                <a href="#" class="nav-item" style="padding: 8px 12px; margin-bottom: 4px; font-size: 14px; gap: 10px;">
                    <i class="fa-solid fa-clone" style="font-size: 12px; color: #10b981;"></i> Flashcard
                </a>
            </div>
            <a href="@Url.Action("StudentLibrary", "Common")" class="nav-item">
                <i class="fa-solid fa-folder-open"></i> Library
            </a>
            <a href="#" class="nav-item">
                <i class="fa-solid fa-users"></i> Community
            </a>
            <div style="flex: 1;"></div>
            <a href="@Url.Action("StudentSettings", "Common")" class="nav-item">
                <i class="fa-solid fa-gear"></i> Settings
            </a>
            <a href="@Url.Action("SignOut", "Common")" class="nav-item" style="color: var(--danger);">
                <i class="fa-solid fa-arrow-right-from-bracket"></i> Logout
            </a>
        </nav>
    </aside>

    <main class="main-content">

        <header class="header">
            <div class="header-title">
                <h1>Quiz History & Results</h1>
                <p>Review your past assessments, scores, and identify areas for improvement</p>
            </div>
            <button class="btn btn-outline">
                <i class="fa-solid fa-download"></i> Export Transcript
            </button>
        </header>

        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon icon-purple">
                    <i class="fa-solid fa-file-pen"></i>
                </div>
                <div class="stat-info">
                    <h4>Quizzes Taken</h4>
                    <p>@Model.QuizzesTaken</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon icon-blue">
                    <i class="fa-solid fa-percent"></i>
                </div>
                <div class="stat-info">
                    <h4>Average Score</h4>
                    <p>@(Model.AverageScore.ToString("0.0"))</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon icon-green">
                    <i class="fa-solid fa-check"></i>
                </div>
                <div class="stat-info">
                    <h4>Passed</h4>
                    <p>@Model.PassedCount</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon icon-orange">
                    <i class="fa-solid fa-xmark"></i>
                </div>
                <div class="stat-info">
                    <h4>Failed</h4>
                    <p>@Model.FailedCount</p>
                </div>
            </div>
        </div>

        <div class="toolbar">
            <div class="search-box">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" class="search-input" placeholder="Search by quiz name or course...">
            </div>
            <select class="filter-select" id="courseFilter">
                <option value="all">All Courses</option>
                @foreach (var course in Model.Attempts.Select(a => a.CourseName).Distinct().OrderBy(c => c))
                {
                    <option value="@course">@course</option>
                }
            </select>

            <select class="filter-select" id="statusFilter">
                <option value="all">All Statuses</option>
                <option value="passed">Passed</option>
                <option value="failed">Failed</option>
                <option value="in_progress">In Progress</option>
            </select>
        </div>

        <div class="history-container">
            <div class="history-header">
                <div class="sortable" data-sort="name">Quiz Name <i class="fa-solid fa-sort"></i></div>
                <div class="sortable" data-sort="course">Course <i class="fa-solid fa-sort"></i></div>
                <div class="sortable" data-sort="score">Score <i class="fa-solid fa-sort"></i></div>
                <div class="sortable" data-sort="accuracy">Accuracy Ratio <i class="fa-solid fa-sort"></i></div>
                <div class="sortable" data-sort="date">Date <i class="fa-solid fa-sort"></i></div>
                <div class="sortable" data-sort="status">Status <i class="fa-solid fa-sort"></i></div>
                <div>Action</div>
            </div>

            <div id="tableBody">
                @if (Model.Attempts.Any())
                {
                    foreach (var item in Model.Attempts)
                    {
                        var accuracyValue = item.TotalQuestions > 0 ? ((float)item.CorrectAnswers / item.TotalQuestions) : 0;

                        // ĐÃ FIX: Tính toán chuỗi trạng thái phù hợp để gán vào data-status cho bộ lọc JS (Tránh lỗi biên dịch)
                        var uiStatus = item.Status == "SUBMITTED" ? (item.Score >= 50 ? "passed" : "failed") : item.Status.ToLower();
                        var rowIsFailed = uiStatus == "failed";

                        <div class="history-row" data-name="@item.QuizTitle.ToLower()" data-course="@item.CourseName" data-status="@uiStatus" data-date="@item.DateTaken.ToUnixTimeSeconds()" data-score="@(item.Score ?? 0)" data-accuracy="@accuracyValue">
                            <div class="col-quiz">
                                <div class="quiz-icon" style="@(rowIsFailed ? "background: #fef2f2; color: var(--danger);" : "")"><i class="fa-solid fa-code"></i></div>
                                <div class="quiz-details" style="display: flex; align-items: center;">
                                    <h4>@item.QuizTitle</h4>
                                </div>
                            </div>
                            <div class="col-course" style="font-size: 14px; font-weight: 500; color: var(--text-main);">
                                @item.CourseName
                            </div>
                            <div class="col-score @(item.Score >= 80 ? "score-high" : (item.Score >= 60 ? "score-medium" : "score-low"))">
                                @(item.Score.HasValue? item.Score.Value.ToString("0.0") : "-")
                            </div>
                            <div class="col-accuracy" style="font-size: 16px; font-weight: 600; color: var(--text-main);">
                                @(item.CorrectAnswers)/@(item.TotalQuestions)
                            </div>
                            <div class="col-date">
                                @item.DateTaken.LocalDateTime.ToString("MMM dd, yyyy")
                                <span>@item.DateTaken.LocalDateTime.ToString("hh:mm tt")</span>
                            </div>

                            <div class="col-status">
                                @if (item.Status == "SUBMITTED")
                                {
                                    if (item.Score >= 50)
                                    {
                                        <span class="badge badge-passed">Passed</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-failed">Failed</span>
                                    }
                                }
                                else if (item.Status == "IN_PROGRESS")
                                {
                                    <span class="badge" style="background: #f3f4f6; color: var(--text-muted);">In Progress</span>
                                }
                                else
                                {
                                    <span class="badge" style="background: #f3f4f6; color: var(--text-muted);">@item.Status</span>
                                }
                            </div>

                            <div class="col-action">
                                <a href="/Quiz/Review?attemptId=@item.QuizAttemptId" class="btn-text">Review Answers</a>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div style="padding: 40px; text-align: center; color: var(--text-muted);" id="noDataMessage">
                        You haven't taken any quizzes yet.
                    </div>
                }
            </div>

        </div>

    </main>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const searchInput = document.querySelector('.search-input');
            const courseFilter = document.getElementById('courseFilter');
            const statusFilter = document.getElementById('statusFilter');
            const tableBody = document.getElementById('tableBody');
            const rows = Array.from(tableBody.querySelectorAll('.history-row'));
            const sortableHeaders = document.querySelectorAll('.sortable');

            let currentSort = { column: null, asc: true };

            function filterRows() {
                const searchTerm = searchInput.value.toLowerCase();
                const courseTerm = courseFilter.value;
                const statusTerm = statusFilter.value;

                rows.forEach(row => {
                    const name = row.getAttribute('data-name');
                    const course = row.getAttribute('data-course');
                    const status = row.getAttribute('data-status');

                    const matchName = name.includes(searchTerm);
                    const matchCourse = courseTerm === 'all' || course === courseTerm;
                    const matchStatus = statusTerm === 'all' || status === statusTerm;

                    if (matchName && matchCourse && matchStatus) {
                        row.style.display = 'grid';
                    } else {
                        row.style.display = 'none';
                    }
                });
            }

            function sortRows(column) {
                if (currentSort.column === column) {
                    currentSort.asc = !currentSort.asc;
                } else {
                    currentSort.column = column;
                    currentSort.asc = true;
                }

                // Update icons
                sortableHeaders.forEach(th => {
                    const icon = th.querySelector('i');
                    if (th.getAttribute('data-sort') === column) {
                        icon.className = currentSort.asc ? 'fa-solid fa-sort-up' : 'fa-solid fa-sort-down';
                        icon.style.color = 'var(--primary)';
                    } else {
                        icon.className = 'fa-solid fa-sort';
                        icon.style.color = 'var(--border-hover)';
                    }
                });

                const sortedRows = [...rows].sort((a, b) => {
                    let valA = a.getAttribute('data-' + column);
                    let valB = b.getAttribute('data-' + column);

                    // Numeric sorts
                    if (['score', 'accuracy', 'date'].includes(column)) {
                        valA = parseFloat(valA);
                        valB = parseFloat(valB);
                        return currentSort.asc ? valA - valB : valB - valA;
                    } else {
                        // String sorts
                        return currentSort.asc ? valA.localeCompare(valB) : valB.localeCompare(valA);
                    }
                });

                // Re-append sorted rows
                sortedRows.forEach(row => tableBody.appendChild(row));
            }

            searchInput.addEventListener('input', filterRows);
            courseFilter.addEventListener('change', filterRows);
            statusFilter.addEventListener('change', filterRows);

            sortableHeaders.forEach(th => {
                th.addEventListener('click', () => {
                    const column = th.getAttribute('data-sort');
                    sortRows(column);
                });
            });
        });
    </script>
</body>
</html>