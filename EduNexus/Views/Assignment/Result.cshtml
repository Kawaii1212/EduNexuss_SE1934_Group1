@model EduNexus.ViewModels.SubmissionResultViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Assignment Result - EduNexus</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary: #5c24ff;
            --primary-light: #9b8cf8;
            --primary-lighter: #f0edff;
            --primary-hover: #481ce0;
            --bg-color: #fafafa;
            --surface: #ffffff;
            --text-main: #111827;
            --text-muted: #6b7280;
            --border: #e5e7eb;
            --border-hover: #d1d5db;
            --danger: #ef4444;
            --success: #10b981;
            --warning: #f59e0b;
            --radius-md: 8px;
            --radius-lg: 12px;
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Topbar */
        .topbar {
            height: 70px;
            background-color: var(--surface);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 40px;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: var(--shadow-sm);
        }

        .back-btn {
            color: var(--text-muted);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 500;
            font-size: 14px;
            transition: 0.2s;
        }

        .back-btn:hover {
            color: var(--text-main);
        }

        .breadcrumbs {
            font-size: 14px;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .breadcrumbs span {
            color: var(--text-main);
            font-weight: 600;
        }

        /* Layout */
        .result-container {
            flex: 1;
            display: flex;
            padding: 40px;
            max-width: 1400px;
            margin: 0 auto;
            width: 100%;
            gap: 32px;
        }

        .main-col {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 24px;
        }

        .side-col {
            width: 350px;
            display: flex;
            flex-direction: column;
            gap: 24px;
        }

        /* Cards */
        .card {
            background: var(--surface);
            border-radius: var(--radius-lg);
            border: 1px solid var(--border);
            padding: 32px;
            box-shadow: var(--shadow-sm);
        }

        .card-header-styled {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 24px;
            padding-bottom: 24px;
            border-bottom: 1px solid var(--border);
        }

        .card-title {
            font-size: 24px;
            font-weight: 700;
            color: var(--text-main);
            margin-bottom: 8px;
        }

        .card-subtitle {
            color: var(--primary);
            font-size: 14px;
            font-weight: 600;
        }

        /* Rubric Table */
        .rubric-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 16px;
        }

        .rubric-table th, .rubric-table td {
            border: 1px solid var(--border);
            padding: 16px;
            text-align: left;
        }

        .rubric-table th {
            background-color: #fafafa;
            color: var(--text-muted);
            font-weight: 600;
            font-size: 14px;
        }

        .rubric-table td {
            font-size: 15px;
            vertical-align: top;
        }
        
        .rubric-table tr:hover {
            background-color: #f9fafb;
        }

        .score-box {
            display: inline-block;
            padding: 4px 10px;
            border-radius: var(--radius-md);
            font-weight: 700;
            font-size: 16px;
        }

        .score-ai {
            background-color: #eff6ff;
            color: #3b82f6;
        }

        .score-final {
            background-color: #ecfdf5;
            color: var(--success);
        }
        
        .feedback-text {
            color: var(--text-muted);
            font-size: 14px;
            margin-top: 8px;
            line-height: 1.5;
        }

        /* Sidebar Cards */
        .status-title {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .status-row {
            display: flex;
            justify-content: space-between;
            padding: 12px 0;
            border-bottom: 1px solid var(--border);
            font-size: 14px;
        }

        .status-row:last-child {
            border-bottom: none;
        }

        .status-label {
            color: var(--text-muted);
            font-weight: 500;
        }

        .status-value {
            font-weight: 600;
            color: var(--text-main);
        }

        .badge-status {
            padding: 4px 10px;
            border-radius: 100px;
            font-size: 12px;
            font-weight: 600;
            background: #f3f4f6;
            color: var(--text-muted);
        }

        .badge-success { background: #ecfdf5; color: var(--success); }
        
        .score-display {
            text-align: center;
            padding: 24px 0;
        }
        
        .score-circle {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            border: 8px solid var(--success);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 16px auto;
            font-size: 32px;
            font-weight: 800;
            color: var(--success);
        }
        
        .ai-score-circle {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            border: 8px solid #3b82f6;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 16px auto;
            font-size: 32px;
            font-weight: 800;
            color: #3b82f6;
        }

        .btn {
            padding: 12px 20px;
            border-radius: var(--radius-md);
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            border: none;
            transition: all 0.2s ease;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            width: 100%;
            margin-top: 24px;
            text-decoration: none;
        }

        .btn-outline {
            background-color: transparent;
            border: 1px solid var(--border);
            color: var(--text-main);
        }

        .btn-outline:hover {
            background-color: var(--bg-color);
        }
        
        .general-feedback {
            padding: 20px;
            background: var(--bg-color);
            border-left: 4px solid var(--primary);
            border-radius: 0 var(--radius-md) var(--radius-md) 0;
            font-size: 15px;
            line-height: 1.6;
        }
    </style>
</head>
<body>

    <!-- Top Navigation -->
    <header class="topbar">
        <div class="topbar-left">
            <a href="javascript:history.back()" class="back-btn">
                <i class="fa-solid fa-arrow-left"></i> Back
            </a>
            <div class="breadcrumbs">
                Assignment <i class="fa-solid fa-chevron-right" style="font-size: 10px;"></i> <span>Evaluation Result</span>
            </div>
        </div>
    </header>

    <div class="result-container">
        
        <!-- Left Column: Assignment Details & Rubric -->
        <div class="main-col">
            <div class="card">
                <div class="card-header-styled">
                    <div>
                        <div class="card-subtitle">Evaluation Result</div>
                        <h1 class="card-title">@Model.AssignmentTitle</h1>
                    </div>
                </div>

                <div class="mb-4">
                    <h3 style="font-size: 18px; margin-bottom: 16px;"><i class="fa-solid fa-comment-dots"></i> General Feedback</h3>
                    <div class="general-feedback">
                        @(string.IsNullOrEmpty(Model.Feedback) ? "No general feedback provided." : Model.Feedback)
                    </div>
                </div>

                <div style="margin-top: 40px;">
                    <h3 style="font-size: 18px; margin-bottom: 16px;"><i class="fa-solid fa-list-check"></i> Detailed Rubric Scores</h3>
                    
                    @if (Model.CriterionScores != null && Model.CriterionScores.Any())
                    {
                        <table class="rubric-table">
                            <thead>
                                <tr>
                                    <th style="width: 25%">Criterion</th>
                                    <th style="width: 15%; text-align: center;">Max Score (Weight)</th>
                                    <th style="width: 15%; text-align: center;">AI Score</th>
                                    <th style="width: 15%; text-align: center;">Final Score</th>
                                    <th style="width: 30%">Feedback</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var crit in Model.CriterionScores)
                                {
                                    <tr>
                                        <td style="font-weight: 600;">@crit.CriterionName</td>
                                        <td style="text-align: center; color: var(--text-muted);">
                                            @crit.MaxScore.ToString("0.0") <br>
                                            <small>(@crit.WeightPercent.ToString("0.0")%)</small>
                                        </td>
                                        <td style="text-align: center;">
                                            <span class="score-box score-ai">@(crit.AiScore?.ToString("0.0") ?? "-")</span>
                                        </td>
                                        <td style="text-align: center;">
                                            <span class="score-box score-final">@(crit.FinalScore?.ToString("0.0") ?? "-")</span>
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(crit.TeacherFeedback))
                                            {
                                                <div class="feedback-text"><strong>Teacher:</strong> @crit.TeacherFeedback</div>
                                            }
                                            @if (!string.IsNullOrEmpty(crit.AiFeedback))
                                            {
                                                <div class="feedback-text" style="color: #6b7280;"><strong>AI:</strong> @crit.AiFeedback</div>
                                            }
                                            @if (string.IsNullOrEmpty(crit.TeacherFeedback) && string.IsNullOrEmpty(crit.AiFeedback))
                                            {
                                                <span class="feedback-text" style="font-style: italic;">No feedback</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div style="padding: 20px; background: #fffbeb; color: var(--warning); border-radius: var(--radius-md); border: 1px solid #fde68a;">
                            No detailed rubric evaluation available for this submission.
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Right Column: Status & Overall Score -->
        <div class="side-col">
            
            <div class="card">
                <div class="status-title"><i class="fa-solid fa-trophy" style="color: var(--warning);"></i> Final Result</div>
                
                <div class="score-display">
                    @if (Model.FinalScore.HasValue)
                    {
                        <div class="score-circle">
                            @Model.FinalScore.Value.ToString("0.0")
                        </div>
                        <h4 style="color: var(--text-main);">Official Score</h4>
                    }
                    else if (Model.AiScore.HasValue)
                    {
                        <div class="ai-score-circle">
                            @Model.AiScore.Value.ToString("0.0")
                        </div>
                        <h4 style="color: var(--text-main);">AI Suggested Score</h4>
                        <p style="font-size: 12px; color: var(--text-muted); margin-top: 8px;">Pending teacher's final review</p>
                    }
                    else
                    {
                        <div class="score-circle" style="border-color: var(--border); color: var(--text-muted);">
                            -
                        </div>
                        <h4 style="color: var(--text-muted);">Not Graded</h4>
                    }
                </div>

                <div style="margin-top: 24px; border-top: 1px solid var(--border); padding-top: 24px;">
                    <div class="status-row">
                        <span class="status-label">Student</span>
                        <span class="status-value">@Model.StudentName</span>
                    </div>
                    <div class="status-row">
                        <span class="status-label">Status</span>
                        <span class="status-value">
                            <span class="badge-status @(Model.Status == "GRADED" ? "badge-success" : "")">
                                @Model.Status
                            </span>
                        </span>
                    </div>
                    <div class="status-row">
                        <span class="status-label">Submitted On</span>
                        <span class="status-value" style="font-size: 13px;">@Model.SubmittedAt.ToString("MMM dd, yyyy HH:mm")</span>
                    </div>
                </div>

                <a href="javascript:history.back()" class="btn btn-outline"><i class="fa-solid fa-arrow-left"></i> Go Back</a>
            </div>

        </div>

    </div>

</body>
</html>
