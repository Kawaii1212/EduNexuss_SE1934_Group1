@model EduNexus.ViewModels.LessonEditorViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Lesson - EduNexus</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            /* Synchronized with EduNexus */
            --primary: #5c24ff;
            --primary-light: #9b8cf8;
            --primary-lighter: #f0edff;
            --primary-hover: #481ce0;
            --bg-color: #fafafa;
            --surface: #ffffff;
            --text-main: #111827;
            --text-muted: #6b7280;
            --text-light: #9ca3af;
            --border: #e5e7eb;
            --border-hover: #d1d5db;
            --danger: #ef4444;
            --success: #10b981;
            --radius-md: 8px;
            --radius-lg: 12px;
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Topbar */
        .topbar {
            height: 70px;
            background-color: var(--surface);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 40px;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .topbar-left {
            display: flex;
            align-items: center;
            gap: 24px;
        }

        .back-btn {
            color: var(--text-muted);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 500;
            font-size: 14px;
            transition: 0.2s;
        }

        .back-btn:hover {
            color: var(--text-main);
        }

        .breadcrumbs {
            font-size: 14px;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .breadcrumbs span {
            color: var(--text-main);
            font-weight: 600;
        }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .btn {
            padding: 10px 20px;
            border-radius: var(--radius-md);
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            border: none;
            transition: all 0.2s ease;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-outline {
            background-color: transparent;
            border: 1px solid var(--border);
            color: var(--text-main);
        }

        .btn-outline:hover {
            background-color: var(--bg-color);
            border-color: var(--border-hover);
        }

        .btn-primary {
            background-color: var(--primary-light);
            color: white;
            box-shadow: 0 4px 12px rgba(155, 140, 248, 0.3);
        }

        .btn-primary:hover {
            background-color: var(--primary);
            box-shadow: 0 6px 16px rgba(92, 36, 255, 0.4);
            transform: translateY(-1px);
        }

        /* Main Content Layout */
        .editor-container {
            flex: 1;
            display: flex;
            padding: 40px;
            max-width: 1400px;
            margin: 0 auto;
            width: 100%;
            gap: 32px;
        }

        .main-col {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 24px;
        }

        .side-col {
            width: 350px;
            display: flex;
            flex-direction: column;
            gap: 24px;
        }

        /* Inputs & Editor */
        .title-input {
            width: 100%;
            font-size: 32px;
            font-weight: 800;
            color: var(--text-main);
            border: none;
            background: transparent;
            outline: none;
            padding: 10px 0;
            border-bottom: 1px solid transparent;
            transition: 0.2s;
        }

        .title-input::placeholder {
            color: #d1d5db;
        }

        .title-input:focus {
            border-bottom: 1px solid var(--primary-light);
        }

        .editor-box {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            display: flex;
            flex-direction: column;
            min-height: 500px;
            box-shadow: var(--shadow-sm);
        }

        .editor-toolbar {
            padding: 12px 16px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 8px;
            background-color: #fafafa;
            border-radius: var(--radius-lg) var(--radius-lg) 0 0;
            flex-wrap: wrap;
        }

        .toolbar-btn {
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: transparent;
            border: none;
            border-radius: 6px;
            color: var(--text-muted);
            cursor: pointer;
            transition: 0.2s;
        }

        .toolbar-btn:hover {
            background-color: #e5e7eb;
            color: var(--text-main);
        }

        .toolbar-btn.active {
            background-color: var(--primary-lighter);
            color: var(--primary);
        }

        .toolbar-divider {
            width: 1px;
            height: 24px;
            background-color: var(--border);
            margin: 0 8px;
        }

        .editor-content {
            padding: 24px;
            flex: 1;
            outline: none;
            font-size: 16px;
            line-height: 1.6;
            color: var(--text-main);
            overflow-y: auto;
            word-wrap: break-word;
            overflow-wrap: break-word;
        }

        .editor-content pre {
            background-color: #f6f8fa;
            border-radius: 6px;
            padding: 16px;
            overflow-x: auto;
            white-space: pre-wrap;
            word-wrap: break-word;
            margin-bottom: 16px;
        }
        
        .editor-content code {
            background-color: #f6f8fa;
            padding: 0.2em 0.4em;
            border-radius: 3px;
            font-family: monospace;
            font-size: 14px;
        }

        .editor-content pre code {
            padding: 0;
            background-color: transparent;
        }

        .editor-content[placeholder]:empty:before {
            content: attr(placeholder);
            color: #9ca3af;
            cursor: text;
        }

        /* Sidebar Cards */
        .settings-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 24px;
            box-shadow: var(--shadow-sm);
        }

        .card-title {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group:last-child {
            margin-bottom: 0;
        }

        .form-label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: var(--text-muted);
            margin-bottom: 8px;
        }

        .form-control, .form-select {
            width: 100%;
            padding: 12px;
            background-color: var(--bg-color);
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            font-size: 14px;
            color: var(--text-main);
            outline: none;
            transition: 0.2s;
        }

        .form-control:focus, .form-select:focus {
            border-color: var(--primary-light);
            background-color: var(--surface);
            box-shadow: 0 0 0 3px var(--primary-lighter);
        }

        /* File Upload Area */
        .upload-area {
            border: 2px dashed var(--border);
            border-radius: var(--radius-md);
            padding: 32px 20px;
            text-align: center;
            background-color: #fafafa;
            cursor: pointer;
            transition: 0.2s;
        }

        .upload-area:hover {
            border-color: var(--primary-light);
            background-color: var(--primary-lighter);
        }

        .upload-icon {
            font-size: 32px;
            color: var(--primary-light);
            margin-bottom: 12px;
        }

        .upload-text {
            font-size: 14px;
            font-weight: 500;
            color: var(--text-main);
            margin-bottom: 4px;
        }

        .upload-subtext {
            font-size: 12px;
            color: var(--text-muted);
        }

        .attached-file {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px;
            background-color: var(--bg-color);
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            margin-top: 16px;
        }

        .file-info {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .file-icon {
            width: 32px;
            height: 32px;
            background-color: #fef2f2;
            color: #ef4444; /* PDF color */
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
        }

        .file-name {
            font-size: 13px;
            font-weight: 500;
            color: var(--text-main);
        }

        .file-size {
            font-size: 11px;
            color: var(--text-muted);
        }

        .btn-remove {
            color: var(--text-muted);
            background: none;
            border: none;
            cursor: pointer;
            padding: 4px;
        }
        
        .btn-remove:hover {
            color: var(--danger);
        }

    </style>
</head>
<body>

    <!-- Top Navigation -->
    <header class="topbar">
        <div class="topbar-left">
            <a href="/Course/Structure?courseId=@Model.CourseId" class="back-btn">
                <i class="fa-solid fa-arrow-left"></i> Back
            </a>
            <div class="breadcrumbs">
                Course Structure <i class="fa-solid fa-chevron-right" style="font-size: 10px;"></i> Module @Model.ModuleId <i class="fa-solid fa-chevron-right" style="font-size: 10px;"></i> <span>Edit Lesson</span>
            </div>
        </div>
        <div class="topbar-right">
            @if (TempData["SuccessMessage"] != null)
            {
                <span style="color: var(--success); font-size: 13px; margin-right: 12px;"><i class="fa-solid fa-check"></i> @TempData["SuccessMessage"]</span>
            }
            <a href="/Lesson/AILessonStaging?id=@Model.LessonId" class="btn" style="background: #f0edff; color: #5c24ff; text-decoration: none; display: flex; align-items: center; gap: 8px;">
                <i class="fa-solid fa-wand-magic-sparkles"></i> AI Staging
            </a>
            <a href="/Lesson/LessonView?id=@Model.LessonId&isPreview=true" target="_blank" class="btn btn-outline" style="text-decoration:none;">Preview</a>
            <button type="submit" form="lessonForm" class="btn btn-primary"><i class="fa-solid fa-paper-plane"></i> Publish</button>
        </div>
    </header>

    <!-- Main Editor Area -->
    <form id="lessonForm" asp-action="LessonEditor" asp-controller="Lesson" method="POST" enctype="multipart/form-data" class="editor-container">
        <input type="hidden" asp-for="LessonId" />
        <input type="hidden" asp-for="ModuleId" />
        <input type="hidden" id="hiddenContent" asp-for="Content" />
        
        <!-- Left: Editor Column -->
        <div class="main-col">
            <input type="text" asp-for="Title" class="title-input" placeholder="Lesson Title...">
            <span asp-validation-for="Title" style="color: red; font-size: 12px;"></span>
            
            <div class="editor-box">
                <!-- Rich Text Toolbar Mockup -->
                <div class="editor-toolbar">
                    <select class="form-select" onchange="execCmd('formatBlock', this.value)" style="width: auto; padding: 6px 12px; font-size: 13px; border-color: transparent; background-color: transparent;">
                        <option value="P">Normal text</option>
                        <option value="H1">Heading 1</option>
                        <option value="H2">Heading 2</option>
                        <option value="H3">Heading 3</option>
                    </select>
                    <div class="toolbar-divider"></div>
                    <button type="button" class="toolbar-btn" title="Bold" onclick="execCmd('bold')"><i class="fa-solid fa-bold"></i></button>
                    <button type="button" class="toolbar-btn" title="Italic" onclick="execCmd('italic')"><i class="fa-solid fa-italic"></i></button>
                    <button type="button" class="toolbar-btn" title="Underline" onclick="execCmd('underline')"><i class="fa-solid fa-underline"></i></button>
                    <div class="toolbar-divider"></div>
                    <button type="button" class="toolbar-btn" title="Align Left" onclick="execCmd('justifyLeft')"><i class="fa-solid fa-align-left"></i></button>
                    <button type="button" class="toolbar-btn" title="Align Center" onclick="execCmd('justifyCenter')"><i class="fa-solid fa-align-center"></i></button>
                    <button type="button" class="toolbar-btn" title="Align Right" onclick="execCmd('justifyRight')"><i class="fa-solid fa-align-right"></i></button>
                    <div class="toolbar-divider"></div>
                    <button type="button" class="toolbar-btn" title="Bullet List" onclick="execCmd('insertUnorderedList')"><i class="fa-solid fa-list-ul"></i></button>
                    <button type="button" class="toolbar-btn" title="Numbered List" onclick="execCmd('insertOrderedList')"><i class="fa-solid fa-list-ol"></i></button>
                    <div class="toolbar-divider"></div>
                    <button type="button" class="toolbar-btn" title="Insert Link" onclick="insertLink()"><i class="fa-solid fa-link"></i></button>
                </div>

                <!-- Editable Content Area -->
                <div class="editor-content" id="editorContent" contenteditable="true" placeholder="Start typing your lesson content here...">
                    @Html.Raw(Model?.Content ?? "")
                </div>
            </div>
        </div>

        <!-- Right: Settings & Attachments Column -->
        <div class="side-col">
            
            <!-- Lesson Settings -->
            <div class="settings-card">
                <div class="card-title"><i class="fa-solid fa-sliders"></i> Lesson Settings</div>

                <div class="form-group">
                    <label class="form-label">Video URL (Optional)</label>
                    <input type="url" asp-for="VideoUrl" class="form-control" placeholder="https://youtube.com/...">
                </div>
            </div>

            <!-- Study Materials / Attachments -->
            <div class="settings-card">
                <div class="card-title"><i class="fa-solid fa-paperclip"></i> Study Materials</div>
                <p style="font-size: 13px; color: var(--text-muted); margin-bottom: 16px;">Attach PDFs, slides, or zip files for students to download.</p>
                
                <label for="fileUpload" class="upload-area" style="cursor: pointer; display: block; text-align: center;">
                    <div class="upload-icon"><i class="fa-solid fa-cloud-arrow-up"></i></div>
                    <div class="upload-text">Click to upload files</div>
                    <div class="upload-subtext">PDF, DOCX, ZIP (max. 10MB)</div>
                    <input type="file" id="fileUpload" name="Attachments" multiple style="display: none;" onchange="updateFileList()" />
                </label>

                <!-- Uploaded File List -->
                <div id="fileListContainer"></div>
            </div>

        </div>

    </form>

    <script>
        // Sync content editable innerHTML to hidden input on form submit
        document.getElementById('lessonForm').addEventListener('submit', function() {
            var contentHtml = document.getElementById('editorContent').innerHTML;
            document.getElementById('hiddenContent').value = contentHtml;
        });

        // Editor commands
        function execCmd(command, value = null) {
            document.execCommand(command, false, value);
            document.getElementById('editorContent').focus();
        }

        function insertLink() {
            let url = prompt("Nhập đường dẫn (URL):");
            if (url) {
                document.execCommand("createLink", false, url);
            }
        }

        // Update file list on upload
        function updateFileList() {
            var input = document.getElementById('fileUpload');
            var container = document.getElementById('fileListContainer');
            container.innerHTML = '';
            
            for (var i = 0; i < input.files.length; i++) {
                var file = input.files[i];
                var fileSize = (file.size / (1024 * 1024)).toFixed(2) + ' MB';
                var html = `
                <div class="attached-file" style="margin-top: 12px; display: flex; align-items: center; justify-content: space-between; padding: 12px; border: 1px solid var(--border); border-radius: var(--radius-md); background-color: #f9fafb;">
                    <div class="file-info" style="display: flex; align-items: center; gap: 12px;">
                        <div class="file-icon" style="color: var(--primary); font-size: 20px;"><i class="fa-solid fa-file"></i></div>
                        <div>
                            <div class="file-name" style="font-weight: 600; font-size: 13px;">${file.name}</div>
                            <div class="file-size" style="font-size: 12px; color: var(--text-muted);">${fileSize}</div>
                        </div>
                    </div>
                </div>`;
                container.innerHTML += html;
            }
        }
    </script>
</body>
</html>
