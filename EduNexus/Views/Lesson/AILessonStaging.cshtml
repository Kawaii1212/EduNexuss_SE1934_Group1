@{
    Layout = null;
    long lessonId = ViewBag.LessonId ?? 0;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Lesson Staging - EduNexus</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Marked.js for markdown parsing -->
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <style>
        :root {
            --primary: #5c24ff;
            --primary-light: #9b8cf8;
            --primary-lighter: #f0edff;
            --bg-color: #fafafa;
            --surface: #ffffff;
            --text-main: #111827;
            --text-muted: #6b7280;
            --border: #e5e7eb;
            --ai-gradient: linear-gradient(135deg, #5c24ff 0%, #d946ef 100%);
            --radius-md: 8px;
            --radius-lg: 12px;
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            height: 100vh;
            margin: 0;
            display: flex;
            flex-direction: column;
            overflow: hidden; /* We handle scrolling inside panes */
        }

        /* Topbar */
        .topbar {
            height: 70px;
            background-color: var(--surface);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 24px;
            z-index: 100;
        }

        .back-btn {
            color: var(--text-muted);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 500;
            font-size: 14px;
            transition: 0.2s;
        }
        .back-btn:hover { color: var(--text-main); }

        .ai-status-badge {
            background: var(--primary-lighter);
            color: var(--primary);
            padding: 6px 12px;
            border-radius: 100px;
            font-size: 13px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .btn {
            padding: 8px 16px;
            border-radius: var(--radius-md);
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            border: none;
            transition: 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        .btn-primary { background: var(--ai-gradient); color: white; }
        .btn-primary:hover { opacity: 0.9; }

        /* Layout */
        .staging-layout {
            display: flex;
            flex: 1;
            height: calc(100vh - 70px);
            overflow: hidden;
        }

        /* Left Pane - Input Workspace */
        .pane-left {
            width: 40%;
            border-right: 1px solid var(--border);
            background: var(--surface);
            display: flex;
            flex-direction: column;
            overflow-y: auto;
        }

        .tabs {
            display: flex;
            border-bottom: 1px solid var(--border);
        }

        .tab {
            flex: 1;
            padding: 16px 0;
            text-align: center;
            font-weight: 600;
            font-size: 14px;
            color: var(--text-muted);
            cursor: pointer;
            border-bottom: 2px solid transparent;
            transition: 0.2s;
        }

        .tab.active {
            color: var(--primary);
            border-bottom-color: var(--primary);
        }

        .tab-content {
            padding: 24px;
            flex: 1;
            display: none;
            flex-direction: column;
        }

        .tab-content.active { display: flex; }

        .form-label {
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 8px;
            display: block;
        }

        .form-control {
            width: 100%;
            padding: 12px;
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            font-size: 14px;
            outline: none;
            transition: border-color 0.2s;
            resize: vertical;
        }

        .form-control:focus { border-color: var(--primary); }

        .generate-btn {
            width: 100%;
            padding: 12px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            font-weight: 600;
            color: var(--text-main);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-top: 16px;
            transition: 0.2s;
        }
        .generate-btn:hover { border-color: var(--primary); color: var(--primary); }

        /* Right Pane - Preview */
        .pane-right {
            width: 60%;
            background: var(--bg-color);
            display: block;
            padding: 32px;
            overflow-y: auto;
        }

        .preview-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
        }
        
        .preview-header h2 { font-size: 18px; font-weight: 600; }

        .preview-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 32px;
            box-shadow: var(--shadow-sm);
            min-height: 500px;
            height: auto;
            overflow: visible;
        }

        /* Generated Markdown Styles */
        .markdown-body {
            font-size: 15px;
            line-height: 1.6;
            color: var(--text-main);
            word-wrap: break-word;
            overflow-wrap: break-word;
        }
        .markdown-body h1, .markdown-body h2, .markdown-body h3 {
            margin-top: 24px;
            margin-bottom: 16px;
            font-weight: 600;
        }
        .markdown-body p { margin-bottom: 16px; }
        .markdown-body ul, .markdown-body ol { margin-bottom: 16px; padding-left: 24px; }
        .markdown-body li { margin-bottom: 8px; }
        .markdown-body pre {
            background-color: #f6f8fa;
            border-radius: 6px;
            padding: 16px;
            overflow-x: auto;
            white-space: pre-wrap; /* Forces text to wrap inside code blocks */
            word-wrap: break-word;
            margin-bottom: 16px;
        }
        .markdown-body code {
            background-color: #f6f8fa;
            padding: 0.2em 0.4em;
            border-radius: 3px;
            font-family: monospace;
            font-size: 14px;
        }
        .markdown-body pre code {
            padding: 0;
            background-color: transparent;
        }

        /* Skeleton Loading */
        .skeleton {
            background: #eee;
            background: linear-gradient(110deg, #ececec 8%, #f5f5f5 18%, #ececec 33%);
            border-radius: 4px;
            background-size: 200% 100%;
            animation: 1.5s shine linear infinite;
        }
        
        .skeleton-title { width: 50%; height: 28px; margin-bottom: 24px; }
        .skeleton-text { width: 100%; height: 16px; margin-bottom: 12px; }
        .skeleton-text-short { width: 80%; height: 16px; margin-bottom: 24px; }

        @@keyframes shine {
            to { background-position-x: -200%; }
        }

        .loading-view { display: none; }
        .loading-view.active { display: block; }
        .empty-view { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; color: var(--text-muted); text-align: center;}
        .empty-view i { font-size: 48px; margin-bottom: 16px; color: #e5e7eb; }
        .content-view { display: none; }
    </style>
</head>
<body>

    <!-- Topbar -->
    <header class="topbar">
        <a href="/Lesson/LessonEditor?id=@lessonId" class="back-btn">
            <i class="fa-solid fa-arrow-left"></i> Back to Lesson Editor
        </a>
        <div class="ai-status-badge">
            <i class="fa-solid fa-wand-magic-sparkles"></i> AI Gemini Staging
        </div>
        <div>
            <button class="btn btn-primary" id="btnImport" onclick="importToLesson()" style="display: none;">
                <i class="fa-solid fa-download"></i> Save & Import to Lesson
            </button>
        </div>
    </header>

    <!-- Layout -->
    <div class="staging-layout">
        
        <!-- Left Pane: Tools -->
        <aside class="pane-left">
            <div class="tabs">
                <div class="tab active" onclick="switchTab('text')">Text Generator</div>
                <div class="tab" onclick="switchTab('video')">Video Summarizer</div>
            </div>

            <!-- Tab 1: Text Generator -->
            <div class="tab-content active" id="tab-text">
                <label class="form-label">Lesson Outline (Markdown / Bullet points)</label>
                <textarea id="txtOutline" class="form-control" rows="12" placeholder="e.g.&#10;- Introduction to Object Oriented Programming&#10;- 4 Pillars: Abstraction, Encapsulation, Inheritance, Polymorphism&#10;- Real world examples in C#"></textarea>
                
                <button class="generate-btn" onclick="generateText()">
                    <i class="fa-solid fa-wand-magic-sparkles" style="color: var(--primary);"></i> Generate Full Lesson
                </button>
            </div>

            <!-- Tab 2: Video Summarizer -->
            <div class="tab-content" id="tab-video">
                <label class="form-label">YouTube Video URL</label>
                <input type="url" id="txtVideoUrl" class="form-control" placeholder="https://youtube.com/watch?v=...">
                
                <div style="margin-top: 24px;">
                    <button class="generate-btn" onclick="summarizeVideo()">
                        <i class="fa-solid fa-wand-magic-sparkles" style="color: var(--primary);"></i> Analyze & Summarize Video
                    </button>
                </div>
                
                <div id="videoPreviewContainer" style="margin-top: 24px; display: none;">
                    <label class="form-label">Video Preview</label>
                    <div style="aspect-ratio: 16/9; background: #000; border-radius: var(--radius-md); overflow: hidden;">
                        <iframe id="videoIframe" src="" style="width: 100%; height: 100%; border: none;" allowfullscreen></iframe>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Right Pane: Preview -->
        <main class="pane-right">
            <div class="preview-header">
                <h2>Generated Result Preview</h2>
            </div>
            
            <div class="preview-card">
                
                <!-- Empty State -->
                <div id="emptyView" class="empty-view">
                    <i class="fa-solid fa-wand-magic-sparkles"></i>
                    <p>Enter your outline or video URL on the left and<br>click Generate to see AI results here.</p>
                </div>

                <!-- Loading State -->
                <div id="loadingView" class="loading-view">
                    <div class="skeleton skeleton-title"></div>
                    <div class="skeleton skeleton-text"></div>
                    <div class="skeleton skeleton-text"></div>
                    <div class="skeleton skeleton-text-short"></div>
                    
                    <div class="skeleton skeleton-title" style="margin-top: 32px;"></div>
                    <div class="skeleton skeleton-text"></div>
                    <div class="skeleton skeleton-text"></div>
                    <div class="skeleton skeleton-text-short"></div>
                </div>

                <!-- Content State -->
                <div id="contentView" class="content-view markdown-body" contenteditable="true" style="outline: none;">
                    <!-- Markdown will be rendered here -->
                </div>

            </div>
        </main>

    </div>

    <!-- Scripts -->
    <script>
        const lessonId = @lessonId;
        let currentGeneratedMarkdown = "";
        let currentVideoUrl = "";

        function switchTab(tab) {
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
            
            if (tab === 'text') {
                document.querySelectorAll('.tab')[0].classList.add('active');
                document.getElementById('tab-text').classList.add('active');
            } else {
                document.querySelectorAll('.tab')[1].classList.add('active');
                document.getElementById('tab-video').classList.add('active');
            }
        }

        function showLoading() {
            document.getElementById('emptyView').style.display = 'none';
            document.getElementById('contentView').style.display = 'none';
            document.getElementById('loadingView').classList.add('active');
            document.getElementById('btnImport').style.display = 'none';
        }

        function showResult(markdownHtml) {
            document.getElementById('loadingView').classList.remove('active');
            const contentView = document.getElementById('contentView');
            contentView.innerHTML = markdownHtml;
            contentView.style.display = 'block';
            document.getElementById('btnImport').style.display = 'inline-flex';
        }

        function cleanMarkdown(md) {
            if (!md) return "";
            md = md.trim();
            if (md.startsWith("```markdown")) {
                md = md.substring(11);
                if (md.endsWith("```")) md = md.substring(0, md.length - 3);
            } else if (md.startsWith("```html")) {
                md = md.substring(7);
                if (md.endsWith("```")) md = md.substring(0, md.length - 3);
            }
            return md.trim();
        }

        function showError(msg) {
            document.getElementById('loadingView').classList.remove('active');
            document.getElementById('emptyView').style.display = 'flex';
            document.getElementById('emptyView').innerHTML = `<i class="fa-solid fa-circle-exclamation" style="color: red;"></i><p style="color: red;">${msg}</p>`;
        }

        async function generateText() {
            const outline = document.getElementById('txtOutline').value;
            if (!outline.trim()) return alert("Please enter an outline first.");
            
            showLoading();
            currentVideoUrl = ""; // clear video url

            try {
                const res = await fetch('/Lesson/GenerateLessonText', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ Outline: outline })
                });
                const data = await res.json();
                
                if (data.success) {
                    currentGeneratedMarkdown = cleanMarkdown(data.content);
                    showResult(marked.parse(currentGeneratedMarkdown));
                } else {
                    showError(data.message);
                }
            } catch (err) {
                showError("An error occurred while calling AI.");
            }
        }

        function getYouTubeEmbedUrl(url) {
            if (!url) return "";
            var match = url.match(/(?:youtube\.com\/(?:[^\/]+\/.+\/|(?:v|e(?:mbed)?)\/|.*[?&]v=)|youtu\.be\/)([^"&?\/\s]{11})/);
            return match ? `https://www.youtube.com/embed/${match[1]}` : url;
        }

        async function summarizeVideo() {
            const url = document.getElementById('txtVideoUrl').value;
            if (!url.trim()) return alert("Please enter a YouTube URL.");
            
            // Show video preview
            const embedUrl = getYouTubeEmbedUrl(url);
            document.getElementById('videoPreviewContainer').style.display = 'block';
            document.getElementById('videoIframe').src = embedUrl;
            currentVideoUrl = url;
            
            showLoading();

            try {
                const res = await fetch('/Lesson/SummarizeVideo', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ VideoUrl: url })
                });
                const data = await res.json();
                
                if (data.success) {
                    currentGeneratedMarkdown = cleanMarkdown(data.content);
                    showResult(marked.parse(currentGeneratedMarkdown));
                } else {
                    showError(data.message);
                }
            } catch (err) {
                showError("An error occurred while calling AI.");
            }
        }

        async function importToLesson() {
            // Get the edited HTML directly from the content view
            const finalHtml = document.getElementById('contentView').innerHTML;
            
            const btn = document.getElementById('btnImport');
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Saving...';
            btn.disabled = true;

            try {
                const res = await fetch('/Lesson/SaveStaging', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        LessonId: lessonId, 
                        Content: finalHtml,
                        VideoUrl: currentVideoUrl
                    })
                });
                const data = await res.json();
                
                if (data.success) {
                    window.location.href = `/Lesson/LessonEditor?id=${lessonId}`;
                } else {
                    alert("Error saving staging.");
                    btn.innerHTML = '<i class="fa-solid fa-download"></i> Save & Import to Lesson';
                    btn.disabled = false;
                }
            } catch (err) {
                alert("Error saving staging.");
                btn.disabled = false;
            }
        }
    </script>
</body>
</html>
