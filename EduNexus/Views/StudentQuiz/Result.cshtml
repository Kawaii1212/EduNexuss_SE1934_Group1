@model EduNexus.ViewModels.QuizResultViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quiz Result - EduNexus</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary: #5c24ff;
            --primary-light: #9b8cf8;
            --primary-lighter: #f0edff;
            --primary-hover: #481ce0;
            --bg-color: #fafafa;
            --surface: #ffffff;
            --text-main: #111827;
            --text-muted: #6b7280;
            --border: #e5e7eb;
            --border-hover: #d1d5db;
            --danger: #ef4444;
            --success: #10b981;
            --warning: #f59e0b;
            --radius-md: 8px;
            --radius-lg: 12px;
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Topbar */
        .topbar {
            height: 70px;
            background-color: var(--surface);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 40px;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: var(--shadow-sm);
        }

        .back-btn {
            color: var(--text-muted);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 500;
            font-size: 14px;
            transition: 0.2s;
        }

        .back-btn:hover {
            color: var(--text-main);
        }

        .breadcrumbs {
            font-size: 14px;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .breadcrumbs span {
            color: var(--text-main);
            font-weight: 600;
        }

        /* Layout */
        .result-container {
            flex: 1;
            display: flex;
            padding: 40px;
            max-width: 1400px;
            margin: 0 auto;
            width: 100%;
            gap: 32px;
        }

        .main-col {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 24px;
        }

        .side-col {
            width: 350px;
            display: flex;
            flex-direction: column;
            gap: 24px;
        }

        /* Cards */
        .card {
            background: var(--surface);
            border-radius: var(--radius-lg);
            border: 1px solid var(--border);
            padding: 32px;
            box-shadow: var(--shadow-sm);
        }

        .card-header-styled {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 24px;
            padding-bottom: 24px;
            border-bottom: 1px solid var(--border);
        }

        .card-title {
            font-size: 24px;
            font-weight: 700;
            color: var(--text-main);
            margin-bottom: 8px;
        }

        .card-subtitle {
            color: var(--primary);
            font-size: 14px;
            font-weight: 600;
        }

        .status-title {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .status-row {
            display: flex;
            justify-content: space-between;
            padding: 12px 0;
            border-bottom: 1px solid var(--border);
            font-size: 14px;
        }

        .status-row:last-child {
            border-bottom: none;
        }

        .status-label {
            color: var(--text-muted);
            font-weight: 500;
        }

        .status-value {
            font-weight: 600;
            color: var(--text-main);
        }

        .badge-status {
            padding: 4px 10px;
            border-radius: 100px;
            font-size: 12px;
            font-weight: 600;
            background: #f3f4f6;
            color: var(--text-muted);
        }

        .badge-success { background: #ecfdf5; color: var(--success); }

        .score-display {
            text-align: center;
            padding: 24px 0;
        }

        .score-circle {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            border: 8px solid var(--success);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 16px auto;
            font-size: 32px;
            font-weight: 800;
            color: var(--success);
        }

        .btn {
            padding: 12px 20px;
            border-radius: var(--radius-md);
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            border: none;
            transition: all 0.2s ease;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            width: 100%;
            margin-top: 24px;
            text-decoration: none;
        }

        .btn-outline {
            background-color: transparent;
            border: 1px solid var(--border);
            color: var(--text-main);
        }

        .btn-outline:hover {
            background-color: var(--bg-color);
        }

        .btn-primary {
            background-color: var(--primary);
            color: white;
        }

        .btn-primary:hover {
            background-color: var(--primary-hover);
        }

        .general-feedback {
            padding: 20px;
            background: var(--bg-color);
            border-left: 4px solid var(--warning);
            border-radius: 0 var(--radius-md) var(--radius-md) 0;
            font-size: 15px;
            line-height: 1.6;
        }
        
        .spinner {
            border: 4px solid rgba(0, 0, 0, 0.1);
            width: 36px;
            height: 36px;
            border-radius: 50%;
            border-left-color: var(--warning);
            animation: spin 1s linear infinite;
            margin: 0 auto 10px auto;
        }

        @@keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
    </style>
</head>
<body>

    <!-- Top Navigation -->
    <header class="topbar">
        <div class="topbar-left">
            <a href="/Course/MyCourses" class="back-btn">
                <i class="fa-solid fa-arrow-left"></i> Back to Courses
            </a>
            <div class="breadcrumbs">
                Quiz <i class="fa-solid fa-chevron-right" style="font-size: 10px;"></i> <span>Evaluation Result</span>
            </div>
        </div>
    </header>

    <div class="result-container">
        
        <!-- Left Column: Assignment Details & Rubric -->
        <div class="main-col">
            <div class="card">
                <div class="card-header-styled">
                    <div>
                        <div class="card-subtitle">Quiz Result</div>
                        <h1 class="card-title">@Model.QuizName</h1>
                    </div>
                </div>

                <div class="mb-4">
                    <h3 style="font-size: 18px; margin-bottom: 16px; color: var(--warning);"><i class="fa-solid fa-robot"></i> AI Performance Analysis</h3>
                    <div class="general-feedback">
                        <div id="aiLoading" class="text-center" style="text-align: center; padding: 20px;">
                            <div class="spinner"></div>
                            <p style="color: var(--text-muted);">Analyzing your strengths and weaknesses...</p>
                        </div>
                        <div id="aiResult" style="display: none;"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column: Status & Overall Score -->
        <div class="side-col">
            
            <div class="card">
                <div class="status-title"><i class="fa-solid fa-trophy" style="color: var(--warning);"></i> Final Result</div>
                
                <div class="score-display">
                    <div class="score-circle">
                        @Model.Score.ToString("0") / @Model.TotalQuestions
                    </div>
                    <h4 style="color: var(--text-main);">Official Score</h4>
                </div>

                <div style="margin-top: 24px; border-top: 1px solid var(--border); padding-top: 24px;">
                    <div class="status-row">
                        <span class="status-label">Status</span>
                        <span class="status-value">
                            <span class="badge-status badge-success">COMPLETED</span>
                        </span>
                    </div>
                    <div class="status-row">
                        <span class="status-label">Submitted On</span>
                        <span class="status-value" style="font-size: 13px;">@(Model.SubmittedAt?.ToString("MMM dd, yyyy HH:mm") ?? "-")</span>
                    </div>
                </div>

                <a href="/StudentQuiz/Review?attemptId=@Model.AttemptId" class="btn btn-primary"><i class="fa-solid fa-search"></i> Review Answers</a>
                <a href="javascript:history.back()" class="btn btn-outline"><i class="fa-solid fa-arrow-left"></i> Go Back</a>
            </div>

        </div>

    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script>
        $(document).ready(function () {
            // Tự động gọi API phân tích AI khi load trang
            $.ajax({
                url: '/StudentQuiz/AnalyzeResult',
                type: 'POST',
                data: { attemptId: @Model.AttemptId },
                success: function (res) {
                    $('#aiLoading').hide();
                    $('#aiResult').show();
                    if (res.success) {
                        $('#aiResult').html(marked.parse(res.analysis));
                    } else {
                        $('#aiResult').html('<p style="color: var(--danger);">Unable to load AI analysis.</p>');
                    }
                },
                error: function () {
                    $('#aiLoading').hide();
                    $('#aiResult').show();
                    $('#aiResult').html('<p style="color: var(--danger);">Connection error while loading AI analysis.</p>');
                }
            });
        });
    </script>
</body>
</html>
