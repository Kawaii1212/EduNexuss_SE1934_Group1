@model List<EduNexus.Models.Question>
@{
    Layout = "~/Views/Shared/_SmeLayout.cshtml";
    ViewData["Title"] = $"Câu hỏi chương {ViewBag.ModuleOrderNo} - EduNexus";
    ViewData["ActiveMenu"] = "MyCourses";
    ViewData["ActiveSubMenu"] = "Question";
}

<style>
    .view-questions-page {
        --v-primary: #5c24ff;
        --v-primary-light: #9b8cf8;
        --v-primary-lighter: #f0edff;
        --v-bg: #fafafa;
        --v-surface: #fff;
        --v-text: #111827;
        --v-muted: #6b7280;
        --v-border: #e5e7eb;
        --v-success: #10b981;
        --v-warning: #f59e0b;
        --v-radius: 12px;
        --v-shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        --v-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    .view-questions-page .page-header {
        background: var(--v-surface);
        border: 1px solid var(--v-border);
        border-radius: var(--v-radius);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 24px;
        margin-bottom: 24px;
        box-shadow: var(--v-shadow-sm);
    }

    .view-questions-page .header-left {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .view-questions-page .back-btn {
        color: var(--v-muted);
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
        padding: 8px 14px;
        border: 1px solid var(--v-border);
        border-radius: 8px;
        background: var(--v-surface);
    }

    .view-questions-page .back-btn:hover {
        color: var(--v-text);
        background: #f8fafc;
        border-color: var(--v-muted);
    }

    .view-questions-page .page-badge {
        background: var(--v-primary-lighter);
        color: var(--v-primary);
        padding: 8px 16px;
        border-radius: 100px;
        font-size: 13px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .view-questions-page .questions-container {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .view-questions-page .question-card {
        background: var(--v-surface);
        border: 1px solid var(--v-border);
        border-radius: var(--v-radius);
        padding: 24px;
        box-shadow: var(--v-shadow-sm);
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .view-questions-page .question-card:hover {
        transform: translateY(-2px);
        box-shadow: var(--v-shadow);
    }

    .view-questions-page .q-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
        border-bottom: 1px dashed var(--v-border);
        padding-bottom: 10px;
    }

    .view-questions-page .q-number {
        font-weight: 700;
        color: var(--v-primary);
        font-size: 14px;
    }

    .view-questions-page .q-diff {
        display: inline-flex;
        padding: 2px 8px;
        border-radius: 4px;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
    }

    .view-questions-page .diff-EASY { background: #d1fae5; color: #065f46; }
    .view-questions-page .diff-MEDIUM { background: #fef3c7; color: #d97706; }
    .view-questions-page .diff-HARD { background: #fee2e2; color: #991b1b; }

    .view-questions-page .q-content {
        font-size: 15px;
        font-weight: 600;
        color: var(--v-text);
        margin-bottom: 16px;
        line-height: 1.6;
    }

    .view-questions-page .options-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-bottom: 16px;
    }

    .view-questions-page .option-item {
        padding: 12px 16px;
        background: #f8fafc;
        border: 1px solid var(--v-border);
        border-radius: 8px;
        font-size: 13.5px;
        display: flex;
        align-items: center;
        gap: 10px;
        color: #475569;
        transition: background-color 0.15s;
    }

    .view-questions-page .option-item.correct {
        background: #ecfdf5;
        border-color: #a7f3d0;
        color: #065f46;
        font-weight: 600;
    }

    .view-questions-page .option-item.correct i {
        color: var(--v-success);
    }

    .view-questions-page .explanation-section {
        background: #fafafa;
        border-left: 4px solid var(--v-primary);
        border-radius: 0 8px 8px 0;
        padding: 14px 18px;
        font-size: 13px;
        color: #4b5563;
        line-height: 1.6;
    }

    .view-questions-page .explanation-title {
        font-weight: 700;
        color: var(--v-primary);
        margin-bottom: 6px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .view-questions-page .empty-state {
        text-align: center;
        padding: 64px 20px;
        background: var(--v-surface);
        border: 1px solid var(--v-border);
        border-radius: var(--v-radius);
        color: var(--v-muted);
    }

    .view-questions-page .empty-state i {
        font-size: 48px;
        color: var(--v-primary-light);
        margin-bottom: 16px;
        display: block;
    }

    .view-questions-page .empty-state p {
        font-size: 15px;
        font-weight: 600;
        color: var(--v-text);
        margin-bottom: 4px;
    }
</style>

<div class="view-questions-page">
    <div class="page-header">
        <div class="header-left">
            @if (ViewBag.ActiveCourseId != null)
            {
                <a href="/Course/Structure?courseId=@ViewBag.ActiveCourseId" class="back-btn">
                    <i class="fa-solid fa-arrow-left"></i> Quay lại cấu trúc khóa học
                </a>
            }
            else
            {
                <a href="/Course/MyCourses" class="back-btn">
                    <i class="fa-solid fa-arrow-left"></i> Danh sách khóa học
                </a>
            }
            <div class="page-badge">
                <i class="fa-solid fa-eye"></i> Xem câu hỏi Module
            </div>
        </div>
        <div style="font-weight: 700; font-size: 14px; color: var(--v-muted);">
            @ViewBag.ActiveCourseTitle
        </div>
    </div>

    <div style="margin-bottom: 24px;">
        <h2 style="font-size: 18px; font-weight: 800; color: var(--v-text); display: flex; align-items: center; gap: 8px;">
            <i class="fa-solid fa-book" style="color: var(--v-primary);"></i>
            Chương @ViewBag.ModuleOrderNo: @ViewBag.ModuleName
        </h2>
        <p style="font-size: 13.5px; color: var(--v-muted); margin-top: 4px;">Danh sách câu hỏi trắc nghiệm đã phê duyệt thuộc module này.</p>
    </div>

    @if (Model == null || Model.Count == 0)
    {
        <div class="empty-state">
            <i class="fa-regular fa-folder-open"></i>
            <p>Chưa có câu hỏi nào được duyệt cho Module này.</p>
            <span style="font-size: 13px;">Hãy liên hệ SME hoặc quản trị viên để cập nhật ngân hàng câu hỏi.</span>
        </div>
    }
    else
    {
        <div class="questions-container">
            @{
                int idx = 0;
            }
            @foreach (var q in Model)
            {
                idx++;
                <div class="question-card">
                    <div class="q-header">
                        <span class="q-number">Câu hỏi @idx</span>
                        <span class="q-diff diff-@q.Difficulty">@q.Difficulty</span>
                    </div>

                    <div class="q-content">@q.Content</div>

                    <div class="options-grid">
                        <div class="option-item @(q.CorrectOption == "A" ? "correct" : "")">
                            <i class="fa-regular @(q.CorrectOption == "A" ? "fa-circle-check" : "fa-circle")"></i>
                            <strong>A.</strong> @q.OptionA
                        </div>
                        <div class="option-item @(q.CorrectOption == "B" ? "correct" : "")">
                            <i class="fa-regular @(q.CorrectOption == "B" ? "fa-circle-check" : "fa-circle")"></i>
                            <strong>B.</strong> @q.OptionB
                        </div>
                        <div class="option-item @(q.CorrectOption == "C" ? "correct" : "")">
                            <i class="fa-regular @(q.CorrectOption == "C" ? "fa-circle-check" : "fa-circle")"></i>
                            <strong>C.</strong> @q.OptionC
                        </div>
                        <div class="option-item @(q.CorrectOption == "D" ? "correct" : "")">
                            <i class="fa-regular @(q.CorrectOption == "D" ? "fa-circle-check" : "fa-circle")"></i>
                            <strong>D.</strong> @q.OptionD
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(q.AiExplanation))
                    {
                        <div class="explanation-section">
                            <div class="explanation-title">
                                <i class="fa-regular fa-lightbulb"></i> Giải thích đáp án:
                            </div>
                            <div>@q.AiExplanation</div>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>
