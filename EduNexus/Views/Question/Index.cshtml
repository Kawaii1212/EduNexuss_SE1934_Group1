@model EduNexus.ViewModels.QuestionBankViewModel
@{
    Layout = "~/Views/Shared/_SmeLayout.cshtml";
    ViewData["Title"] = "Ngân hàng Câu hỏi - EduNexus";
    ViewData["ActiveMenu"] = "MyCourses";
    ViewData["ActiveSubMenu"] = "Question";
}

<style>
    .question-bank-page {
        --q-primary: #5c24ff;
        --q-primary-light: #9b8cf8;
        --q-primary-lighter: #f0edff;
        --q-bg: #fafafa;
        --q-surface: #fff;
        --q-text: #111827;
        --q-muted: #6b7280;
        --q-border: #e5e7eb;
        --q-success: #10b981;
        --q-danger: #ef4444;
        --q-warning: #f59e0b;
        --q-radius: 12px;
        --q-shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        --q-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    }

    .question-bank-page .question-header {
        background: var(--q-surface);
        border: 1px solid var(--q-border);
        border-radius: var(--q-radius);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 24px;
        margin-bottom: 24px;
        box-shadow: var(--q-shadow-sm);
    }

    .question-bank-page .question-header-left {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .question-bank-page .back-btn {
        color: var(--q-muted);
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
        padding: 8px 14px;
        border: 1px solid var(--q-border);
        border-radius: 8px;
        background: var(--q-surface);
    }

    .question-bank-page .back-btn:hover {
        color: var(--q-text);
        background: #f8fafc;
        border-color: var(--q-muted);
    }

    .question-bank-page .page-badge {
        background: var(--q-primary-lighter);
        color: var(--q-primary);
        padding: 8px 16px;
        border-radius: 100px;
        font-size: 13px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .question-bank-page .header-actions {
        display: flex;
        gap: 12px;
    }

    .question-bank-page .btn {
        padding: 10px 18px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 13px;
        cursor: pointer;
        border: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
        text-decoration: none;
    }

    .question-bank-page .btn-primary {
        background: linear-gradient(135deg, var(--q-primary), #8b5cf6);
        color: #fff;
        box-shadow: 0 4px 10px rgba(92, 36, 255, 0.2);
    }

    .question-bank-page .btn-primary:hover {
        transform: translateY(-1px);
        opacity: 0.95;
        box-shadow: 0 6px 14px rgba(92, 36, 255, 0.3);
    }

    .question-bank-page .btn-outline {
        background: var(--q-surface);
        border: 1px solid var(--q-border);
        color: var(--q-text);
    }

    .question-bank-page .btn-outline:hover {
        background: #f8fafc;
        border-color: var(--q-muted);
    }

    .question-bank-page .question-container {
        display: flex;
        gap: 24px;
    }

    .question-bank-page .filter-sidebar {
        width: 300px;
        flex-shrink: 0;
    }

    .question-bank-page .question-content {
        flex: 1;
    }

    .question-bank-page .filter-panel {
        background: var(--q-surface);
        border: 1px solid var(--q-border);
        border-radius: var(--q-radius);
        padding: 24px;
        position: sticky;
        top: 24px;
        box-shadow: var(--q-shadow-sm);
    }

    .question-bank-page .filter-title {
        font-size: 15px;
        font-weight: 700;
        margin-bottom: 18px;
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--q-text);
        border-bottom: 1px solid var(--q-border);
        padding-bottom: 10px;
    }

    .question-bank-page .form-group {
        margin-bottom: 16px;
    }

    .question-bank-page .form-group label {
        display: block;
        font-size: 13px;
        font-weight: 600;
        margin-bottom: 6px;
        color: var(--q-text);
    }

    .question-bank-page .form-control {
        width: 100%;
        padding: 10px 12px;
        border: 1px solid var(--q-border);
        border-radius: 8px;
        font-size: 13px;
        outline: none;
        background: #fff;
        transition: all 0.15s;
    }

    .question-bank-page .form-control:focus {
        border-color: var(--q-primary-light);
        box-shadow: 0 0 0 3px rgba(92, 36, 255, 0.1);
    }

    .question-bank-page .search-box {
        position: relative;
    }

    .question-bank-page .search-box i {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--q-muted);
        font-size: 14px;
    }

    .question-bank-page .search-box input {
        padding-right: 36px;
    }

    .question-bank-page .btn-filter-submit {
        width: 100%;
        justify-content: center;
        margin-top: 8px;
    }

    .question-bank-page .btn-filter-reset {
        width: 100%;
        justify-content: center;
        margin-top: 8px;
        background: transparent;
        color: var(--q-muted);
        border: 1px dashed var(--q-border);
    }

    .question-bank-page .btn-filter-reset:hover {
        color: var(--q-text);
        background: #f8fafc;
    }

    .question-bank-page .card {
        background: var(--q-surface);
        border: 1px solid var(--q-border);
        border-radius: var(--q-radius);
        box-shadow: var(--q-shadow-sm);
        overflow: hidden;
    }

    .question-bank-page .card-header {
        padding: 18px 24px;
        background: #fafafa;
        border-bottom: 1px solid var(--q-border);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .question-bank-page .card-header h3 {
        font-size: 16px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--q-text);
        margin: 0;
    }

    .question-bank-page .badge-count {
        background: var(--q-primary-lighter);
        color: var(--q-primary);
        font-size: 12px;
        font-weight: 700;
        padding: 3px 10px;
        border-radius: 100px;
    }

    /* Table styles */
    .question-bank-page table {
        width: 100%;
        border-collapse: collapse;
    }

    .question-bank-page th {
        background: #f8fafc;
        padding: 14px 20px;
        text-align: left;
        font-size: 12.5px;
        font-weight: 700;
        color: var(--q-muted);
        border-bottom: 1px solid var(--q-border);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .question-bank-page td {
        padding: 20px;
        border-bottom: 1px solid var(--q-border);
        vertical-align: top;
        font-size: 14px;
    }

    .question-bank-page tr:last-child td {
        border-bottom: none;
    }

    .question-bank-page .q-module-info {
        font-size: 11px;
        font-weight: 600;
        color: var(--q-primary);
        margin-bottom: 6px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: var(--q-primary-lighter);
        padding: 2px 8px;
        border-radius: 4px;
    }

    .question-bank-page .q-text {
        font-weight: 600;
        color: var(--q-text);
        margin-bottom: 12px;
        line-height: 1.5;
    }

    .question-bank-page .q-opts {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px 16px;
    }

    .question-bank-page .q-opt {
        font-size: 13px;
        color: var(--q-muted);
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .question-bank-page .q-opt.ok {
        color: var(--q-success);
        font-weight: 600;
    }

    .question-bank-page .q-opt i {
        font-size: 14px;
    }

    .question-bank-page .exp-link {
        font-size: 12px;
        color: var(--q-primary);
        cursor: pointer;
        text-decoration: none;
        margin-top: 12px;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-weight: 600;
    }

    .question-bank-page .exp-link:hover {
        text-decoration: underline;
    }

    .question-bank-page .exp-box {
        font-size: 12.5px;
        color: #475569;
        margin-top: 8px;
        padding: 12px 16px;
        background: #f8fafc;
        border-radius: 8px;
        display: none;
        line-height: 1.6;
        border-left: 3px solid var(--q-primary);
        animation: qFadeIn 0.2s ease;
    }

    @@keyframes qFadeIn {
        from { opacity: 0; transform: translateY(-5px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .question-bank-page .diff {
        display: inline-flex;
        padding: 4px 10px;
        border-radius: 100px;
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
    }

    .question-bank-page .diff-EASY {
        background: #ecfdf5;
        color: #065f46;
    }

    .question-bank-page .diff-MEDIUM {
        background: #fffbeb;
        color: #92400e;
    }

    .question-bank-page .diff-HARD {
        background: #fef2f2;
        color: #991b1b;
    }

    .question-bank-page .status-badge {
        display: inline-flex;
        padding: 4px 10px;
        border-radius: 100px;
        font-size: 11px;
        font-weight: 600;
    }

    .question-bank-page .status-DRAFT {
        background: #eef2f6;
        color: #475569;
    }

    .question-bank-page .status-APPROVED {
        background: #e0f2fe;
        color: #0369a1;
    }

    .question-bank-page .status-REJECTED {
        background: #ffedd5;
        color: #c2410c;
    }

    .question-bank-page .actions-col {
        display: flex;
        flex-direction: column;
        gap: 6px;
        min-width: 100px;
    }

    .question-bank-page .action-link-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        padding: 8px 10px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.15s;
        text-align: center;
        cursor: pointer;
        border: none;
    }

    .question-bank-page .btn-view {
        background: #f0edff;
        color: var(--q-primary);
    }

    .question-bank-page .btn-view:hover {
        background: #e0daff;
    }

    .question-bank-page .btn-edit {
        background: #e0f2fe;
        color: #0284c7;
    }

    .question-bank-page .btn-edit:hover {
        background: #bae6fd;
    }

    .question-bank-page .btn-del {
        background: #fee2e2;
        color: var(--q-danger);
        width: 100%;
    }

    .question-bank-page .btn-del:hover {
        background: #fecaca;
    }

    .question-bank-page .empty {
        padding: 64px 20px;
        text-align: center;
        color: var(--q-muted);
    }

    .question-bank-page .empty i {
        font-size: 48px;
        color: var(--q-primary-light);
        margin-bottom: 16px;
        display: block;
    }

    .question-bank-page .empty p {
        font-size: 15px;
        margin-bottom: 8px;
        font-weight: 600;
        color: var(--q-text);
    }
</style>

<div class="question-bank-page">
    <div class="question-header">
        <div class="question-header-left">
            @if (ViewBag.ActiveCourseId != null)
            {
                <a href="/Course/Structure?courseId=@ViewBag.ActiveCourseId" class="back-btn">
                    <i class="fa-solid fa-arrow-left"></i> Quay lại chi tiết khóa học
                </a>
            }
            else
            {
                <a href="/Course/MyCourses" class="back-btn">
                    <i class="fa-solid fa-arrow-left"></i> Danh sách khóa học
                </a>
            }
            <div class="page-badge">
                <i class="fa-solid fa-database"></i> Ngân hàng Câu hỏi
            </div>
        </div>
        <div class="header-actions">
            <a href="/Question/Import?courseId=@ViewBag.ActiveCourseId&moduleId=@Model.SelectedModuleId" class="btn btn-outline">
                <i class="fa-solid fa-file-import"></i> Nhập từ CSV
            </a>
            <a href="/QuestionStaging/Index?moduleId=@Model.SelectedModuleId" class="btn btn-outline" style="border-color: #8b5cf6; color: #8b5cf6;">
                <i class="fa-solid fa-robot"></i> Tạo bằng AI
            </a>
            <a href="/Question/Create?courseId=@ViewBag.ActiveCourseId&moduleId=@Model.SelectedModuleId" class="btn btn-primary">
                <i class="fa-solid fa-plus"></i> Tạo câu hỏi thủ công
            </a>
        </div>
    </div>

    <div class="question-container">
        <div class="filter-sidebar">
            <form method="get" action="/Question/Index" class="filter-panel">
                @if (ViewBag.ActiveCourseId != null)
                {
                    <input type="hidden" name="courseId" value="@ViewBag.ActiveCourseId" />
                }
                
                <div class="filter-title">
                    <i class="fa-solid fa-sliders"></i> Bộ lọc tìm kiếm
                </div>

                <div class="form-group">
                    <label for="searchTerm">Từ khoá tìm kiếm</label>
                    <div class="search-box">
                        <input type="text" id="searchTerm" name="searchTerm" class="form-control" 
                               value="@Model.SearchTerm" placeholder="Nhập nội dung câu hỏi..." />
                        <i class="fa-solid fa-magnifying-glass"></i>
                    </div>
                </div>

                <div class="form-group">
                    <label for="moduleId">Chọn Module</label>
                    <select id="moduleId" name="moduleId" class="form-control" required>
                        @foreach (var m in Model.Modules)
                        {
                            <option value="@m.Id" selected="@(m.Id == Model.SelectedModuleId ? "selected" : null)">
                                Chương @m.OrderNo: @m.Title
                            </option>
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label for="difficulty">Độ khó</label>
                    <select id="difficulty" name="difficulty" class="form-control">
                        <option value="">-- Tất cả độ khó --</option>
                        <option value="EASY" selected="@(Model.SelectedDifficulty == "EASY" ? "selected" : null)">Dễ (EASY)</option>
                        <option value="MEDIUM" selected="@(Model.SelectedDifficulty == "MEDIUM" ? "selected" : null)">Trung bình (MEDIUM)</option>
                        <option value="HARD" selected="@(Model.SelectedDifficulty == "HARD" ? "selected" : null)">Khó (HARD)</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="status">Trạng thái phê duyệt</label>
                    <select id="status" name="status" class="form-control">
                        <option value="">-- Tất cả trạng thái --</option>
                        <option value="APPROVED" selected="@(Model.SelectedStatus == "APPROVED" ? "selected" : null)">Đã duyệt (APPROVED)</option>
                        <option value="DRAFT" selected="@(Model.SelectedStatus == "DRAFT" ? "selected" : null)">Nháp / Chờ (DRAFT)</option>
                        <option value="REJECTED" selected="@(Model.SelectedStatus == "REJECTED" ? "selected" : null)">Bị từ chối (REJECTED)</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-primary btn-filter-submit">
                    <i class="fa-solid fa-filter"></i> Áp dụng bộ lọc
                </button>
                
                @if (Model.SelectedModuleId.HasValue || !string.IsNullOrEmpty(Model.SelectedDifficulty) || 
                     !string.IsNullOrEmpty(Model.SelectedStatus) || !string.IsNullOrEmpty(Model.SearchTerm))
                {
                    <a href="/Question/Index?courseId=@ViewBag.ActiveCourseId" class="btn btn-filter-reset">
                        <i class="fa-solid fa-rotate-left"></i> Xoá bộ lọc
                    </a>
                }
            </form>
        </div>

        <div class="question-content">
            @if (ViewData["SuccessMessage"] != null)
            {
                <div class="alert alert-success border-0 shadow-sm mb-4" style="background-color: #ecfdf5; color: #065f46; border-radius: 8px;">
                    <i class="fa-solid fa-circle-check me-2"></i> @ViewData["SuccessMessage"]
                </div>
            }
            @if (ViewData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger border-0 shadow-sm mb-4" style="background-color: #fef2f2; color: #991b1b; border-radius: 8px;">
                    <i class="fa-solid fa-circle-exclamation me-2"></i> @ViewData["ErrorMessage"]
                </div>
            }

            <div class="card">
                <div class="card-header">
                    <h3>
                        <i class="fa-solid fa-list-check" style="color:var(--q-primary)"></i>
                        Danh sách câu hỏi trong ngân hàng
                        <span class="badge-count">@Model.Questions.Count</span>
                    </h3>
                </div>

                @if (Model.Questions.Count == 0)
                {
                    <div class="empty">
                        <i class="fa-regular fa-folder-open"></i>
                        <p>Không tìm thấy câu hỏi nào phù hợp với bộ lọc hiện tại.</p>
                        <span style="font-size: 13px; color: var(--q-muted)">Hãy thử thay đổi điều kiện tìm kiếm hoặc tạo câu hỏi mới.</span>
                    </div>
                }
                else
                {
                    <table>
                        <thead>
                            <tr>
                                <th style="width:62%">Nội dung câu hỏi & Đáp án</th>
                                <th style="width:12%">Độ khó</th>
                                <th style="width:12%">Trạng thái</th>
                                <th style="width:14%">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var q in Model.Questions)
                            {
                                <tr>
                                    <td>
                                        <div class="q-module-info">
                                            <i class="fa-solid fa-bookmark"></i> @q.Module.Course.Title &raquo; @q.Module.Title
                                        </div>
                                        <div class="q-text">@q.Content</div>
                                        <div class="q-opts">
                                            <div class="q-opt @(q.CorrectOption == "A" ? "ok" : "")">
                                                <i class="fa-regular @(q.CorrectOption == "A" ? "fa-circle-check" : "fa-circle")"></i>
                                                A. @q.OptionA
                                            </div>
                                            <div class="q-opt @(q.CorrectOption == "B" ? "ok" : "")">
                                                <i class="fa-regular @(q.CorrectOption == "B" ? "fa-circle-check" : "fa-circle")"></i>
                                                B. @q.OptionB
                                            </div>
                                            <div class="q-opt @(q.CorrectOption == "C" ? "ok" : "")">
                                                <i class="fa-regular @(q.CorrectOption == "C" ? "fa-circle-check" : "fa-circle")"></i>
                                                C. @q.OptionC
                                            </div>
                                            <div class="q-opt @(q.CorrectOption == "D" ? "ok" : "")">
                                                <i class="fa-regular @(q.CorrectOption == "D" ? "fa-circle-check" : "fa-circle")"></i>
                                                D. @q.OptionD
                                            </div>
                                        </div>
                                        @if (!string.IsNullOrEmpty(q.AiExplanation))
                                        {
                                            <span class="exp-link" onclick="toggleExp(@q.Id)">
                                                <i class="fa-regular fa-lightbulb"></i> Xem giải thích
                                            </span>
                                            <div class="exp-box" id="exp-@q.Id">@q.AiExplanation</div>
                                        }
                                    </td>
                                    <td>
                                        <span class="diff diff-@q.Difficulty">@q.Difficulty</span>
                                    </td>
                                    <td>
                                        <span class="status-badge status-@q.Status">@q.Status</span>
                                    </td>
                                    <td>
                                        <div class="actions-col">
                                            <a href="/Question/Details/@q.Id" class="action-link-btn btn-view">
                                                <i class="fa-solid fa-eye"></i> Xem chi tiết
                                            </a>
                                            <a href="/Question/Edit/@q.Id" class="action-link-btn btn-edit">
                                                <i class="fa-solid fa-pen-to-square"></i> Chỉnh sửa
                                            </a>
                                            <form action="/Question/Delete/@q.Id" method="post" 
                                                  onsubmit="return confirm('Bạn có chắc chắn muốn xóa câu hỏi này? Hành động này không thể hoàn tác.')">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="action-link-btn btn-del">
                                                    <i class="fa-solid fa-trash-can"></i> Xoá bỏ
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>

<script>
    function toggleExp(id) {
        const el = document.getElementById('exp-' + id);
        if (el.style.display === 'block') {
            el.style.display = 'none';
        } else {
            el.style.display = 'block';
        }
    }
</script>
