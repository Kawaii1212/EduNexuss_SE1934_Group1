@model EduNexus.Models.QuestionBankViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ngân hàng Câu hỏi - EduNexus</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary: #5c24ff;
            --primary-light: #9b8cf8;
            --primary-lighter: #f0edff;
            --bg: #fafafa;
            --surface: #fff;
            --text: #111827;
            --muted: #6b7280;
            --border: #e5e7eb;
            --success: #10b981;
            --danger: #ef4444;
            --warning: #f59e0b;
            --radius: 12px;
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
        }

        .topbar {
            height: 70px;
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 32px;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: var(--shadow-sm);
        }

        .topbar-left {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .back-btn {
            color: var(--muted);
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: color 0.2s;
        }

        .back-btn:hover {
            color: var(--text);
        }

        .page-badge {
            background: var(--primary-lighter);
            color: var(--primary);
            padding: 6px 14px;
            border-radius: 100px;
            font-size: 13px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .topbar-actions {
            display: flex;
            gap: 12px;
        }

        .btn {
            padding: 10px 20px;
            border-radius: var(--radius);
            font-weight: 600;
            font-size: 13px;
            cursor: pointer;
            border: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.2s;
            text-decoration: none;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary), #8b5cf6);
            color: #fff;
            box-shadow: 0 4px 10px rgba(92, 36, 255, 0.2);
        }

        .btn-primary:hover {
            transform: translateY(-1px);
            opacity: 0.95;
            box-shadow: 0 6px 14px rgba(92, 36, 255, 0.3);
        }

        .btn-outline {
            background: var(--surface);
            border: 1px solid var(--border);
            color: var(--text);
        }

        .btn-outline:hover {
            background: var(--bg);
            border-color: var(--muted);
        }

        .btn-danger {
            background: var(--danger);
            color: #fff;
        }

        .btn-danger:hover {
            background: #dc2626;
        }

        .btn-sm {
            padding: 6px 12px;
            font-size: 12px;
            border-radius: 8px;
        }

        .container {
            display: flex;
            gap: 30px;
            padding: 30px 32px;
            max-width: 1440px;
            margin: 0 auto;
        }

        .sidebar {
            width: 320px;
            flex-shrink: 0;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .alert {
            padding: 14px 18px;
            border-radius: var(--radius);
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 10px;
            animation: slideDown 0.3s ease;
        }

        .alert-success {
            background: #ecfdf5;
            border: 1px solid #a7f3d0;
            color: #065f46;
        }

        .alert-error {
            background: #fef2f2;
            border: 1px solid #fca5a5;
            color: #991b1b;
        }

        @@keyframes slideDown {
            from { transform: translateY(-10px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }

        .card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow-sm);
            overflow: hidden;
            transition: box-shadow 0.2s;
        }

        .card:hover {
            box-shadow: var(--shadow);
        }

        .card-header {
            padding: 18px 24px;
            background: #fafafa;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .card-header h3 {
            font-size: 16px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 10px;
            color: var(--text);
        }

        .filter-panel {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 24px;
            position: sticky;
            top: 100px;
            box-shadow: var(--shadow-sm);
        }

        .filter-title {
            font-size: 15px;
            font-weight: 700;
            margin-bottom: 18px;
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--text);
            border-bottom: 1px solid var(--border);
            padding-bottom: 10px;
        }

        .form-group {
            margin-bottom: 16px;
        }

        .form-group label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 6px;
            color: var(--text);
        }

        .form-control {
            width: 100%;
            padding: 10px 12px;
            border: 1px solid var(--border);
            border-radius: 8px;
            font-size: 13px;
            outline: none;
            background: #fff;
            transition: all 0.15s;
        }

        .form-control:focus {
            border-color: var(--primary-light);
            box-shadow: 0 0 0 3px rgba(92, 36, 255, 0.1);
        }

        .search-box {
            position: relative;
        }

        .search-box i {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            font-size: 14px;
        }

        .search-box input {
            padding-right: 36px;
        }

        .btn-filter-submit {
            width: 100%;
            justify-content: center;
            margin-top: 8px;
        }

        .btn-filter-reset {
            width: 100%;
            justify-content: center;
            margin-top: 8px;
            background: transparent;
            color: var(--muted);
            border: 1px dashed var(--border);
        }

        .btn-filter-reset:hover {
            color: var(--text);
            background: var(--bg);
        }

        .badge-count {
            background: var(--primary-lighter);
            color: var(--primary);
            font-size: 12px;
            font-weight: 700;
            padding: 3px 10px;
            border-radius: 100px;
        }

        /* Table styles */
        table {
            width: 100%;
            border-collapse: collapse;
        }

        th {
            padding: 12px 20px;
            text-align: left;
            font-size: 11px;
            font-weight: 600;
            color: var(--muted);
            text-transform: uppercase;
            background: #fafafa;
            border-bottom: 1px solid var(--border);
        }

        td {
            padding: 18px 20px;
            border-bottom: 1px solid var(--border);
            font-size: 14px;
            vertical-align: top;
        }

        tr:last-child td {
            border-bottom: none;
        }

        tr:hover td {
            background: #fcfcfc;
        }

        .q-module-info {
            font-size: 12px;
            color: var(--primary);
            font-weight: 600;
            margin-bottom: 4px;
        }

        .q-text {
            font-weight: 600;
            margin-bottom: 10px;
            line-height: 1.5;
            color: var(--text);
        }

        .q-opts {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 6px 20px;
            background: #fdfdfd;
            padding: 10px 14px;
            border-radius: 8px;
            border: 1px solid #f5f5f5;
        }

        .q-opt {
            font-size: 13px;
            color: var(--muted);
            padding: 2px 0;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .q-opt.ok {
            color: var(--success);
            font-weight: 600;
        }

        .q-opt.ok i {
            color: var(--success);
        }

        .exp-link {
            font-size: 12px;
            color: var(--primary);
            cursor: pointer;
            text-decoration: none;
            margin-top: 10px;
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-weight: 500;
        }

        .exp-link:hover {
            text-decoration: underline;
        }

        .exp-box {
            font-size: 12px;
            color: var(--muted);
            margin-top: 8px;
            padding: 10px 14px;
            background: var(--primary-lighter);
            border-radius: 8px;
            display: none;
            line-height: 1.6;
            border-left: 3px solid var(--primary);
            animation: fadeIn 0.2s ease;
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(-5px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .diff {
            display: inline-flex;
            padding: 4px 10px;
            border-radius: 100px;
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
        }

        .diff-EASY {
            background: #ecfdf5;
            color: #065f46;
        }

        .diff-MEDIUM {
            background: #fffbeb;
            color: #92400e;
        }

        .diff-HARD {
            background: #fef2f2;
            color: #991b1b;
        }

        .status-badge {
            display: inline-flex;
            padding: 4px 10px;
            border-radius: 100px;
            font-size: 11px;
            font-weight: 600;
        }

        .status-DRAFT {
            background: #eef2f6;
            color: #475569;
        }

        .status-APPROVED {
            background: #e0f2fe;
            color: #0369a1;
        }

        .status-REJECTED {
            background: #ffedd5;
            color: #c2410c;
        }

        .actions-col {
            display: flex;
            flex-direction: column;
            gap: 6px;
            min-width: 90px;
        }

        .action-link-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            padding: 6px 10px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.15s;
            text-align: center;
            cursor: pointer;
        }

        .btn-view {
            background: #f0edff;
            color: var(--primary);
        }

        .btn-view:hover {
            background: #e0daff;
        }

        .btn-edit {
            background: #e0f2fe;
            color: #0284c7;
        }

        .btn-edit:hover {
            background: #bae6fd;
        }

        .btn-del {
            background: #fee2e2;
            color: var(--danger);
            border: none;
            width: 100%;
        }

        .btn-del:hover {
            background: #fecaca;
        }

        .empty {
            padding: 64px 20px;
            text-align: center;
            color: var(--muted);
        }

        .empty i {
            font-size: 48px;
            color: var(--primary-light);
            margin-bottom: 16px;
            display: block;
        }

        .empty p {
            font-size: 15px;
            margin-bottom: 8px;
        }
    </style>
</head>
<body>

    <header class="topbar">
        <div class="topbar-left">
            <a href="/Home/Index" class="back-btn">
                <i class="fa-solid fa-arrow-left"></i> Quay lại
            </a>
            <div class="page-badge">
                <i class="fa-solid fa-database"></i> Ngân hàng Câu hỏi
            </div>
        </div>
        <div class="topbar-actions">
            <a href="/Question/Import" class="btn btn-outline">
                <i class="fa-solid fa-file-import"></i> Nhập từ CSV
            </a>
            <a href="/Question/Create" class="btn btn-primary">
                <i class="fa-solid fa-plus"></i> Tạo câu hỏi thủ công
            </a>
        </div>
    </header>

    <div class="container">
        <div class="sidebar">
            <form method="get" action="/Question" class="filter-panel">
                <div class="filter-title">
                    <i class="fa-solid fa-sliders"></i> Bộ lọc tìm kiếm
                </div>

                <div class="form-group">
                    <label for="searchTerm">Từ khoá tìm kiếm</label>
                    <div class="search-box">
                        <input type="text" id="searchTerm" name="searchTerm" class="form-control" 
                               value="@Model.SearchTerm" placeholder="Nhập nội dung câu hỏi..." />
                        <i class="fa-solid fa-magnifying-glass"></i>
                    </div>
                </div>

                <div class="form-group">
                    <label for="moduleId">Chọn Module</label>
                    <select id="moduleId" name="moduleId" class="form-control">
                        <option value="">-- Tất cả Module --</option>
                        @foreach (var m in Model.Modules)
                        {
                            <option value="@m.Id" selected="@(m.Id == Model.SelectedModuleId ? "selected" : null)">
                                @m.Course.Title — @m.Title
                            </option>
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label for="difficulty">Độ khó</label>
                    <select id="difficulty" name="difficulty" class="form-control">
                        <option value="">-- Tất cả độ khó --</option>
                        <option value="EASY" selected="@(Model.SelectedDifficulty == "EASY" ? "selected" : null)">Dễ (EASY)</option>
                        <option value="MEDIUM" selected="@(Model.SelectedDifficulty == "MEDIUM" ? "selected" : null)">Trung bình (MEDIUM)</option>
                        <option value="HARD" selected="@(Model.SelectedDifficulty == "HARD" ? "selected" : null)">Khó (HARD)</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="status">Trạng thái phê duyệt</label>
                    <select id="status" name="status" class="form-control">
                        <option value="">-- Tất cả trạng thái --</option>
                        <option value="APPROVED" selected="@(Model.SelectedStatus == "APPROVED" ? "selected" : null)">Đã duyệt (APPROVED)</option>
                        <option value="DRAFT" selected="@(Model.SelectedStatus == "DRAFT" ? "selected" : null)">Nháp / Chờ (DRAFT)</option>
                        <option value="REJECTED" selected="@(Model.SelectedStatus == "REJECTED" ? "selected" : null)">Bị từ chối (REJECTED)</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-primary btn-filter-submit">
                    <i class="fa-solid fa-filter"></i> Áp dụng bộ lọc
                </button>
                
                @if (Model.SelectedModuleId.HasValue || !string.IsNullOrEmpty(Model.SelectedDifficulty) || 
                     !string.IsNullOrEmpty(Model.SelectedStatus) || !string.IsNullOrEmpty(Model.SearchTerm))
                {
                    <a href="/Question" class="btn btn-filter-reset">
                        <i class="fa-solid fa-rotate-left"></i> Xoá bộ lọc
                    </a>
                }
            </form>
        </div>

        <div class="main-content">
            @if (ViewData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">
                    <i class="fa-solid fa-circle-check"></i> @ViewData["SuccessMessage"]
                </div>
            }
            @if (ViewData["ErrorMessage"] != null)
            {
                <div class="alert alert-error">
                    <i class="fa-solid fa-circle-exclamation"></i> @ViewData["ErrorMessage"]
                </div>
            }

            <div class="card">
                <div class="card-header">
                    <h3>
                        <i class="fa-solid fa-list-check" style="color:var(--primary)"></i>
                        Danh sách câu hỏi trong ngân hàng
                        <span class="badge-count">@Model.Questions.Count</span>
                    </h3>
                </div>

                @if (Model.Questions.Count == 0)
                {
                    <div class="empty">
                        <i class="fa-regular fa-folder-open"></i>
                        <p>Không tìm thấy câu hỏi nào phù hợp với bộ lọc hiện tại.</p>
                        <span style="font-size: 13px; color: var(--muted)">Hãy thử thay đổi điều kiện tìm kiếm hoặc tạo câu hỏi mới.</span>
                    </div>
                }
                else
                {
                    <table>
                        <thead>
                            <tr>
                                <th style="width:60%">Nội dung câu hỏi & Đáp án</th>
                                <th style="width:12%">Độ khó</th>
                                <th style="width:12%">Trạng thái</th>
                                <th style="width:16%">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var q in Model.Questions)
                            {
                                <tr>
                                    <td>
                                        <div class="q-module-info">
                                            <i class="fa-solid fa-bookmark"></i> @q.Module.Course.Title &raquo; @q.Module.Title
                                        </div>
                                        <div class="q-text">@q.Content</div>
                                        <div class="q-opts">
                                            <div class="q-opt @(q.CorrectOption == "A" ? "ok" : "")">
                                                <i class="fa-regular @(q.CorrectOption == "A" ? "fa-circle-check" : "fa-circle")"></i>
                                                A. @q.OptionA
                                            </div>
                                            <div class="q-opt @(q.CorrectOption == "B" ? "ok" : "")">
                                                <i class="fa-regular @(q.CorrectOption == "B" ? "fa-circle-check" : "fa-circle")"></i>
                                                B. @q.OptionB
                                            </div>
                                            <div class="q-opt @(q.CorrectOption == "C" ? "ok" : "")">
                                                <i class="fa-regular @(q.CorrectOption == "C" ? "fa-circle-check" : "fa-circle")"></i>
                                                C. @q.OptionC
                                            </div>
                                            <div class="q-opt @(q.CorrectOption == "D" ? "ok" : "")">
                                                <i class="fa-regular @(q.CorrectOption == "D" ? "fa-circle-check" : "fa-circle")"></i>
                                                D. @q.OptionD
                                            </div>
                                        </div>
                                        @if (!string.IsNullOrEmpty(q.AiExplanation))
                                        {
                                            <span class="exp-link" onclick="toggleExp(@q.Id)">
                                                <i class="fa-regular fa-lightbulb"></i> Xem giải thích
                                            </span>
                                            <div class="exp-box" id="exp-@q.Id">@q.AiExplanation</div>
                                        }
                                    </td>
                                    <td>
                                        <span class="diff diff-@q.Difficulty">@q.Difficulty</span>
                                    </td>
                                    <td>
                                        <span class="status-badge status-@q.Status">@q.Status</span>
                                    </td>
                                    <td>
                                        <div class="actions-col">
                                            <a href="/Question/Details/@q.Id" class="action-link-btn btn-view">
                                                <i class="fa-solid fa-eye"></i> Xem chi tiết
                                            </a>
                                            <a href="/Question/Edit/@q.Id" class="action-link-btn btn-edit">
                                                <i class="fa-solid fa-pen-to-square"></i> Chỉnh sửa
                                            </a>
                                            <form action="/Question/Delete/@q.Id" method="post" 
                                                  onsubmit="return confirm('Bạn có chắc chắn muốn xoá câu hỏi này? Hành động này không thể hoàn tác.')">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="action-link-btn btn-del">
                                                    <i class="fa-solid fa-trash-can"></i> Xoá bỏ
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    <script>
        function toggleExp(id) {
            const el = document.getElementById('exp-' + id);
            if (el.style.display === 'block') {
                el.style.display = 'none';
            } else {
                el.style.display = 'block';
            }
        }
    </script>
</body>
</html>
