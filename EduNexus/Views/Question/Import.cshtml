@model EduNexus.ViewModels.QuestionImportViewModel
@{
    Layout = "~/Views/Shared/_SmeLayout.cshtml";
    ViewData["Title"] = "Nhập câu hỏi từ CSV - EduNexus";
    ViewData["ActiveMenu"] = "MyCourses";
    ViewData["ActiveSubMenu"] = "Question";
}

<style>
    .question-import-page {
        --i-primary: #5c24ff;
        --i-primary-light: #9b8cf8;
        --i-primary-lighter: #f0edff;
        --i-surface: #fff;
        --i-text: #111827;
        --i-muted: #6b7280;
        --i-border: #e5e7eb;
        --i-danger: #ef4444;
        --i-success: #10b981;
        --i-radius: 12px;
        --i-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    .question-import-page .page-header {
        background: var(--i-surface);
        border: 1px solid var(--i-border);
        border-radius: var(--i-radius);
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 16px 24px;
        margin-bottom: 24px;
    }

    .question-import-page .back-btn {
        color: var(--i-muted);
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
        padding: 8px 14px;
        border: 1px solid var(--i-border);
        border-radius: 8px;
        background: var(--i-surface);
    }

    .question-import-page .back-btn:hover {
        color: var(--i-text);
        background: #f8fafc;
        border-color: var(--i-muted);
    }

    .question-import-page .page-badge {
        background: var(--i-primary-lighter);
        color: var(--i-primary);
        padding: 8px 16px;
        border-radius: 100px;
        font-size: 13px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .question-import-page .card {
        background: var(--i-surface);
        border: 1px solid var(--i-border);
        border-radius: var(--i-radius);
        box-shadow: var(--i-shadow);
        overflow: hidden;
        max-width: 800px;
        margin: 0 auto;
    }

    .question-import-page .card-header {
        padding: 20px 24px;
        background: #fafafa;
        border-bottom: 1px solid var(--i-border);
    }

    .question-import-page .card-header h2 {
        font-size: 18px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--i-text);
        margin: 0;
    }

    .question-import-page .card-body {
        padding: 30px;
    }

    .question-import-page .form-group {
        margin-bottom: 24px;
    }

    .question-import-page .form-group label {
        display: block;
        font-size: 14px;
        font-weight: 600;
        margin-bottom: 8px;
        color: var(--i-text);
    }

    .question-import-page .form-control {
        width: 100%;
        padding: 11px 14px;
        border: 1px solid var(--i-border);
        border-radius: 8px;
        font-size: 14px;
        outline: none;
        background: #fff;
        transition: all 0.15s;
    }

    .question-import-page .form-control:focus {
        border-color: var(--i-primary-light);
        box-shadow: 0 0 0 3px rgba(92, 36, 255, 0.1);
    }

    .question-import-page textarea.form-control {
        resize: vertical;
        min-height: 120px;
    }

    .question-import-page .info-panel {
        background: #f8fafc;
        border: 1px solid var(--i-border);
        border-radius: 8px;
        padding: 16px 20px;
        margin-bottom: 24px;
        font-size: 13.5px;
        color: #475569;
        line-height: 1.6;
    }

    .question-import-page .info-panel h4 {
        font-size: 14px;
        font-weight: 700;
        color: var(--i-text);
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .question-import-page .error-list {
        background: #fef2f2;
        border: 1px solid #fca5a5;
        border-radius: 8px;
        padding: 18px 24px;
        margin-bottom: 24px;
        color: #991b1b;
        font-size: 13.5px;
    }

    .question-import-page .error-list h4 {
        font-size: 14px;
        font-weight: 700;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .question-import-page .btn-submit-row {
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        border-top: 1px solid var(--i-border);
        padding-top: 24px;
        margin-top: 12px;
    }

    .question-import-page .btn {
        padding: 11px 24px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        border: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
        text-decoration: none;
    }

    .question-import-page .btn-primary {
        background: linear-gradient(135deg, var(--i-primary), #8b5cf6);
        color: #fff;
        box-shadow: 0 4px 10px rgba(92, 36, 255, 0.2);
    }

    .question-import-page .btn-primary:hover {
        transform: translateY(-1px);
        opacity: 0.95;
    }

    .question-import-page .btn-cancel {
        background: transparent;
        border: 1px solid var(--i-border);
        color: var(--i-muted);
    }

    .question-import-page .btn-cancel:hover {
        background: #f8fafc;
        color: var(--i-text);
    }

    .question-import-page .error-message {
        font-size: 12px;
        color: var(--i-danger);
        margin-top: 5px;
        display: block;
        font-weight: 500;
    }
</style>

<div class="question-import-page">
    <div class="page-header">
        <a href="/Question/Index?courseId=@ViewBag.ActiveCourseId" class="back-btn">
            <i class="fa-solid fa-arrow-left"></i> Trở về Ngân hàng
        </a>
        <div class="page-badge">
            <i class="fa-solid fa-file-import"></i> Nhập câu hỏi từ CSV
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h2>
                <i class="fa-solid fa-file-import" style="color:var(--i-primary)"></i>
                Nhập câu hỏi hàng loạt
            </h2>
        </div>
        <div class="card-body">
            <div class="info-panel">
                <h4><i class="fa-solid fa-circle-info" style="color: var(--i-primary)"></i> Hướng dẫn định dạng CSV</h4>
                <p>Mẫu CSV hợp lệ cần có tối thiểu 6 cột theo thứ tự sau:</p>
                <code style="display:block; padding: 10px; background: #eef2f6; border-radius: 6px; margin: 8px 0; font-size: 12px; color: var(--i-primary); font-family: monospace;">
                    Nội dung câu hỏi, Đáp án A, Đáp án B, Đáp án C, Đáp án D, Đáp án đúng (A/B/C/D), [Độ khó (EASY/MEDIUM/HARD) - Mặc định: MEDIUM], [Giải thích - Tuỳ chọn]
                </code>
                <p style="margin-top: 8px; font-size: 12.5px;" class="text-muted">
                    <em>* Lưu ý: Nếu nội dung câu hỏi hoặc đáp án có chứa dấu phẩy (,), vui lòng bao bọc cột đó trong dấu ngoặc kép đôi ("). Ví dụ: "Câu hỏi có chứa dấu, phẩy", A, B, C, D, A</em>
                </p>
            </div>

            @if (Model.ImportErrors != null && Model.ImportErrors.Any())
            {
                <div class="error-list">
                    <h4><i class="fa-solid fa-triangle-exclamation"></i> Có lỗi xảy ra khi nhập dữ liệu:</h4>
                    <ul style="padding-left: 20px; margin-bottom: 0;">
                        @foreach (var err in Model.ImportErrors)
                        {
                            <li>@err</li>
                        }
                    </ul>
                </div>
            }

            <form asp-action="Import" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                @if (ViewBag.ActiveCourseTitle != null)
                {
                    <div class="form-group">
                        <label>Khóa học</label>
                        <input type="text" class="form-control" value="@ViewBag.ActiveCourseTitle" readonly style="background-color: #f1f5f9; cursor: not-allowed;" />
                        @if (ViewBag.ActiveCourseId != null)
                        {
                            <input type="hidden" name="courseId" value="@ViewBag.ActiveCourseId" />
                        }
                    </div>
                }

                <div class="form-group">
                    <label asp-for="ModuleId">Thuộc Module nhận câu hỏi</label>
                    <select asp-for="ModuleId" class="form-control">
                        <option value="">-- Chọn Module ứng với môn học --</option>
                        @if (Model.Modules != null)
                        {
                            foreach (var m in Model.Modules)
                            {
                                <option value="@m.Id" selected="@(m.Id == Model.ModuleId ? "selected" : null)">Chương @m.OrderNo: @m.Title</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="ModuleId" class="error-message"></span>
                </div>

                <div class="form-group">
                    <label for="File">Tải lên file CSV (.csv)</label>
                    <input type="file" id="File" name="File" class="form-control" accept=".csv" />
                    <span asp-validation-for="File" class="error-message"></span>
                </div>

                <div style="text-align: center; margin: 20px 0; font-weight: 700; color: var(--i-muted); font-size: 13px;">HOẶC DÁN NỘI DUNG CSV TRỰC TIẾP VÀO ĐÂY</div>

                <div class="form-group">
                    <label asp-for="CsvText">Nội dung văn bản CSV</label>
                    <textarea asp-for="CsvText" class="form-control" placeholder="Nội dung,Đáp án A,Đáp án B,Đáp án C,Đáp án D,Đáp án đúng (A/B/C/D)"></textarea>
                    <span asp-validation-for="CsvText" class="error-message"></span>
                </div>

                <div class="btn-submit-row">
                    <a href="/Question/Index?courseId=@ViewBag.ActiveCourseId" class="btn btn-cancel">Huỷ bỏ</a>
                    <button type="submit" class="btn btn-primary">
                        <i class="fa-solid fa-file-arrow-up"></i> Thực hiện Import
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
