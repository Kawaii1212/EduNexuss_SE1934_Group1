@model EduNexus.ViewModels.QuestionFormViewModel
@{
    Layout = "~/Views/Shared/_SmeLayout.cshtml";
    ViewData["Title"] = "Thêm câu hỏi mới - EduNexus";
    ViewData["ActiveMenu"] = "MyCourses";
    ViewData["ActiveSubMenu"] = "Question";
}

<style>
    .question-create-page {
        --c-primary: #5c24ff;
        --c-primary-light: #9b8cf8;
        --c-primary-lighter: #f0edff;
        --c-surface: #fff;
        --c-text: #111827;
        --c-muted: #6b7280;
        --c-border: #e5e7eb;
        --c-success: #10b981;
        --c-danger: #ef4444;
        --c-radius: 12px;
        --c-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    .question-create-page .page-header {
        background: var(--c-surface);
        border: 1px solid var(--c-border);
        border-radius: var(--c-radius);
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 16px 24px;
        margin-bottom: 24px;
    }

    .question-create-page .back-btn {
        color: var(--c-muted);
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
        padding: 8px 14px;
        border: 1px solid var(--c-border);
        border-radius: 8px;
        background: var(--c-surface);
    }

    .question-create-page .back-btn:hover {
        color: var(--c-text);
        background: #f8fafc;
        border-color: var(--c-muted);
    }

    .question-create-page .page-badge {
        background: var(--c-primary-lighter);
        color: var(--c-primary);
        padding: 8px 16px;
        border-radius: 100px;
        font-size: 13px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .question-create-page .card {
        background: var(--c-surface);
        border: 1px solid var(--c-border);
        border-radius: var(--c-radius);
        box-shadow: var(--c-shadow);
        overflow: hidden;
        max-width: 800px;
        margin: 0 auto;
    }

    .question-create-page .card-header {
        padding: 20px 24px;
        background: #fafafa;
        border-bottom: 1px solid var(--c-border);
    }

    .question-create-page .card-header h2 {
        font-size: 18px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--c-text);
        margin: 0;
    }

    .question-create-page .card-body {
        padding: 30px;
    }

    .question-create-page .form-group {
        margin-bottom: 24px;
    }

    .question-create-page .form-group label {
        display: block;
        font-size: 14px;
        font-weight: 600;
        margin-bottom: 8px;
        color: var(--c-text);
    }

    .question-create-page .form-control {
        width: 100%;
        padding: 11px 14px;
        border: 1px solid var(--c-border);
        border-radius: 8px;
        font-size: 14px;
        outline: none;
        background: #fff;
        transition: all 0.15s;
    }

    .question-create-page .form-control:focus {
        border-color: var(--c-primary-light);
        box-shadow: 0 0 0 3px rgba(92, 36, 255, 0.1);
    }

    .question-create-page textarea.form-control {
        resize: vertical;
        min-height: 100px;
    }

    .question-create-page .options-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .question-create-page .option-field {
        position: relative;
    }

    .question-create-page .option-prefix {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        font-weight: 700;
        color: var(--c-primary);
        font-size: 14px;
    }

    .question-create-page .option-field input {
        padding-left: 36px;
    }

    .question-create-page .diff-btns {
        display: flex;
        gap: 10px;
    }

    .question-create-page .diff-btn {
        flex: 1;
        padding: 10px;
        border: 1px solid var(--c-border);
        border-radius: 8px;
        background: var(--c-surface);
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        color: var(--c-muted);
        text-align: center;
        transition: all 0.15s;
    }

    .question-create-page .diff-btn.active {
        border-color: var(--c-primary);
        background: var(--c-primary-lighter);
        color: var(--c-primary);
    }

    .question-create-page .btn-submit-row {
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        border-top: 1px solid var(--c-border);
        padding-top: 24px;
        margin-top: 12px;
    }

    .question-create-page .btn {
        padding: 11px 24px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        border: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
        text-decoration: none;
    }

    .question-create-page .btn-primary {
        background: linear-gradient(135deg, var(--c-primary), #8b5cf6);
        color: #fff;
        box-shadow: 0 4px 10px rgba(92, 36, 255, 0.2);
    }

    .question-create-page .btn-primary:hover {
        transform: translateY(-1px);
        opacity: 0.95;
    }

    .question-create-page .btn-cancel {
        background: transparent;
        border: 1px solid var(--c-border);
        color: var(--c-muted);
    }

    .question-create-page .btn-cancel:hover {
        background: #f8fafc;
        color: var(--c-text);
    }

    .question-create-page .error-message {
        font-size: 12px;
        color: var(--c-danger);
        margin-top: 5px;
        display: block;
        font-weight: 500;
    }

    .question-create-page .alert-danger-form {
        background: #fef2f2;
        border: 1px solid #fca5a5;
        color: #991b1b;
        padding: 14px 18px;
        border-radius: 8px;
        font-size: 14px;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 10px;
    }
</style>

<div class="question-create-page">
    <div class="page-header">
        <a href="/Question/Index?courseId=@ViewBag.ActiveCourseId" class="back-btn">
            <i class="fa-solid fa-arrow-left"></i> Trở về Ngân hàng
        </a>
        <div class="page-badge">
            <i class="fa-solid fa-file-signature"></i> Thêm mới câu hỏi
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h2>
                <i class="fa-solid fa-circle-plus" style="color:var(--c-primary)"></i>
                Tạo câu hỏi trắc nghiệm mới
            </h2>
        </div>
        <div class="card-body">
            @if (ViewData["ErrorMessage"] != null)
            {
                <div class="alert-danger-form">
                    <i class="fa-solid fa-circle-xmark"></i> @ViewData["ErrorMessage"]
                </div>
            }

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                @if (ViewBag.ActiveCourseTitle != null)
                {
                    <div class="form-group">
                        <label>Khóa học</label>
                        <input type="text" class="form-control" value="@ViewBag.ActiveCourseTitle" readonly style="background-color: #f1f5f9; cursor: not-allowed;" />
                        @if (ViewBag.ActiveCourseId != null)
                        {
                            <input type="hidden" name="courseId" value="@ViewBag.ActiveCourseId" />
                        }
                    </div>
                }

                <div class="form-group">
                    <label asp-for="ModuleId">Thuộc Module</label>
                    <select asp-for="ModuleId" class="form-control">
                        <option value="">-- Chọn Module ứng với môn học --</option>
                        @if (Model.Modules != null)
                        {
                            foreach (var m in Model.Modules)
                            {
                                <option value="@m.Id" selected="@(m.Id == Model.ModuleId ? "selected" : null)">Chương @m.OrderNo: @m.Title</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="ModuleId" class="error-message"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Content">Nội dung câu hỏi</label>
                    <textarea asp-for="Content" class="form-control" placeholder="Nhập nội dung câu hỏi trắc nghiệm..."></textarea>
                    <span asp-validation-for="Content" class="error-message"></span>
                </div>

                <div class="form-group">
                    <label>Các phương án trả lời</label>
                    <div class="options-grid">
                        <div class="option-field">
                            <span class="option-prefix">A.</span>
                            <input asp-for="OptionA" class="form-control" placeholder="Đáp án A" />
                            <span asp-validation-for="OptionA" class="error-message"></span>
                        </div>
                        <div class="option-field">
                            <span class="option-prefix">B.</span>
                            <input asp-for="OptionB" class="form-control" placeholder="Đáp án B" />
                            <span asp-validation-for="OptionB" class="error-message"></span>
                        </div>
                        <div class="option-field">
                            <span class="option-prefix">C.</span>
                            <input asp-for="OptionC" class="form-control" placeholder="Đáp án C" />
                            <span asp-validation-for="OptionC" class="error-message"></span>
                        </div>
                        <div class="option-field">
                            <span class="option-prefix">D.</span>
                            <input asp-for="OptionD" class="form-control" placeholder="Đáp án D" />
                            <span asp-validation-for="OptionD" class="error-message"></span>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="CorrectOption">Phương án đúng</label>
                    <select asp-for="CorrectOption" class="form-control" style="font-weight: 600; color: var(--c-success);">
                        <option value="A" style="color:var(--c-text);">Phương án A</option>
                        <option value="B" style="color:var(--c-text);">Phương án B</option>
                        <option value="C" style="color:var(--c-text);">Phương án C</option>
                        <option value="D" style="color:var(--c-text);">Phương án D</option>
                    </select>
                    <span asp-validation-for="CorrectOption" class="error-message"></span>
                </div>

                <div class="form-group">
                    <label>Độ khó câu hỏi</label>
                    <div class="diff-btns">
                        <button type="button" onclick="setDiff('EASY', this)"
                                class="diff-btn @(Model.Difficulty == "EASY" ? "active" : "")">
                            Dễ
                        </button>
                        <button type="button" onclick="setDiff('MEDIUM', this)"
                                class="diff-btn @(Model.Difficulty == "MEDIUM" || string.IsNullOrEmpty(Model.Difficulty) ? "active" : "")">
                            Vừa
                        </button>
                        <button type="button" onclick="setDiff('HARD', this)"
                                class="diff-btn @(Model.Difficulty == "HARD" ? "active" : "")">
                            Khó
                        </button>
                    </div>
                    <input type="hidden" asp-for="Difficulty" id="diffInput" value="@(string.IsNullOrEmpty(Model.Difficulty) ? "MEDIUM" : Model.Difficulty)" />
                </div>

                <div class="form-group">
                    <label asp-for="AiExplanation">Giải thích đáp án (Tuỳ chọn)</label>
                    <textarea asp-for="AiExplanation" class="form-control" placeholder="Giải thích vì sao lựa chọn này đúng..."></textarea>
                    <span asp-validation-for="AiExplanation" class="error-message"></span>
                </div>

                <div class="btn-submit-row">
                    <a href="/Question/Index?courseId=@ViewBag.ActiveCourseId" class="btn btn-cancel">Huỷ bỏ</a>
                    <button type="submit" class="btn btn-primary">
                        <i class="fa-solid fa-floppy-disk"></i> Lưu câu hỏi
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function setDiff(val, btn) {
        document.querySelectorAll('.diff-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById('diffInput').value = val;
    }
</script>
