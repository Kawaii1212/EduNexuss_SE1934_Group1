@model DataAccessLayer.Models.Question
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chi tiết Câu hỏi - EduNexus</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary: #5c24ff;
            --primary-light: #9b8cf8;
            --primary-lighter: #f0edff;
            --bg: #fafafa;
            --surface: #fff;
            --text: #111827;
            --muted: #6b7280;
            --border: #e5e7eb;
            --success: #10b981;
            --success-light: #d1fae5;
            --success-dark: #065f46;
            --danger: #ef4444;
            --warning: #f59e0b;
            --radius: 12px;
            --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
        }

        .topbar {
            height: 70px;
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 32px;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .topbar-left {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .back-btn {
            color: var(--muted);
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: color 0.2s;
        }

        .back-btn:hover {
            color: var(--text);
        }

        .page-badge {
            background: var(--primary-lighter);
            color: var(--primary);
            padding: 6px 14px;
            border-radius: 100px;
            font-size: 13px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .container {
            max-width: 900px;
            margin: 40px auto;
            padding: 0 20px;
            display: flex;
            flex-direction: column;
            gap: 24px;
        }

        .card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow-lg);
            overflow: hidden;
        }

        .card-header {
            padding: 24px 30px;
            background: #fafafa;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .card-header h2 {
            font-size: 18px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 10px;
            color: var(--text);
        }

        .card-body {
            padding: 30px;
        }

        .meta-badges {
            display: flex;
            gap: 8px;
            margin-bottom: 20px;
        }

        .badge {
            display: inline-flex;
            padding: 5px 12px;
            border-radius: 100px;
            font-size: 12px;
            font-weight: 600;
        }

        .badge-primary {
            background: var(--primary-lighter);
            color: var(--primary);
        }

        .diff {
            font-weight: 700;
            text-transform: uppercase;
        }

        .diff-EASY {
            background: #ecfdf5;
            color: #065f46;
        }

        .diff-MEDIUM {
            background: #fffbeb;
            color: #92400e;
        }

        .diff-HARD {
            background: #fef2f2;
            color: #991b1b;
        }

        .status-DRAFT {
            background: #eef2f6;
            color: #475569;
        }

        .status-APPROVED {
            background: #e0f2fe;
            color: #0369a1;
        }

        .status-REJECTED {
            background: #ffedd5;
            color: #c2410c;
        }

        .q-title {
            font-size: 16px;
            font-weight: 600;
            line-height: 1.6;
            margin-bottom: 24px;
            color: var(--text);
            background: #f8fafc;
            padding: 20px;
            border-radius: 10px;
            border-left: 4px solid var(--primary);
        }

        .options-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin-bottom: 30px;
        }

        .opt-item {
            padding: 16px 20px;
            border: 1px solid var(--border);
            border-radius: 10px;
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 14px;
            transition: all 0.15s;
        }

        .opt-item-correct {
            background: var(--success-light);
            border-color: var(--success);
            color: var(--success-dark);
            font-weight: 600;
            box-shadow: 0 2px 4px rgba(16, 185, 129, 0.1);
        }

        .opt-badge {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 13px;
            background: var(--bg);
            border: 1px solid var(--border);
            color: var(--text);
            flex-shrink: 0;
        }

        .opt-item-correct .opt-badge {
            background: var(--success);
            border-color: var(--success);
            color: #fff;
        }

        .exp-section {
            background: #faf5ff;
            border: 1px solid #e9d5ff;
            border-radius: var(--radius);
            padding: 20px;
            margin-bottom: 30px;
        }

        .exp-title {
            font-size: 14px;
            font-weight: 700;
            color: #6b21a8;
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .exp-body {
            font-size: 13.5px;
            color: #7e22ce;
            line-height: 1.6;
        }

        .info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            border-top: 1px solid var(--border);
            padding-top: 24px;
        }

        .info-item {
            font-size: 13px;
            color: var(--muted);
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .info-item strong {
            color: var(--text);
            font-size: 14px;
        }

        .card-footer {
            padding: 20px 30px;
            background: #fafafa;
            border-top: 1px solid var(--border);
            display: flex;
            justify-content: flex-end;
            gap: 12px;
        }

        .btn {
            padding: 10px 20px;
            border-radius: var(--radius);
            font-weight: 600;
            font-size: 13px;
            cursor: pointer;
            border: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.2s;
            text-decoration: none;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary), #8b5cf6);
            color: #fff;
            box-shadow: 0 4px 10px rgba(92, 36, 255, 0.2);
        }

        .btn-primary:hover {
            transform: translateY(-1px);
            opacity: 0.95;
            box-shadow: 0 6px 14px rgba(92, 36, 255, 0.3);
        }

        .btn-outline {
            background: var(--surface);
            border: 1px solid var(--border);
            color: var(--text);
        }

        .btn-outline:hover {
            background: var(--bg);
            border-color: var(--muted);
        }
    </style>
</head>
<body>

    <header class="topbar">
        <div class="topbar-left">
            <a href="/Question" class="back-btn">
                <i class="fa-solid fa-arrow-left"></i> Quay lại Ngân hàng
            </a>
            <div class="page-badge">
                <i class="fa-solid fa-circle-info"></i> Chi tiết câu hỏi
            </div>
        </div>
    </header>

    <div class="container">
        <div class="card">
            <div class="card-header">
                <h2>
                    <i class="fa-solid fa-circle-question" style="color:var(--primary)"></i>
                    Câu hỏi ID: #@Model.Id
                </h2>
                <span class="badge badge-primary">
                    <i class="fa-solid fa-bookmark"></i> @Model.Module.Course.Title &raquo; @Model.Module.Title
                </span>
            </div>
            
            <div class="card-body">
                <div class="meta-badges">
                    <span class="badge diff diff-@Model.Difficulty">Độ khó: @Model.Difficulty</span>
                    <span class="badge status-badge status-@Model.Status">Trạng thái: @Model.Status</span>
                    <span class="badge badge-primary">Nguồn: @Model.Source</span>
                </div>

                <div class="q-title">
                    @Model.Content
                </div>

                <div class="options-list">
                    <div class="opt-item @(Model.CorrectOption == "A" ? "opt-item-correct" : "")">
                        <span class="opt-badge">A</span>
                        <span>@Model.OptionA</span>
                        @if (Model.CorrectOption == "A")
                        {
                            <i class="fa-solid fa-circle-check" style="margin-left: auto;"></i>
                        }
                    </div>
                    <div class="opt-item @(Model.CorrectOption == "B" ? "opt-item-correct" : "")">
                        <span class="opt-badge">B</span>
                        <span>@Model.OptionB</span>
                        @if (Model.CorrectOption == "B")
                        {
                            <i class="fa-solid fa-circle-check" style="margin-left: auto;"></i>
                        }
                    </div>
                    <div class="opt-item @(Model.CorrectOption == "C" ? "opt-item-correct" : "")">
                        <span class="opt-badge">C</span>
                        <span>@Model.OptionC</span>
                        @if (Model.CorrectOption == "C")
                        {
                            <i class="fa-solid fa-circle-check" style="margin-left: auto;"></i>
                        }
                    </div>
                    <div class="opt-item @(Model.CorrectOption == "D" ? "opt-item-correct" : "")">
                        <span class="opt-badge">D</span>
                        <span>@Model.OptionD</span>
                        @if (Model.CorrectOption == "D")
                        {
                            <i class="fa-solid fa-circle-check" style="margin-left: auto;"></i>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.AiExplanation))
                {
                    <div class="exp-section">
                        <div class="exp-title">
                            <i class="fa-solid fa-lightbulb"></i> Giải thích đáp án đúng:
                        </div>
                        <div class="exp-body">
                            @Model.AiExplanation
                        </div>
                    </div>
                }

                <div class="info-grid">
                    <div class="info-item">
                        Người tạo:
                        <strong>@(Model.CreatedByNavigation != null ? Model.CreatedByNavigation.FullName : "Người dùng hệ thống")</strong>
                    </div>
                    <div class="info-item">
                        Ngày tạo:
                        <strong>@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</strong>
                    </div>
                    @if (Model.ApprovedByNavigation != null)
                    {
                        <div class="info-item">
                            Người duyệt:
                            <strong>@Model.ApprovedByNavigation.FullName</strong>
                        </div>
                    }
                </div>
            </div>

            <div class="card-footer">
                <a href="/Question" class="btn btn-outline">Trở về</a>
                <a href="/Question/Edit/@Model.Id" class="btn btn-primary">
                    <i class="fa-solid fa-pen-to-square"></i> Chỉnh sửa câu hỏi
                </a>
            </div>
        </div>
    </div>

</body>
</html>
