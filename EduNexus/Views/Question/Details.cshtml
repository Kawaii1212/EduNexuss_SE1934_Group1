@model EduNexus.Models.Question
@{
    Layout = "~/Views/Shared/_SmeLayout.cshtml";
    ViewData["Title"] = "Chi tiết câu hỏi - EduNexus";
    ViewData["ActiveMenu"] = "MyCourses";
    ViewData["ActiveSubMenu"] = "Question";
}

<style>
    .question-details-page {
        --d-primary: #5c24ff;
        --d-primary-light: #9b8cf8;
        --d-primary-lighter: #f0edff;
        --d-surface: #fff;
        --d-text: #111827;
        --d-muted: #6b7280;
        --d-border: #e5e7eb;
        --d-success: #10b981;
        --d-radius: 12px;
        --d-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    .question-details-page .page-header {
        background: var(--d-surface);
        border: 1px solid var(--d-border);
        border-radius: var(--d-radius);
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 16px 24px;
        margin-bottom: 24px;
    }

    .question-details-page .back-btn {
        color: var(--d-muted);
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
        padding: 8px 14px;
        border: 1px solid var(--d-border);
        border-radius: 8px;
        background: var(--d-surface);
    }

    .question-details-page .back-btn:hover {
        color: var(--d-text);
        background: #f8fafc;
        border-color: var(--d-muted);
    }

    .question-details-page .page-badge {
        background: var(--d-primary-lighter);
        color: var(--d-primary);
        padding: 8px 16px;
        border-radius: 100px;
        font-size: 13px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .question-details-page .card {
        background: var(--d-surface);
        border: 1px solid var(--d-border);
        border-radius: var(--d-radius);
        box-shadow: var(--d-shadow);
        overflow: hidden;
        max-width: 800px;
        margin: 0 auto;
    }

    .question-details-page .card-header {
        padding: 20px 24px;
        background: #fafafa;
        border-bottom: 1px solid var(--d-border);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .question-details-page .card-header h2 {
        font-size: 18px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--d-text);
        margin: 0;
    }

    .question-details-page .card-body {
        padding: 30px;
    }

    .question-details-page .meta-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 24px;
        padding-bottom: 20px;
        border-bottom: 1px solid var(--d-border);
    }

    .question-details-page .meta-item {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .question-details-page .meta-label {
        font-size: 12px;
        font-weight: 700;
        color: var(--d-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .question-details-page .meta-value {
        font-size: 14px;
        font-weight: 600;
        color: var(--d-text);
    }

    .question-details-page .q-content-box {
        background: #f8fafc;
        border: 1px solid var(--d-border);
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 24px;
    }

    .question-details-page .q-content-title {
        font-size: 12px;
        font-weight: 700;
        color: var(--d-muted);
        text-transform: uppercase;
        margin-bottom: 8px;
    }

    .question-details-page .q-content-text {
        font-size: 16px;
        font-weight: 700;
        color: var(--d-text);
        line-height: 1.5;
    }

    .question-details-page .options-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-bottom: 24px;
    }

    .question-details-page .option-item {
        border: 1px solid var(--d-border);
        border-radius: 8px;
        padding: 14px 18px;
        font-size: 14px;
        display: flex;
        align-items: center;
        gap: 12px;
        transition: all 0.2s;
    }

    .question-details-page .option-item.correct {
        border-color: var(--d-success);
        background-color: #ecfdf5;
        color: #065f46;
        font-weight: 600;
    }

    .question-details-page .option-prefix {
        font-weight: 800;
        color: var(--d-primary);
    }

    .question-details-page .option-item.correct .option-prefix {
        color: var(--d-success);
    }

    .question-details-page .explanation-box {
        background: #fafaff;
        border: 1px solid var(--d-primary-light);
        border-left: 4px solid var(--d-primary);
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 24px;
    }

    .question-details-page .explanation-title {
        font-size: 13px;
        font-weight: 700;
        color: var(--d-primary);
        margin-bottom: 6px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .question-details-page .explanation-text {
        font-size: 14px;
        color: #475569;
        line-height: 1.6;
    }

    .question-details-page .card-footer-actions {
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        border-top: 1px solid var(--d-border);
        padding-top: 24px;
        margin-top: 12px;
    }

    .question-details-page .btn {
        padding: 11px 24px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        border: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
        text-decoration: none;
    }

    .question-details-page .btn-primary {
        background: linear-gradient(135deg, var(--d-primary), #8b5cf6);
        color: #fff;
        box-shadow: 0 4px 10px rgba(92, 36, 255, 0.2);
    }

    .question-details-page .btn-primary:hover {
        transform: translateY(-1px);
        opacity: 0.95;
    }

    .question-details-page .btn-outline {
        background: var(--d-surface);
        border: 1px solid var(--d-border);
        color: var(--d-text);
    }

    .question-details-page .btn-outline:hover {
        background: #f8fafc;
        border-color: var(--d-muted);
    }
</style>

<div class="question-details-page">
    <div class="page-header">
        <a href="/Question/Index?courseId=@ViewBag.ActiveCourseId" class="back-btn">
            <i class="fa-solid fa-arrow-left"></i> Trở về Ngân hàng
        </a>
        <div class="page-badge">
            <i class="fa-solid fa-eye"></i> Chi tiết câu hỏi
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h2>
                <i class="fa-solid fa-circle-info" style="color:var(--d-primary)"></i>
                Thông tin câu hỏi #@Model.Id
            </h2>
            <div style="font-size: 12px; font-weight: 600; color: var(--d-muted)">
                Trạng thái: <span class="badge" style="background: #eef2f6; color: #475569; padding: 4px 8px; border-radius: 4px;">@Model.Status</span>
            </div>
        </div>
        
        <div class="card-body">
            <div class="meta-grid">
                <div class="meta-item">
                    <span class="meta-label">Thuộc Chương (Module)</span>
                    <span class="meta-value">Chương @Model.Module.OrderNo: @Model.Module.Title</span>
                </div>
                <div class="meta-item">
                    <span class="meta-label">Độ khó</span>
                    <span class="meta-value" style="text-transform: capitalize;">@Model.Difficulty.ToLower()</span>
                </div>
                <div class="meta-item">
                    <span class="meta-label">Nguồn câu hỏi</span>
                    <span class="meta-value">@Model.Source</span>
                </div>
                <div class="meta-item">
                    <span class="meta-label">Ngày tạo</span>
                    <span class="meta-value">@Model.CreatedAt.ToString("g")</span>
                </div>
            </div>

            <div class="q-content-box">
                <div class="q-content-title">Nội dung câu hỏi</div>
                <div class="q-content-text">@Model.Content</div>
            </div>

            <div class="q-content-title" style="margin-bottom: 8px;">Các phương án lựa chọn</div>
            <div class="options-list">
                <div class="option-item @(Model.CorrectOption == "A" ? "correct" : "")">
                    @if (Model.CorrectOption == "A") { <i class="fa-solid fa-circle-check"></i> }
                    else { <i class="fa-regular fa-circle"></i> }
                    <span class="option-prefix">Phương án A:</span> @Model.OptionA
                </div>
                <div class="option-item @(Model.CorrectOption == "B" ? "correct" : "")">
                    @if (Model.CorrectOption == "B") { <i class="fa-solid fa-circle-check"></i> }
                    else { <i class="fa-regular fa-circle"></i> }
                    <span class="option-prefix">Phương án B:</span> @Model.OptionB
                </div>
                <div class="option-item @(Model.CorrectOption == "C" ? "correct" : "")">
                    @if (Model.CorrectOption == "C") { <i class="fa-solid fa-circle-check"></i> }
                    else { <i class="fa-regular fa-circle"></i> }
                    <span class="option-prefix">Phương án C:</span> @Model.OptionC
                </div>
                <div class="option-item @(Model.CorrectOption == "D" ? "correct" : "")">
                    @if (Model.CorrectOption == "D") { <i class="fa-solid fa-circle-check"></i> }
                    else { <i class="fa-regular fa-circle"></i> }
                    <span class="option-prefix">Phương án D:</span> @Model.OptionD
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.AiExplanation))
            {
                <div class="explanation-box">
                    <div class="explanation-title">
                        <i class="fa-regular fa-lightbulb"></i> Giải thích đáp án đúng
                    </div>
                    <div class="explanation-text">@Model.AiExplanation</div>
                </div>
            }

            <div class="card-footer-actions">
                <a href="/Question/Index?courseId=@ViewBag.ActiveCourseId" class="btn btn-outline">Quay lại danh sách</a>
                <a href="/Question/Edit/@Model.Id" class="btn btn-primary">
                    <i class="fa-solid fa-pen-to-square"></i> Chỉnh sửa câu hỏi
                </a>
            </div>
        </div>
    </div>
</div>
