@model EduNexus.ViewModels.SmeAssignmentsViewModel
@{
    Layout = "~/Views/Shared/_SmeLayout.cshtml";
    ViewData["Title"] = "Quản lý Assignments";
}

<style>
    /* Header Area */
    .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 32px;
    }

    .header-title h1 {
        font-size: 28px;
        font-weight: 800;
        letter-spacing: -0.025em;
        margin-bottom: 6px;
    }

    .header-title p {
        color: var(--text-muted);
        font-size: 15px;
    }

    .role-badge {
        background: #f1f5f9;
        color: var(--text-main);
        padding: 8px 16px;
        border-radius: 9999px;
        font-weight: 600;
        font-size: 13px;
        border: 1px solid var(--border);
    }

    /* Welcome Banner */
    .welcome-banner {
        background: linear-gradient(135deg, #f59e0b, #d97706);
        border-radius: var(--radius-lg);
        padding: 32px;
        color: white;
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 32px;
        box-shadow: 0 10px 25px -5px rgba(245, 158, 11, 0.25);
        position: relative;
        overflow: hidden;
    }

    .welcome-banner::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -10%;
        width: 300px;
        height: 300px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.08);
        pointer-events: none;
    }

    .banner-text h2 {
        font-size: 26px;
        font-weight: 700;
        margin-bottom: 8px;
    }

    .banner-text p {
        font-size: 15px;
        opacity: 0.95;
        max-width: 500px;
        line-height: 1.5;
    }

    /* Stats Cards */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 24px;
        margin-bottom: 40px;
    }

    .stat-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 24px;
        display: flex;
        align-items: center;
        gap: 20px;
        box-shadow: 0 1px 3px 0 rgba(0,0,0,0.1);
        transition: all 0.3s ease;
    }

    .stat-card:hover {
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        transform: translateY(-2px);
    }

    .stat-icon {
        width: 54px;
        height: 54px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
    }

    .icon-primary { background-color: var(--primary-lighter); color: var(--primary); }
    .icon-success { background-color: #d1fae5; color: var(--success); }
    .icon-warning { background-color: #fffbeb; color: var(--warning); }

    .stat-info h4 {
        color: var(--text-muted);
        font-size: 14px;
        font-weight: 500;
        margin-bottom: 4px;
    }

    .stat-info p {
        font-size: 26px;
        font-weight: 700;
        color: var(--text-main);
    }

    /* Assignment List Area */
    .section-title {
        font-size: 20px;
        font-weight: 700;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .assignments-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: 28px;
    }

    .assignment-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        box-shadow: 0 1px 3px 0 rgba(0,0,0,0.1);
        display: flex;
        flex-direction: column;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .assignment-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);
        border-color: #f59e0b;
    }

    .assignment-img-placeholder {
        height: 140px;
        background: linear-gradient(135deg, #fef3c7, #fde68a);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 54px;
        color: #d97706;
        position: relative;
    }

    .assignment-status-badge {
        position: absolute;
        top: 16px;
        right: 16px;
        padding: 6px 12px;
        border-radius: 9999px;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .badge-draft { background: #f1f5f9; color: #475569; }
    .badge-published { background: #d1fae5; color: #065f46; }
    .badge-closed { background: #fee2e2; color: #991b1b; }

    .assignment-class-tag {
        position: absolute;
        bottom: 16px;
        left: 16px;
        background: rgba(15, 23, 42, 0.6);
        color: white;
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 600;
        backdrop-filter: blur(4px);
    }

    .assignment-body {
        padding: 24px;
        display: flex;
        flex-direction: column;
        flex: 1;
    }

    .assignment-body h3 {
        font-size: 19px;
        font-weight: 700;
        margin-bottom: 10px;
        line-height: 1.4;
        color: var(--text-main);
    }

    .assignment-meta {
        display: flex;
        flex-direction: column;
        gap: 12px;
        padding-top: 16px;
        border-top: 1px solid var(--border);
        margin-top: auto;
        color: var(--text-muted);
        font-size: 13px;
    }

    .assignment-meta span {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .assignment-meta i {
        color: #f59e0b;
        width: 16px;
    }

    .assignment-footer {
        padding: 0 24px 24px 24px;
    }

    .btn-manage {
        display: flex;
        width: 100%;
        padding: 12px;
        background-color: #f8fafc;
        border: 1px solid var(--border);
        color: var(--text-main);
        text-decoration: none;
        border-radius: var(--radius-md);
        font-weight: 600;
        font-size: 14px;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: all 0.2s;
    }

    .assignment-card:hover .btn-manage {
        background-color: #f59e0b;
        color: white;
        border-color: #f59e0b;
        box-shadow: 0 4px 12px rgba(245, 158, 11, 0.15);
    }

    /* Empty State */
    .empty-state {
        grid-column: 1 / -1;
        background: var(--surface);
        border: 1px dashed var(--border);
        border-radius: var(--radius-lg);
        padding: 60px;
        text-align: center;
        color: var(--text-muted);
    }

    .empty-state i {
        font-size: 48px;
        margin-bottom: 16px;
        color: #fcd34d;
    }

    .empty-state h3 {
        font-size: 18px;
        color: var(--text-main);
        margin-bottom: 8px;
    }
</style>

<header class="header">
    <div class="header-title">
        <h1>Quản lý Assignments</h1>
        <p>Khóa học: @Model.CourseTitle</p>
    </div>
    <div class="role-badge">
        Vai trò: SME
    </div>
</header>

<!-- Welcome Banner -->
<section class="welcome-banner">
    <div class="banner-text">
        <h2>Danh sách bài tập, @Model.SmeName!</h2>
        <p>Kiểm tra và quản lý nội dung các bài tập tự luận (Assignment) của khóa học, hỗ trợ theo dõi tiến trình chấm bài.</p>
    </div>
</section>

<!-- Statistics Widget Grid -->
<section class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon icon-primary">
            <i class="fa-solid fa-layer-group"></i>
        </div>
        <div class="stat-info">
            <h4>Tổng số Assignment</h4>
            <p>@Model.TotalAssignments</p>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon icon-success">
            <i class="fa-solid fa-check-double"></i>
        </div>
        <div class="stat-info">
            <h4>Đang mở / Đang hoạt động</h4>
            <p>@Model.ActiveAssignments</p>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon icon-warning">
            <i class="fa-solid fa-lock"></i>
        </div>
        <div class="stat-info">
            <h4>Nháp / Đã đóng</h4>
            <p>@Model.DraftAssignments</p>
        </div>
    </div>
</section>

<div class="section-title" style="justify-content: space-between;">
    <div>
        <i class="fa-solid fa-file-pen" style="color: #f59e0b"></i> Assignments của Khóa học
    </div>
    <a href="/SmeAssignment/Create?courseId=@Model.CourseId" class="btn btn-primary" style="background-color: #f59e0b; border-color: #f59e0b; color: white; padding: 8px 16px; border-radius: 6px; font-size: 14px; text-decoration: none;">
        <i class="fa-solid fa-plus"></i> Tạo Assignment mới
    </a>
</div>

<div class="assignments-grid">
    @if (Model.Assignments != null && Model.Assignments.Any())
    {
        foreach (var assignment in Model.Assignments)
        {
            <div class="assignment-card">
                <div class="assignment-img-placeholder">
                    <i class="fa-solid fa-file-pen"></i>

                    <!-- Status Badge -->
                    @if (assignment.Status == "PUBLISHED" && assignment.DueDate > DateTimeOffset.UtcNow)
                    {
                        <span class="assignment-status-badge badge-published">Đang mở</span>
                    }
                    else if (assignment.Status == "CLOSED" || assignment.DueDate <= DateTimeOffset.UtcNow)
                    {
                        <span class="assignment-status-badge badge-closed">Đã đóng</span>
                    }
                    else
                    {
                        <span class="assignment-status-badge badge-draft">Bản nháp</span>
                    }

                    <span class="assignment-class-tag">Lớp: @assignment.ClassName</span>
                </div>
                <div class="assignment-body">
                    <h3>@assignment.Title</h3>
                    <div class="assignment-meta">
                        <span>
                            <i class="fa-regular fa-clock"></i> Hạn nộp: @assignment.DueDate.ToString("dd/MM/yyyy HH:mm")
                        </span>
                        <span>
                            <i class="fa-solid fa-star"></i> Điểm tối đa: @assignment.MaxScore.ToString("0.0")
                        </span>
                        <span>
                            <i class="fa-solid fa-users"></i> Đã nộp: @assignment.SubmissionCount học viên
                        </span>
                    </div>
                </div>
                <div class="assignment-footer">
                    <a href="/SmeAssignment/Edit?id=@(assignment.Id)" class="btn-manage" title="Sửa Assignment">
                        Sửa chi tiết <i class="fa-solid fa-pen-to-square"></i>
                    </a>
                    <a href="/Grading/Index?classId=@(assignment.Id)" class="btn-manage" style="margin-top: 8px;" title="SME xem dạng view-only hoặc chuyển tới màn hình của giáo viên">
                        Chấm bài <i class="fa-solid fa-arrow-right"></i>
                    </a>
                </div>
            </div>
        }
    }
    else
    {
        <div class="empty-state">
            <i class="fa-solid fa-folder-open"></i>
            <h3>Chưa có bài tập nào</h3>
            <p>Khóa học này chưa có assignment nào được tạo hoặc giao cho các lớp.</p>
        </div>
    }
</div>
