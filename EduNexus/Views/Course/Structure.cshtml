@model EduNexus.ViewModels.SmeCourseStructureViewModel
@using System.Text.Encodings.Web
@{
    Layout = "~/Views/Shared/_SmeLayout.cshtml";
    ViewData["Title"] = "Cấu trúc khóa học";
    ViewData["ActiveMenu"] = "MyCourses";
}

<style>
    /* Header Area */
    .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
    }

    .header-left {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--primary);
        text-decoration: none;
        font-weight: 600;
        font-size: 14px;
        margin-bottom: 8px;
        transition: color 0.2s;
    }

    .back-link:hover {
        color: var(--primary-hover);
    }

    .header-left h1 {
        font-size: 28px;
        font-weight: 800;
        letter-spacing: -0.025em;
        color: var(--text-main);
    }

    .header-left p {
        color: var(--text-muted);
        font-size: 15px;
    }

    .course-badges {
        display: flex;
        gap: 12px;
    }

    .badge-item {
        padding: 6px 14px;
        border-radius: 9999px;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        border: 1px solid var(--border);
    }

    .badge-status-published { background: #d1fae5; color: #065f46; border-color: #a7f3d0; }
    .badge-status-draft { background: #f1f5f9; color: #475569; }
    .badge-status-pending { background: #fef3c7; color: #d97706; border-color: #fde68a; }
    .badge-group { background: #f0edff; color: var(--primary); border-color: #dcd7ff; }

    /* Module Section */
    .modules-container {
        display: flex;
        flex-direction: column;
        gap: 20px;
        margin-top: 24px;
    }

    .module-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        box-shadow: 0 1px 3px 0 rgba(0,0,0,0.05);
        overflow: hidden;
        transition: border-color 0.2s;
    }

    .module-card:hover {
        border-color: var(--primary-light);
    }

    /* Module Header/Toggle Button */
    .module-header {
        width: 100%;
        padding: 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: none;
        border: none;
        text-align: left;
        cursor: pointer;
        outline: none;
    }

    .module-header-left {
        display: flex;
        align-items: center;
        gap: 16px;
        flex: 1;
    }

    .module-number {
        width: 44px;
        height: 44px;
        border-radius: 10px;
        background-color: var(--primary-lighter);
        color: var(--primary);
        font-weight: 700;
        font-size: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .module-title-desc h3 {
        font-size: 18px;
        font-weight: 700;
        color: var(--text-main);
        margin-bottom: 4px;
    }

    .module-title-desc p {
        color: var(--text-muted);
        font-size: 13.5px;
    }

    .module-header-right {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .chevron-icon {
        font-size: 18px;
        color: var(--text-muted);
        transition: transform 0.3s;
    }

    .module-card.expanded .chevron-icon {
        transform: rotate(180deg);
    }

    /* Module Content Expandable Panel */
    .module-content-panel {
        display: none;
        border-top: 1px solid var(--border);
        background-color: #fafbfd;
        padding: 24px;
    }

    .module-card.expanded .module-content-panel {
        display: block;
    }

    .btn-disabled {
        background-color: #f1f5f9;
        color: #94a3b8;
        cursor: not-allowed;
        pointer-events: none;
    }

    .btn-add-lesson-large {
        transition: all 0.2s ease-in-out;
    }
    .btn-add-lesson-large:hover {
        background-color: var(--primary-lighter) !important;
        border-color: var(--primary) !important;
        transform: translateY(-1px);
    }

    .btn-quizzes-small {
        transition: all 0.2s ease-in-out;
    }
    .btn-quizzes-small:hover {
        background-color: #10b981 !important;
        color: white !important;
        transform: translateY(-1px);
    }
</style>

<div class="header">
    <div class="header-left">
        <a href="/Course/MyCourses" class="back-link">
            <i class="fa-solid fa-arrow-left"></i> Quay lại danh sách khóa học
        </a>
        <h1>@Model.CourseTitle</h1>
        <p>Phân tích cấu trúc chi tiết, quản lý bài học và ngân hàng câu hỏi của khóa học</p>
    </div>
    <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 12px;">
        <div class="course-badges">
            @if (!string.IsNullOrEmpty(Model.CourseGroupName))
            {
                <span class="badge-item badge-group">@Model.CourseGroupName</span>
            }
            @if (Model.Status == "PUBLISHED")
            {
                <span class="badge-item badge-status-published">Đang chạy</span>
            }
            else if (Model.Status == "PENDING_REVIEW")
            {
                <span class="badge-item badge-status-pending">Chờ duyệt</span>
            }
            else
            {
                <span class="badge-item badge-status-draft">Bản nháp</span>
            }
        </div>
        <a href="/Course/CreateModule?courseId=@Model.CourseId" class="btn text-white px-3 py-2 border-0" style="background: var(--primary); border-radius: var(--radius-md); font-weight: 600; box-shadow: 0 4px 12px rgba(92, 36, 255, 0.2); font-size: 13px; text-decoration: none; display: inline-flex; align-items: center; gap: 6px;">
            <i class="fa-solid fa-plus"></i> Thêm chương mới
        </a>
    </div>
</div>

<div class="modules-container">
    @if (Model.Modules != null && Model.Modules.Any())
    {
        int index = 0;
        foreach (var module in Model.Modules)
        {
            index++;
            <div class="module-card" id="module-card-@module.Id">
                <div class="module-header" onclick="toggleModule(@module.Id)" style="cursor: pointer; display: flex; justify-content: space-between; align-items: center; width: 100%; padding: 24px;">
                    <div class="module-header-left">
                        <div class="module-number">@index</div>
                        <div class="module-title-desc">
                            <h3>Chương @index: @module.Title</h3>
                            <p>@(string.IsNullOrEmpty(module.Description) ? "Chương học chưa cập nhật mô tả chi tiết." : module.Description)</p>
                        </div>
                    </div>
                    <div class="module-header-right" style="display: flex; align-items: center; gap: 8px;">
                        <a href="/Course/EditModule?moduleId=@module.Id" onclick="event.stopPropagation();" class="text-primary" style="display: inline-flex; align-items: center; gap: 6px; padding: 6px 12px; border: 1px solid var(--primary-light); border-radius: 6px; background-color: var(--primary-lighter); color: var(--primary); text-decoration: none; font-size: 12.5px; font-weight: 600; transition: all 0.2s;" title="Sửa chương học">
                            <i class="fa-solid fa-pen-to-square"></i> Sửa
                        </a>
                        <form asp-controller="Course" asp-action="DeleteModule" asp-route-moduleId="@module.Id" method="post" style="display:inline; margin: 0; padding: 0;" onclick="event.stopPropagation();" onsubmit="return confirm('Bạn có chắc chắn muốn xóa chương học này? Tất cả bài học và câu hỏi trong chương cũng sẽ bị xóa. Hành động này không thể hoàn tác.')">
                            @Html.AntiForgeryToken()
                            <button type="submit" style="display: inline-flex; align-items: center; gap: 6px; padding: 6px 12px; border: 1px solid #fca5a5; border-radius: 6px; background-color: #fef2f2; color: var(--danger); font-size: 12.5px; font-weight: 600; cursor: pointer; transition: all 0.2s;" title="Xóa chương học">
                                <i class="fa-solid fa-trash-can"></i> Xóa
                            </button>
                        </form>
                        <i class="fa-solid fa-chevron-down chevron-icon" style="margin-left: 8px;"></i>
                    </div>
                </div>

                <div class="module-content-panel">
                    <!-- Danh sách bài học dọc -->
                    <div class="lessons-vertical-list" style="display: flex; flex-direction: column; gap: 10px; margin-bottom: 16px;">
                        @if (module.Lessons.Any())
                        {
                            int lessonIdx = 0;
                            foreach (var lesson in module.Lessons)
                            {
                                lessonIdx++;
                                <div class="lesson-item-row" style="display: flex; align-items: center; justify-content: space-between; padding: 12px 18px; background: white; border: 1px solid var(--border); border-radius: 8px; box-shadow: 0 1px 2px rgba(0,0,0,0.02); transition: all 0.2s;">
                                    <div style="display: flex; align-items: center; gap: 12px;">
                                        <div style="width: 24px; height: 24px; border-radius: 50%; background: #f0edff; color: var(--primary); font-size: 11px; font-weight: 700; display: flex; align-items: center; justify-content: center;">
                                            @lessonIdx
                                        </div>
                                        <span style="font-weight: 600; font-size: 13.5px; color: var(--text-main);">@lesson.Title</span>
                                    </div>
                                    <div style="display: flex; align-items: center; gap: 16px;">
                                        <!-- Nút Sửa bài học -->
                                        <a href="/Lesson/LessonEditor?id=@lesson.Id" onclick="event.stopPropagation();" style="text-decoration: none; color: var(--primary); font-size: 13px; font-weight: 600; padding: 0; display: inline-flex; align-items: center; gap: 4px;" title="Sửa chi tiết bài học">
                                            <i class="fa-solid fa-pen-to-square"></i> Sửa
                                        </a>
                                        <!-- Nút Xóa bài học -->
                                        <form asp-controller="Course" asp-action="DeleteLesson" asp-route-lessonId="@lesson.Id" method="post" style="display:inline; margin: 0; padding: 0;" onclick="event.stopPropagation();" onsubmit="return confirm('Bạn có chắc chắn muốn xóa bài học này?')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" style="background: none; border: none; color: var(--danger); font-size: 13px; font-weight: 600; cursor: pointer; padding: 0; display: inline-flex; align-items: center; gap: 4px;" title="Xóa bài học">
                                                <i class="fa-solid fa-trash-can"></i> Xóa
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div style="text-align: center; padding: 32px 24px; background: white; border: 1px dashed var(--border); border-radius: 8px; color: var(--text-muted); font-style: italic; font-size: 13.5px;">
                                <i class="fa-solid fa-graduation-cap" style="font-size: 24px; color: var(--text-light); margin-bottom: 8px; display: block;"></i>
                                Chưa có bài học nào trong chương này
                            </div>
                        }
                    </div>

                    <!-- Nút thêm bài học siêu to khổng lồ rộng 100% -->
                    <a href="/Lesson/LessonEditor?moduleId=@module.Id" class="btn-add-lesson-large" style="width: 100%; padding: 16px; background: #faf8ff; border: 2px dashed var(--primary-light); border-radius: 10px; color: var(--primary); font-weight: 700; font-size: 14.5px; display: flex; align-items: center; justify-content: center; gap: 8px; cursor: pointer; text-decoration: none; transition: all 0.2s; outline: none;">
                        <i class="fa-solid fa-plus" style="font-size: 15px;"></i> Thêm bài học mới
                    </a>

                    <!-- Nút quizzes nhỏ ở dưới, hiển thị câu hỏi của riêng module đó -->
                    <div style="display: flex; justify-content: flex-end; margin-top: 14px;">
                        <a href="/Question/ViewQuestions?moduleId=@module.Id" class="btn-quizzes-view-small" style="display: inline-flex; align-items: center; gap: 6px; padding: 6px 12px; border: 1px solid #3b82f6; border-radius: 6px; background-color: #eff6ff; color: #3b82f6; text-decoration: none; font-size: 12px; font-weight: 600; transition: all 0.2s;" title="Xem câu hỏi của chương (Chỉ đọc)">
                            <i class="fa-solid fa-eye"></i> Xem câu hỏi
                        </a>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="empty-state" style="background: white; border: 1px dashed var(--border); border-radius: var(--radius-lg); padding: 60px; text-align: center;">
            <i class="fa-solid fa-cubes" style="font-size: 40px; color: var(--text-light); margin-bottom: 16px;"></i>
            <h3>Chưa có chương học nào</h3>
            <p>Khóa học này chưa được cấu hình các chương (modules).</p>
        </div>
    }
</div>

<!-- Modal Thêm bài học -->
<div class="modal fade" id="addLessonModal" tabindex="-1" aria-labelledby="addLessonModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: var(--radius-lg); border: none; overflow: hidden; box-shadow: 0 10px 25px rgba(0,0,0,0.15);">
            <div class="modal-header" style="background: #fafafa; border-bottom: 1px solid var(--border); padding: 16px 24px;">
                <h5 class="modal-title fw-bold" id="addLessonModalLabel" style="font-size: 16px; color: var(--text-main);">
                    <i class="fa-solid fa-circle-plus" style="color: var(--primary); margin-right: 6px;"></i> Thêm bài học mới
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-controller="Course" asp-action="CreateLesson" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body" style="padding: 24px;">
                    <input type="hidden" name="ModuleId" id="modalModuleId" />
                    <div class="form-group mb-0">
                        <label for="modalLessonTitle" class="form-label fw-semibold mb-2" style="font-size: 13.5px; color: var(--text-main);">Tên bài học (Tiêu đề)</label>
                        <input type="text" name="Title" id="modalLessonTitle" class="form-control" placeholder="Ví dụ: Bài 1: Cài đặt môi trường phát triển" required style="padding: 10px 14px; border-radius: 8px; border: 1px solid var(--border); font-size: 13.5px;" />
                    </div>
                </div>
                <div class="modal-footer" style="background: #f8fafc; border-top: 1px solid var(--border); padding: 12px 24px;">
                    <button type="button" class="btn btn-outline" data-bs-dismiss="modal" style="padding: 8px 16px; border: 1px solid var(--border); border-radius: 6px; font-size: 13px; font-weight: 600; color: var(--text-muted); background: none; transition: all 0.2s;">Hủy bỏ</button>
                    <button type="submit" class="btn text-white" style="padding: 8px 16px; border-radius: 6px; font-size: 13px; font-weight: 600; background: var(--primary); border: none; box-shadow: 0 4px 10px rgba(92, 36, 255, 0.2); transition: all 0.2s;">Lưu bài học</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Sửa bài học -->
<div class="modal fade" id="editLessonModal" tabindex="-1" aria-labelledby="editLessonModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: var(--radius-lg); border: none; overflow: hidden; box-shadow: 0 10px 25px rgba(0,0,0,0.15);">
            <div class="modal-header" style="background: #fafafa; border-bottom: 1px solid var(--border); padding: 16px 24px;">
                <h5 class="modal-title fw-bold" id="editLessonModalLabel" style="font-size: 16px; color: var(--text-main);">
                    <i class="fa-solid fa-pen-to-square" style="color: var(--primary); margin-right: 6px;"></i> Chỉnh sửa bài học
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-controller="Course" asp-action="EditLesson" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body" style="padding: 24px;">
                    <input type="hidden" name="Id" id="editLessonId" />
                    <div class="form-group mb-0">
                        <label for="editLessonTitle" class="form-label fw-semibold mb-2" style="font-size: 13.5px; color: var(--text-main);">Tên bài học (Tiêu đề)</label>
                        <input type="text" name="Title" id="editLessonTitle" class="form-control" placeholder="Ví dụ: Bài 1: Cấu trúc cơ bản" required style="padding: 10px 14px; border-radius: 8px; border: 1px solid var(--border); font-size: 13.5px;" />
                    </div>
                </div>
                <div class="modal-footer" style="background: #f8fafc; border-top: 1px solid var(--border); padding: 12px 24px;">
                    <button type="button" class="btn btn-outline" data-bs-dismiss="modal" style="padding: 8px 16px; border: 1px solid var(--border); border-radius: 6px; font-size: 13px; font-weight: 600; color: var(--text-muted); background: none;">Hủy bỏ</button>
                    <button type="submit" class="btn text-white" style="padding: 8px 16px; border-radius: 6px; font-size: 13px; font-weight: 600; background: var(--primary); border: none; box-shadow: 0 4px 10px rgba(92, 36, 255, 0.2);">Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function toggleModule(moduleId) {
        const card = document.getElementById('module-card-' + moduleId);
        if (card) {
            card.classList.toggle('expanded');
        }
    }

    function openAddLessonModal(moduleId) {
        document.getElementById('modalModuleId').value = moduleId;
        document.getElementById('modalLessonTitle').value = '';
        var myModal = new bootstrap.Modal(document.getElementById('addLessonModal'));
        myModal.show();
    }

    function openEditLessonModal(lessonId, title) {
        document.getElementById('editLessonId').value = lessonId;
        document.getElementById('editLessonTitle').value = title;
        var myModal = new bootstrap.Modal(document.getElementById('editLessonModal'));
        myModal.show();
    }

    // Expand the first module automatically on load
    document.addEventListener("DOMContentLoaded", function() {
        const firstCard = document.querySelector('.module-card');
        if (firstCard) {
            firstCard.classList.add('expanded');
        }
    });
</script>
