@model EduNexus.ViewModels.FlashcardStagingViewModel
@{
    Layout = "~/Views/Shared/_SmeLayout.cshtml";
    ViewData["Title"] = "AI Flashcard Staging";
    ViewData["ActiveMenu"] = "MyCourses";
    ViewData["ActiveSubMenu"] = "Flashcards";
}

<div class="container-fluid py-3">
    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success">@Model.SuccessMessage</div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2>AI Flashcard Staging</h2>
            <p class="text-muted mb-0">@Model.DeckName</p>
        </div>
        <a asp-action="Editor" asp-route-courseId="@Model.CourseId" asp-route-deckId="@Model.DeckId"
           class="btn btn-outline-secondary btn-sm">Quay lại Editor</a>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card">
                <div class="card-header">Sinh flashcard bằng AI</div>
                <div class="card-body">
                    <form asp-action="Generate" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Form.DeckId" />
                        <div class="mb-3">
                            <label asp-for="Form.Topic" class="form-label">Chủ đề *</label>
                            <textarea asp-for="Form.Topic" class="form-control" rows="3" placeholder="Ví dụ: Từ vựng tiếng Anh giao tiếp A1"></textarea>
                            <span asp-validation-for="Form.Topic" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Form.CardCount" class="form-label">Số thẻ</label>
                            <input asp-for="Form.CardCount" type="number" min="1" max="30" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="Form.SourceMaterial" class="form-label">Tài liệu nguồn (tuỳ chọn)</label>
                            <textarea asp-for="Form.SourceMaterial" class="form-control" rows="4"></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fa-solid fa-wand-magic-sparkles"></i> Generate by AI
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">Thẻ chờ duyệt (@Model.StagedCards.Count)</h5>
                @if (Model.StagedCards.Any())
                {
                    <form asp-action="ApproveAll" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="deckId" value="@Model.DeckId" />
                        <button type="submit" class="btn btn-success btn-sm">Approve All</button>
                    </form>
                }
            </div>

            @if (!Model.StagedCards.Any())
            {
                <div class="alert alert-info">Chưa có thẻ AI nào trong staging.</div>
            }
            else
            {
                @foreach (var card in Model.StagedCards)
                {
                    <div class="card mb-3">
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <small class="text-muted">Mặt trước</small>
                                    <p class="mb-0">@card.FrontText</p>
                                </div>
                                <div class="col-md-6">
                                    <small class="text-muted">Mặt sau</small>
                                    <p class="mb-0">@card.BackText</p>
                                </div>
                            </div>
                            <div class="mt-3 d-flex gap-2">
                                <form asp-action="ApproveCard" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="cardId" value="@card.Id" />
                                    <input type="hidden" name="deckId" value="@Model.DeckId" />
                                    <button type="submit" class="btn btn-sm btn-success">Approve</button>
                                </form>
                                <form asp-action="RejectCard" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="cardId" value="@card.Id" />
                                    <input type="hidden" name="deckId" value="@Model.DeckId" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Reject</button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
