@model EduNexus.ViewModels.SmeFlashcardListViewModel
@{
    Layout = "~/Views/Shared/_SmeLayout.cshtml";
    ViewData["Title"] = "Flashcard Decks";
    ViewData["ActiveMenu"] = "MyCourses";
    ViewData["ActiveSubMenu"] = "Flashcards";
}

<style>
    .flashcard-page .page-header {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: 20px 24px;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        box-shadow: 0 1px 2px rgba(0,0,0,.04);
    }

    .flashcard-page .page-header h2 {
        font-size: 22px;
        font-weight: 700;
        margin-bottom: 4px;
    }

    .flashcard-page .filter-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: 20px;
        margin-bottom: 24px;
    }

    .flashcard-page .data-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        overflow: hidden;
        box-shadow: 0 1px 2px rgba(0,0,0,.04);
    }

    .flashcard-page .data-card .card-head {
        padding: 16px 24px;
        border-bottom: 1px solid var(--border);
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .flashcard-page table { width: 100%; border-collapse: collapse; }
    .flashcard-page th {
        text-align: left;
        padding: 14px 20px;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: .04em;
        color: var(--text-muted);
        background: #f8fafc;
        border-bottom: 1px solid var(--border);
    }
    .flashcard-page td {
        padding: 16px 20px;
        border-bottom: 1px solid var(--border);
        vertical-align: middle;
    }
    .flashcard-page tr:last-child td { border-bottom: none; }
    .flashcard-page tr:hover td { background: #fafbff; }

    .flashcard-page .status-pill {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 600;
    }
    .flashcard-page .status-pill.published { background: #ecfdf5; color: #059669; }
    .flashcard-page .status-pill.draft { background: #f1f5f9; color: #64748b; }

    .flashcard-page .empty-state {
        text-align: center;
        padding: 48px 24px;
        color: var(--text-muted);
    }
    .flashcard-page .empty-state i { font-size: 40px; margin-bottom: 12px; opacity: .5; }
</style>

<div class="flashcard-page">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success border-0 mb-4">
            <i class="fa-solid fa-circle-check me-2"></i>@TempData["SuccessMessage"]
        </div>
    }

    <div class="page-header">
        <div>
            <h2><i class="fa-solid fa-clone me-2" style="color:var(--primary)"></i>Flashcard Decks</h2>
            <p class="text-muted mb-0">@Model.CourseTitle</p>
        </div>
        <a asp-action="Editor" asp-route-courseId="@Model.CourseId" asp-route-moduleId="@Model.ModuleId"
           class="btn btn-primary">
            <i class="fa-solid fa-plus"></i> Tạo bộ thẻ mới
        </a>
    </div>

    <div class="filter-card">
        <form method="get" class="row g-3 align-items-end">
            <input type="hidden" name="courseId" value="@Model.CourseId" />
            <div class="col-md-4">
                <label class="form-label small text-muted">Module</label>
                <select name="moduleId" class="form-select">
                    <option value="">Tất cả module</option>
                    @foreach (var m in Model.Modules)
                    {
                        <option value="@m.Id" selected="@(Model.ModuleId == m.Id)">@m.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label small text-muted">Tìm kiếm</label>
                <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="Tìm theo tên bộ thẻ..." />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-outline-secondary w-100">
                    <i class="fa-solid fa-filter"></i> Lọc
                </button>
            </div>
        </form>
    </div>

    <div class="data-card">
        <div class="card-head">
            <i class="fa-solid fa-layer-group" style="color:var(--primary)"></i>
            Danh sách bộ thẻ
            <span class="badge bg-light text-dark">@Model.Decks.Count</span>
        </div>

        @if (!Model.Decks.Any())
        {
            <div class="empty-state">
                <div><i class="fa-regular fa-folder-open"></i></div>
                <p class="mb-0">Chưa có bộ flashcard nào.</p>
            </div>
        }
        else
        {
            <table>
                <thead>
                    <tr>
                        <th>Tên bộ thẻ</th>
                        <th>Module</th>
                        <th>Chủ đề</th>
                        <th>Số thẻ</th>
                        <th>Trạng thái</th>
                        <th style="text-align:right">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var deck in Model.Decks)
                    {
                        <tr>
                            <td><strong>@deck.Name</strong></td>
                            <td>@(deck.ModuleName ?? "—")</td>
                            <td>@(deck.Category ?? "—")</td>
                            <td>@deck.CardCount</td>
                            <td>
                                <span class="status-pill @(deck.Status == "PUBLISHED" ? "published" : "draft")">
                                    @deck.Status
                                </span>
                            </td>
                            <td style="text-align:right">
                                <a asp-action="Editor" asp-route-courseId="@Model.CourseId" asp-route-deckId="@deck.Id"
                                   class="btn btn-sm btn-outline-primary">Sửa</a>
                                <a asp-action="Staging" asp-route-deckId="@deck.Id"
                                   class="btn btn-sm btn-outline-info">AI Staging</a>
                                <form asp-action="DeleteDeck" method="post" class="d-inline"
                                      onsubmit="return confirm('Xóa bộ thẻ này?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="deckId" value="@deck.Id" />
                                    <input type="hidden" name="courseId" value="@Model.CourseId" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
