@model EduNexus.ViewModels.ResetPasswordViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password - EduNexus</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #5c24ff;
            --primary-light: #9b8cf8;
            --bg-color: #ffffff;
            --text-main: #000000;
            --text-muted: #6b7280;
            --input-bg: #f3f4f6;
            --border-color: #e5e7eb;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            display: flex;
            min-height: 100vh;
            background-color: var(--bg-color);
        }

        .left-panel {
            flex: 1.1;
            display: flex;
            flex-direction: column;
            padding: 40px;
            position: relative;
        }

        .top-nav {
            font-size: 14px;
            color: var(--text-main);
            margin-bottom: auto;
        }

        .top-nav a {
            color: var(--primary);
            text-decoration: none;
            font-weight: 600;
        }

        .form-container {
            max-width: 420px;
            width: 100%;
            margin: 0 auto;
            margin-bottom: auto;
        }

        .form-container h1 {
            font-size: 36px;
            font-weight: 800;
            color: var(--text-main);
            margin-bottom: 10px;
        }

        .form-container p {
            color: var(--text-muted);
            margin-bottom: 40px;
            font-size: 14px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-control {
            width: 100%;
            padding: 16px;
            background-color: var(--input-bg);
            border: none;
            border-radius: 8px;
            font-size: 14px;
            color: var(--text-main);
            outline: none;
            transition: 0.2s;
        }

        .form-control::placeholder {
            color: #9ca3af;
        }

        .form-control:focus {
            box-shadow: 0 0 0 2px var(--primary-light);
        }

        .btn-primary {
            width: 100%;
            padding: 16px;
            background-color: var(--primary-light);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
            margin-top: 10px;
        }

        .btn-primary:hover {
            background-color: var(--primary);
        }

        .right-panel {
            flex: 0.9;
            background-color: var(--primary);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 60px;
        }

        .right-panel h1 {
            color: white;
            font-size: 64px;
            font-weight: 800;
            line-height: 1.2;
            letter-spacing: -1px;
        }

        .alert-success {
            background-color: #d1fae5;
            color: #065f46;
            padding: 12px;
            border-radius: 8px;
            margin-bottom: 20px;
            font-size: 14px;
        }

        @@media (max-width: 900px) {
            body {
                flex-direction: column;
            }
            .right-panel {
                display: none;
            }
        }
    </style>
</head>
<body>

    <div class="left-panel">
        <div class="top-nav">
            <a href="@Url.Action("UserLogin", "Auth")">Back to Sign In</a>
        </div>
        
        <div class="form-container">
            <h1>Reset Password</h1>
            <p>Enter the 6-digit verification code sent to your email and your new password.</p>
            
            @if (TempData["Success"] != null)
            {
                <div class="alert-success">@TempData["Success"]</div>
            }

            <form asp-action="ResetPassword" method="POST">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="ModelOnly" class="text-danger" style="color:red; margin-bottom:15px; font-size:14px;"></div>
                }

                <input type="hidden" asp-for="Email" />

                <div class="form-group">
                    <input asp-for="Code" class="form-control" placeholder="6-digit verification code" required maxlength="6">
                    <span asp-validation-for="Code" style="color:red; font-size: 12px; margin-top: 5px; display: block;"></span>
                </div>
                
                <div class="form-group">
                    <input asp-for="NewPassword" type="password" class="form-control" placeholder="New Password" required>
                    <span asp-validation-for="NewPassword" style="color:red; font-size: 12px; margin-top: 5px; display: block;"></span>
                </div>
                
                <div class="form-group">
                    <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Confirm New Password" required>
                    <span asp-validation-for="ConfirmPassword" style="color:red; font-size: 12px; margin-top: 5px; display: block;"></span>
                </div>
                
                <button type="submit" class="btn-primary">Reset Password</button>
            </form>
        </div>
    </div>

    <div class="right-panel">
        <h1>Let Study<br>ON TIME.</h1>
    </div>

</body>
</html>
